{
  "name": "Bugfix Pipeline",
  "stages": [
    {
      "name": "Diagnose",
      "tasks": [
        {
          "file": "tasks-diagnose.json",
          "max_parallel": 1
        }
      ],
      "pass_outputs_to_next": true
    },
    {
      "name": "Fix",
      "tasks": [
        {
          "file": "tasks-fix.json",
          "max_parallel": 3
        }
      ],
      "pass_outputs_to_next": true
    },
    {
      "name": "Verify",
      "tasks": [
        {
          "file": "tasks-verify.json",
          "max_parallel": 3
        }
      ],
      "pass_outputs_to_next": false
    }
  ],
  "aggregate": true
}
