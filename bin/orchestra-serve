# ---------------------------------------------------------------------------
# User model — file-based storage in <data_dir>/users.json
# ---------------------------------------------------------------------------
# Set by main() once the data directory is resolved.
_USERS_FILE: Path | None = None

_USERS_LOCK = threading.Lock()

_PBKDF2_ITERATIONS = 600_000
_PBKDF2_HASH = "sha256"


def _users_file() -> Path:
    """Return the resolved users.json path (raises RuntimeError if not configured)."""
    if _USERS_FILE is None:
        raise RuntimeError("User store not initialised — call init_user_store() first")
    return _USERS_FILE


def init_user_store(data_dir: Path) -> None:
    """Configure the user store.  Call once from main() after resolving data_dir."""
    global _USERS_FILE
    data_dir.mkdir(parents=True, exist_ok=True)
    _USERS_FILE = data_dir / "users.json"


def _hash_password(password: str) -> str:
    """Return a self-contained password hash string: algorithm$iterations$salt$digest.

    Uses PBKDF2-HMAC-SHA256 with a 32-byte random salt.  The resulting string
    is safe to store verbatim and can be verified with :func:`_verify_password`.
    """
    salt = secrets.token_hex(32)
    digest = hashlib.pbkdf2_hmac(
        _PBKDF2_HASH,
        password.encode(),
        salt.encode(),
        _PBKDF2_ITERATIONS,
    ).hex()
    return f"pbkdf2:{_PBKDF2_HASH}:{_PBKDF2_ITERATIONS}:{salt}:{digest}"


def _verify_password(password: str, stored_hash: str) -> bool:
    """Return True when *password* matches *stored_hash* produced by :func:`_hash_password`."""
    try:
        algo, hash_name, iterations_str, salt, expected = stored_hash.split(":", 4)
        if algo != "pbkdf2":
            return False
        iterations = int(iterations_str)
        digest = hashlib.pbkdf2_hmac(
            hash_name,
            password.encode(),
            salt.encode(),
            iterations,
        ).hex()
        return secrets.compare_digest(digest, expected)
    except (ValueError, TypeError):
        return False


def load_users() -> list[dict]:
    """Load all users from disk.  Returns an empty list when the file does not exist."""
    path = _users_file()
    with _USERS_LOCK:
        if not path.exists():
            return []
        try:
            data = json.loads(path.read_text())
            if not isinstance(data, list):
                return []
            return data
        except (json.JSONDecodeError, OSError):
            return []


def save_users(users: list[dict]) -> None:
    """Persist *users* to disk atomically."""
    path = _users_file()
    with _USERS_LOCK:
        path.parent.mkdir(parents=True, exist_ok=True)
        tmp_fd, tmp_path = tempfile.mkstemp(dir=str(path.parent), suffix=".json.tmp")
        try:
            with os.fdopen(tmp_fd, "w") as f:
                json.dump(users, f, indent=2)
                f.write("\n")
            os.replace(tmp_path, str(path))
        except Exception:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass
            raise


def find_user_by_email(email: str) -> dict | None:
    """Return the user record whose email matches *email* (case-insensitive), or None."""
    normalised = email.strip().lower()
    for user in load_users():
        if user.get("email", "").lower() == normalised:
            return user
    return None


def create_user(email: str, password: str) -> dict:
    """Create a new user, persist it, and return the record (without password_hash).

    Raises ValueError when a user with that email already exists.
    """
    normalised = email.strip().lower()
    if not normalised:
        raise ValueError("email must not be empty")
    if not password:
        raise ValueError("password must not be empty")

    users = load_users()
    for user in users:
        if user.get("email", "").lower() == normalised:
            raise ValueError(f"user with email '{normalised}' already exists")

    record: dict = {
        "id": str(uuid.uuid4()),
        "email": normalised,
        "password_hash": _hash_password(password),
        "created_at": datetime.now(timezone.utc).isoformat(),
    }
    save_users([*users, record])

    # Return a copy without the hash — callers that need authentication
    # should call find_user_by_email() and _verify_password() explicitly.
    return {k: v for k, v in record.items() if k != "password_hash"}


# ---------------------------------------------------------------------------


def _find_repos() -> list[dict]:
    """Scan common directories for git repos (one level deep)."""
    repos = []
    seen = set()
    for scan_dir in WORKSPACE_SCAN_DIRS:
        if not scan_dir.is_dir():
            continue
        for entry in sorted(scan_dir.iterdir()):
            if not entry.is_dir():
                continue
            resolved = entry.resolve()
            if resolved in seen:
                continue
            seen.add(resolved)
            git_dir = entry / ".git"
            if git_dir.exists():
                repos.append({
                    "name": entry.name,
                    "path": str(resolved),
                    "has_git": True,
                })
    return repos


def _find_task_files(repo_path: Path) -> list[dict]:
    """Find tasks JSON files in a repo directory."""
    results = []
    if not repo_path.is_dir():
        return results
    # Check root-level JSON files
    for f in sorted(repo_path.glob("*.json")):
        if _is_tasks_file(f):
            results.append(_task_file_summary(f))
    # Check tasks/ subdirectory
    tasks_dir = repo_path / "tasks"
    if tasks_dir.is_dir():
        for f in sorted(tasks_dir.glob("*.json")):
            if _is_tasks_file(f):
                results.append(_task_file_summary(f))
    # Check pipelines/ subdirectory for task files
    pipelines_dir = repo_path / "pipelines"
    if pipelines_dir.is_dir():
        for f in sorted(pipelines_dir.glob("*.json")):
            if _is_tasks_file(f):
                results.append(_task_file_summary(f))
    return results


def _is_tasks_file(f: Path) -> bool:
    """Check if a JSON file contains a tasks array."""
    try:
        data = json.loads(f.read_text())
        return isinstance(data.get("tasks"), list)
    except Exception:
        return False


def _task_file_summary(f: Path) -> dict:
    """Summarize a tasks file."""
    try:
        data = json.loads(f.read_text())
        tasks = data.get("tasks", [])
        counts = {"total": len(tasks), "pending": 0, "running": 0, "done": 0, "failed": 0}
        for t in tasks:
            st = t.get("status", "pending")
            if st in counts:
                counts[st] += 1
        return {
            "path": str(f),
            "name": f.stem,
            "task_counts": counts,
        }
    except Exception:
        return {"path": str(f), "name": f.stem, "task_counts": {"total": 0}}


def _load_tasks_file(file_path: Path) -> tuple[dict | None, str | None]:
    """Load and validate a tasks JSON file. Returns (data, error_msg)."""
    if not file_path.is_file():
        return None, "Task file not found"
    try:
        data = json.loads(file_path.read_text())
    except (json.JSONDecodeError, ValueError):
        return None, "Invalid JSON in task file"
    if not isinstance(data.get("tasks"), list):
        return None, "Task file missing 'tasks' array"
    return data, None


def _save_tasks_file(file_path: Path, data: dict):
    """Write tasks JSON file atomically via temp file."""
    file_path.parent.mkdir(parents=True, exist_ok=True)
    tmp_fd, tmp_path = tempfile.mkstemp(
        dir=str(file_path.parent), suffix=".json.tmp"
    )
    try:
        with os.fdopen(tmp_fd, "w") as f:
            json.dump(data, f, indent=2)
            f.write("\n")
        os.replace(tmp_path, str(file_path))
    except Exception:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


def _validate_workspace_path(raw_path: str) -> Path | None:
    """Resolve and validate a workspace file path. Returns None if unsafe."""
    try:
        p = Path(raw_path).resolve()
    except (ValueError, OSError):
        return None
    # Must be under home directory
    home = Path.home().resolve()
    if not str(p).startswith(str(home)):
        return None
    return p


class SSEBroker:
    """Manages connected SSE clients and broadcasts events."""

    def __init__(self):
        self._clients: list[queue.Queue] = []
        self._lock = threading.Lock()

    def subscribe(self) -> queue.Queue:
        q = queue.Queue(maxsize=256)
        with self._lock:
            self._clients.append(q)
        return q

    def unsubscribe(self, q: queue.Queue):
        with self._lock:
            try:
                self._clients.remove(q)
            except ValueError:
                pass

    def broadcast(self, event_type: str, data: dict):
        msg = f"event: {event_type}\ndata: {json.dumps(data, default=str)}\n\n"
        with self._lock:
            for q in list(self._clients):
                try:
                    q.put_nowait(msg)
                except queue.Full:
                    pass


class LogWatcher(threading.Thread):
    """Watches logs directory for state changes and stream updates."""

    def __init__(self, logs_dir: Path, broker: SSEBroker):
        super().__init__(daemon=True)
        self._logs_dir = logs_dir
        self._broker = broker
        self._stop_event = threading.Event()
        self._run_states: dict[str, dict[str, str]] = {}
        self._stream_positions: dict[str, int] = {}
        self._pipeline_states: dict[str, dict[int, str]] = {}
        self._snapshot()

    def _snapshot(self):
        """Capture initial state without emitting events."""
        if not self._logs_dir.is_dir():
            return
        for run_dir in self._logs_dir.iterdir():
            if not run_dir.is_dir():
                continue
            state_file = run_dir / "state.json"
            if not state_file.exists():
                continue
            try:
                state = json.loads(state_file.read_text())
            except Exception:
                continue
            tasks = state.get("tasks", [])
            self._run_states[run_dir.name] = {
                t["id"]: t.get("status", "pending") for t in tasks
            }
            for t in tasks:
                stream_f = run_dir / f"{t['id']}.stream.jsonl"
                if stream_f.exists():
                    try:
                        self._stream_positions[str(stream_f)] = stream_f.stat().st_size
                    except OSError:
                        pass
        for f in self._logs_dir.glob("*.json"):
            if f.parent != self._logs_dir:
                continue
            try:
                data = json.loads(f.read_text())
                if not isinstance(data.get("stages"), list):
                    continue
                self._pipeline_states[data["id"]] = {
                    i: s.get("status", "pending")
                    for i, s in enumerate(data["stages"])
                }
            except Exception:
                continue

    def stop(self):
        self._stop_event.set()

    def run(self):
        while not self._stop_event.is_set():
            try:
                self._poll()
            except Exception:
                pass
            self._stop_event.wait(timeout=1.0)

    def _poll(self):
        if not self._logs_dir.is_dir():
            return
        self._poll_runs()
        self._poll_pipelines()

    def _poll_runs(self):
        for run_dir in self._logs_dir.iterdir():
            if not run_dir.is_dir():
                continue
            state_file = run_dir / "state.json"
            if not state_file.exists():
                continue
            run_id = run_dir.name
            try:
                state = json.loads(state_file.read_text())
            except Exception:
                continue
            tasks = state.get("tasks", [])
            old_states = self._run_states.get(run_id, {})
            new_states = {}

            if run_id not in self._run_states:
                self._broker.broadcast("run_started", {
                    "run_id": run_id,
                    "task_count": len(tasks),
                    "started_at": state.get("started_at"),
                })

            for t in tasks:
                tid = t["id"]
                status = t.get("status", "pending")
                new_states[tid] = status
                old_status = old_states.get(tid)

                if old_status == status:
                    continue
                if status == "running" and old_status != "running":
                    self._broker.broadcast("task_started", {
                        "run_id": run_id,
                        "task_id": tid,
                        "task_name": t.get("name", tid),
                    })
                elif status in ("done", "failed"):
                    self._broker.broadcast("task_completed", {
                        "run_id": run_id,
                        "task_id": tid,
                        "task_name": t.get("name", tid),
                        "status": status,
                        "cost_usd": t.get("cost_usd"),
                    })

            self._run_states[run_id] = new_states

            # Emit run_progress on any task status change
            if old_states and new_states != old_states:
                done = sum(1 for s in new_states.values() if s == "done")
                failed = sum(1 for s in new_states.values() if s == "failed")
                running = sum(1 for s in new_states.values() if s == "running")
                self._broker.broadcast("run_progress", {
                    "run_id": run_id,
                    "tasks_done": done,
                    "tasks_failed": failed,
                    "tasks_running": running,
                    "tasks_total": len(new_states),
                })

            # Emit run_completed when all tasks reach terminal state
            all_terminal = new_states and all(
                s in ("done", "failed") for s in new_states.values()
            )
            was_terminal = old_states and all(
                s in ("done", "failed") for s in old_states.values()
            )
            if all_terminal and not was_terminal:
                done = sum(1 for s in new_states.values() if s == "done")
                failed = sum(1 for s in new_states.values() if s == "failed")
                self._broker.broadcast("run_completed", {
                    "run_id": run_id,
                    "tasks_done": done,
                    "tasks_failed": failed,
                })

            # Watch stream files for running tasks
            for t in tasks:
                if t.get("status") != "running":
                    continue
                stream_f = run_dir / f"{t['id']}.stream.jsonl"
                if stream_f.exists():
                    self._poll_stream(run_id, t["id"], stream_f)

    def _poll_stream(self, run_id: str, task_id: str, stream_f: Path):
        key = str(stream_f)
        pos = self._stream_positions.get(key, 0)
        try:
            size = stream_f.stat().st_size
            if size <= pos:
                return
            with open(stream_f, "r", errors="replace") as f:
                f.seek(pos)
                new_data = f.read()
                self._stream_positions[key] = f.tell()

            for line in new_data.strip().split("\n"):
                if not line.strip():
                    continue
                try:
                    ev = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if ev.get("type") == "system" and ev.get("subtype") == "task_progress":
                    self._broker.broadcast("task_progress", {
                        "run_id": run_id,
                        "task_id": task_id,
                        "description": ev.get("description", ""),
                        "tool_name": ev.get("last_tool_name"),
                        "duration_ms": ev.get("usage", {}).get("duration_ms"),
                    })
        except OSError:
            pass

    def _poll_pipelines(self):
        for f in self._logs_dir.glob("*.json"):
            if f.parent != self._logs_dir:
                continue
            try:
                data = json.loads(f.read_text())
                if not isinstance(data.get("stages"), list):
                    continue
                pid = data["id"]
                stages = data["stages"]
                old_stages = self._pipeline_states.get(pid, {})
                new_stages = {}

                for i, stage in enumerate(stages):
                    status = stage.get("status", "pending")
                    new_stages[i] = status
                    old_status = old_stages.get(i)

                    if old_status == status:
                        continue
                    if status == "running":
                        self._broker.broadcast("stage_started", {
                            "pipeline_id": pid,
                            "stage_index": i,
                            "stage_name": stage.get("name", f"Stage {i}"),
                        })
                    elif status in ("done", "failed"):
                        self._broker.broadcast("stage_completed", {
                            "pipeline_id": pid,
                            "stage_index": i,
                            "stage_name": stage.get("name", f"Stage {i}"),
                            "status": status,
                        })

                self._pipeline_states[pid] = new_stages
            except Exception:
                continue


def _summarize_tool(tool: str, inp: dict) -> str:
    """One-line summary of a tool call (ported from orchestra-dashboard)."""
    if tool == "Read":
        fp = inp.get("file_path", "")
        return f"Reading {Path(fp).name}" if fp else "Reading..."
    elif tool == "Glob":
        return f"Searching {inp.get('pattern', '...')}"
    elif tool == "Grep":
        pat = inp.get("pattern", "")
        return f"Grep: {pat[:40]}" if pat else "Searching..."
    elif tool == "Edit":
        fp = inp.get("file_path", "")
        return f"Editing {Path(fp).name}" if fp else "Editing..."
    elif tool == "Write":
        fp = inp.get("file_path", "")
        return f"Writing {Path(fp).name}" if fp else "Writing..."
    elif tool == "Bash":
        cmd = inp.get("command", "")
        return f"$ {cmd[:50]}" if cmd else "Running..."
    elif tool in ("Agent", "Task"):
        desc = inp.get("description", inp.get("prompt", "")[:40])
        return f"Agent: {desc[:40]}" if desc else "Agent..."
    elif tool == "WebFetch":
        url = inp.get("url", "")
        return f"Fetch: {url[:50]}" if url else "Fetching..."
    elif tool == "TodoWrite":
        return "Updating todo list"
    return tool


def _format_bytes(n: int) -> str:
    if n < 1024:
        return f"{n}B"
    elif n < 1024 * 1024:
        return f"{n / 1024:.1f}K"
    else:
        return f"{n / (1024 * 1024):.1f}M"


def _extract_cost_from_stream(stream_path: Path):
    """Return total_cost_usd from a stream.jsonl result event, or None."""
    try:
        with open(stream_path, "r", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    ev = json.loads(line)
                    if ev.get("type") == "result" and "total_cost_usd" in ev:
                        return float(ev["total_cost_usd"])
                except (json.JSONDecodeError, ValueError):
                    continue
    except OSError:
        pass
    return None


def _parse_stream(stream_path: Path) -> dict:
    """Single-pass JSONL parse into structured event summary."""
    events = []
    meta = {}
    tool_results = {}

    lines = []
    with open(stream_path, "r", errors="replace") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                lines.append(json.loads(line))
            except json.JSONDecodeError:
                continue

    # First pass: collect tool results
    for ev in lines:
        if ev.get("type") == "user":
            msg = ev.get("message", {})
            content = msg.get("content", [])
            if isinstance(content, list):
                for c in content:
                    if isinstance(c, dict) and c.get("type") == "tool_result":
                        raw = c.get("content", "")
                        if isinstance(raw, list):
                            raw = " ".join(
                                item.get("text", "")
                                for item in raw
                                if isinstance(item, dict)
                            )
                        tool_results[c.get("tool_use_id", "")] = str(raw)

    # Second pass: build event list
    seq = 0
    for ev in lines:
        t = ev.get("type")

        if t == "system":
            sub = ev.get("subtype")
            if sub == "init":
                events.append(
                    {
                        "seq": seq,
                        "type": "init",
                        "cwd": ev.get("cwd"),
                        "model": ev.get("model"),
                        "tool_count": len(ev.get("tools", [])),
                        "session_id": ev.get("session_id"),
                    }
                )
                seq += 1
            elif sub == "task_started":
                events.append(
                    {
                        "seq": seq,
                        "type": "task_started",
                        "description": ev.get("description"),
                    }
                )
                seq += 1
            elif sub == "task_progress":
                events.append(
                    {
                        "seq": seq,
                        "type": "progress",
                        "description": ev.get("description", ""),
                        "tool_name": ev.get("last_tool_name"),
                        "tool_uses_so_far": ev.get("usage", {}).get("tool_uses"),
                        "duration_ms": ev.get("usage", {}).get("duration_ms"),
                    }
                )
                seq += 1
            elif sub == "task_notification":
                events.append(
                    {
                        "seq": seq,
                        "type": "task_notification",
                        "status": ev.get("status"),
                        "summary": ev.get("summary"),
                    }
                )
                seq += 1

        elif t == "assistant":
            for c in ev.get("message", {}).get("content", []):
                ct = c.get("type")
                if ct == "thinking":
                    events.append(
                        {"seq": seq, "type": "thinking", "text": c.get("thinking", "")}
                    )
                    seq += 1
                elif ct == "tool_use":
                    tid = c.get("id", "")
                    raw_result = tool_results.get(tid, "")
                    events.append(
                        {
                            "seq": seq,
                            "type": "tool_use",
                            "name": c.get("name"),
                            "input": c.get("input", {}),
                            "summary": _summarize_tool(
                                c.get("name", ""), c.get("input", {})
                            ),
                            "result": raw_result[:500],
                            "result_truncated": len(raw_result) > 500,
                        }
                    )
                    seq += 1
                elif ct == "text":
                    events.append(
                        {"seq": seq, "type": "text", "text": c.get("text", "")}
                    )
                    seq += 1

        elif t == "result":
            usage = ev.get("usage", {})
            meta = {
                "duration_ms": ev.get("duration_ms"),
                "total_cost_usd": ev.get("total_cost_usd"),
                "num_turns": ev.get("num_turns"),
                "stop_reason": ev.get("stop_reason"),
                "input_tokens": usage.get("input_tokens", 0),
                "output_tokens": usage.get("output_tokens", 0),
            }

        elif t == "rate_limit_event":
            events.append({"seq": seq, "type": "rate_limit"})
            seq += 1

    return {"meta": meta, "events": events}


class OrchestraHandler(BaseHTTPRequestHandler):
    logs_dir: Path = Path(".")
    broker: SSEBroker = None

    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")
        qs = parse_qs(parsed.query, keep_blank_values=True)

        if path in ("", "/"):
            self._serve_file(VIEWER_DIR / "index.html", "text/html")
        elif path == "/api/runs":
            self._api_runs()
        elif m := re.match(r"^/api/runs/([^/]+)$", path):
            self._api_run_detail(m.group(1))
        elif m := re.match(r"^/api/runs/([^/]+)/([^/]+)/output$", path):
            self._api_task_output(m.group(1), m.group(2))
        elif m := re.match(r"^/api/runs/([^/]+)/([^/]+)/stream$", path):
            summarize = "summarize" in qs
            self._api_task_stream(m.group(1), m.group(2), summarize)
        elif path == "/api/pipelines":
            self._api_pipelines()
        elif m := re.match(r"^/api/pipeline/([^/]+)$", path):
            self._api_pipeline_detail(m.group(1))
        elif path == "/api/config/paths":
            self._api_config_paths()
        elif path == "/api/config/agents":
            self._api_config_agents_list()
        elif m := re.match(r"^/api/config/agents/([^/]+)$", path):
            self._api_config_agent_get(m.group(1))
        elif path == "/api/config/skills":
            self._api_config_skills_list()
        elif m := re.match(r"^/api/config/skills/([^/]+)$", path):
            self._api_config_skill_get(m.group(1))
        elif path == "/api/config/hooks":
            self._api_config_hooks_list()
        elif path == "/api/events":
            self._api_events()
        elif path == "/api/workspace/repos":
            self._api_workspace_repos()
        elif m := re.match(r"^/api/workspace/repos/(.+)/tasks$", path):
            self._api_workspace_repo_tasks(unquote(m.group(1)))
        elif path == "/api/workspace/tasks-file":
            self._api_workspace_tasks_file()
        elif path == "/api/workspace/tasks-md":
            self._api_workspace_tasks_md_get()
        else:
            self._not_found()

    def do_POST(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")

        if path == "/api/workspace/tasks":
            self._api_workspace_task_create()
        elif m := re.match(r"^/api/workspace/tasks/([^/]+)/run$", path):
            self._api_workspace_task_run(m.group(1))
        elif path == "/api/workspace/brainstorm":
            self._api_workspace_brainstorm()
        elif path == "/api/workspace/tasks-md/convert":
            self._api_workspace_tasks_md_convert()
        elif path == "/api/workspace/orchestra/run":
            self._api_workspace_orchestra_run()
        else:
            self._not_found()

    def do_PUT(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")

        if m := re.match(r"^/api/config/agents/([^/]+)$", path):
            self._api_config_agent_put(m.group(1))
        elif m := re.match(r"^/api/config/skills/([^/]+)$", path):
            self._api_config_skill_put(m.group(1))
        elif m := re.match(r"^/api/workspace/tasks/([^/]+)$", path):
            self._api_workspace_task_update(m.group(1))
        elif path == "/api/workspace/tasks-md":
            self._api_workspace_tasks_md_put()
        else:
            self._not_found()

    def do_DELETE(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")

        if m := re.match(r"^/api/config/agents/([^/]+)$", path):
            self._api_config_agent_delete(m.group(1))
        elif m := re.match(r"^/api/config/skills/([^/]+)$", path):
            self._api_config_skill_delete(m.group(1))
        elif m := re.match(r"^/api/workspace/tasks/([^/]+)$", path):
            self._api_workspace_task_delete(m.group(1))
        else:
            self._not_found()

    def do_OPTIONS(self):
        self.send_response(204)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

    def _validate_ids(self, run_id, task_id=None):
        if not RUN_ID_RE.match(run_id):
            self._error(400, "Invalid run ID format")
            return False
        if task_id and not TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task ID format")
            return False
        return True

    def _api_runs(self):
        runs = []
        if not self.logs_dir.is_dir():
            self._json({"runs": []})
            return
        for run_dir in sorted(self.logs_dir.iterdir(), reverse=True):
            if not run_dir.is_dir():
                continue
            state_file = run_dir / "state.json"
            if not state_file.exists():
                continue
            try:
                state = json.loads(state_file.read_text())
            except Exception:
                continue
            tasks = state.get("tasks", [])
            counts = {
                "total": len(tasks),
                "done": 0,
                "running": 0,
                "pending": 0,
                "failed": 0,
            }
            for t in tasks:
                st = t.get("status", "pending")
                if st in counts:
                    counts[st] += 1
            total_output = 0
            total_cost = None
            for t in tasks:
                out_f = run_dir / f"{t['id']}.output.md"
                if out_f.exists():
                    total_output += out_f.stat().st_size
                c = t.get("cost_usd")
                if c is not None:
                    total_cost = (total_cost or 0.0) + c
            # Fall back to parsing stream files for runs without cost in state
            if total_cost is None:
                for t in tasks:
                    if t.get("status") in ("done", "failed"):
                        stream_f = run_dir / f"{t['id']}.stream.jsonl"
                        c = _extract_cost_from_stream(stream_f)
                        if c is not None:
                            total_cost = (total_cost or 0.0) + c
            ts = state.get("started_at", 0)
            try:
                iso = datetime.fromtimestamp(int(ts), tz=timezone.utc).isoformat()
            except Exception:
                iso = None
            runs.append(
                {
                    "id": run_dir.name,
                    "started_at": ts,
                    "started_at_iso": iso,
                    "ecc_enabled": state.get("ecc_enabled", False),
                    "task_counts": counts,
                    "total_output_bytes": total_output,
                    "total_cost_usd": total_cost,
                }
            )
        self._json({"runs": runs})

    def _api_run_detail(self, run_id):
        if not self._validate_ids(run_id):
            return
        run_dir = self.logs_dir / run_id
        state_file = run_dir / "state.json"
        if not state_file.exists():
            self._not_found()
            return
        state = json.loads(state_file.read_text())
        tasks = []
        total_cost = None
        for t in state.get("tasks", []):
            tid = t["id"]
            output_f = run_dir / f"{tid}.output.md"
            stream_f = run_dir / f"{tid}.stream.jsonl"
            # Use cost from state; fall back to parsing stream for older runs
            cost = t.get("cost_usd")
            if cost is None and t.get("status") in ("done", "failed") and stream_f.exists():
                cost = _extract_cost_from_stream(stream_f)
            if cost is not None:
                total_cost = (total_cost or 0.0) + cost
            tasks.append(
                {
                    **t,
                    "cost_usd": cost,
                    "output_bytes": output_f.stat().st_size
                    if output_f.exists()
                    else 0,
                    "stream_bytes": stream_f.stat().st_size
                    if stream_f.exists()
                    else 0,
                    "has_output": output_f.exists() and output_f.stat().st_size > 0,
                    "has_stream": stream_f.exists() and stream_f.stat().st_size > 0,
                }
            )
        ts = state.get("started_at", 0)
        try:
            iso = datetime.fromtimestamp(int(ts), tz=timezone.utc).isoformat()
        except Exception:
            iso = None
        self._json(
            {
                "id": run_id,
                "started_at": ts,
                "started_at_iso": iso,
                "ecc_enabled": state.get("ecc_enabled", False),
                "total_cost_usd": total_cost,
                "tasks": tasks,
            }
        )

    def _api_task_output(self, run_id, task_id):
        if not self._validate_ids(run_id, task_id):
            return
        output_f = self.logs_dir / run_id / f"{task_id}.output.md"
        if not output_f.exists():
            self._not_found()
            return
        self._serve_file(output_f, "text/plain; charset=utf-8")

    def _api_task_stream(self, run_id, task_id, summarize):
        if not self._validate_ids(run_id, task_id):
            return
        stream_f = self.logs_dir / run_id / f"{task_id}.stream.jsonl"
        if not stream_f.exists():
            self._not_found()
            return
        if summarize:
            summary = _parse_stream(stream_f)
            self._json(summary)
        else:
            self._serve_file(stream_f, "application/x-ndjson")

    def _api_pipelines(self):
        pipelines = []
        if not self.logs_dir.is_dir():
            self._json({"pipelines": []})
            return
        # Find pipeline state files: either old format (pipeline-*.json) 
        # or new format (name-slug.json with 'stages' field)
        for f in sorted(self.logs_dir.glob("*.json"), reverse=True):
            # Skip state.json files in run directories
            if f.parent != self.logs_dir:
                continue
            try:
                data = json.loads(f.read_text())
                # Pipeline state files have 'stages' array
                if "stages" not in data or not isinstance(data.get("stages"), list):
                    continue
                stages = data.get("stages", [])
                # Compute overall status
                statuses = [s.get("status", "pending") for s in stages]
                if "running" in statuses:
                    overall = "running"
                elif "failed" in statuses:
                    overall = "failed"
                elif all(s == "done" for s in statuses):
                    overall = "done"
                else:
                    overall = "pending"
                ts = data.get("started_at", 0)
                try:
                    iso = datetime.fromtimestamp(int(ts), tz=timezone.utc).isoformat()
                except Exception:
                    iso = None
                pipelines.append({
                    "id": data["id"],
                    "name": data.get("name", "Unnamed"),
                    "started_at": ts,
                    "started_at_iso": iso,
                    "stage_count": len(stages),
                    "status": overall,
                    "stages": stages,
                })
            except Exception:
                continue
        self._json({"pipelines": pipelines})

    def _api_pipeline_detail(self, pipeline_id):
        if not PIPELINE_ID_RE.match(pipeline_id):
            self._error(400, "Invalid pipeline ID")
            return
        pf = self.logs_dir / f"{pipeline_id}.json"
        if not pf.exists():
            self._not_found()
            return
        data = json.loads(pf.read_text())
        stages = []
        total_cost = None
        for stage in data.get("stages", []):
            enriched = dict(stage)
            run_ids = stage.get("run_ids", [])
            stage_tasks = []
            stage_cost = None
            for run_id in run_ids:
                run_dir = self.logs_dir / run_id
                sf = run_dir / "state.json"
                if sf.exists():
                    try:
                        state = json.loads(sf.read_text())
                        for t in state.get("tasks", []):
                            cost = t.get("cost_usd")
                            if cost is not None:
                                stage_cost = (stage_cost or 0.0) + cost
                            stage_tasks.append({**t, "run_id": run_id})
                    except Exception:
                        pass
            enriched["tasks"] = stage_tasks
            enriched["cost_usd"] = stage_cost
            if stage_cost is not None:
                total_cost = (total_cost or 0.0) + stage_cost
            stages.append(enriched)
        ts = data.get("started_at", 0)
        try:
            iso = datetime.fromtimestamp(int(ts), tz=timezone.utc).isoformat()
        except Exception:
            iso = None
        self._json({
            **data,
            "started_at_iso": iso,
            "total_cost_usd": total_cost,
            "stages": stages,
        })

    # ── SSE endpoint ───────────────────────────────────────────────────

    def _api_events(self):
        if self.broker is None:
            self._error(503, "SSE not available")
            return
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()

        client_q = self.broker.subscribe()
        try:
            while True:
                try:
                    msg = client_q.get(timeout=15)
                    self.wfile.write(msg.encode())
                    self.wfile.flush()
                except queue.Empty:
                    self.wfile.write(b": heartbeat\n\n")
                    self.wfile.flush()
        except (BrokenPipeError, ConnectionResetError, OSError):
            pass
        finally:
            self.broker.unsubscribe(client_q)

    # ── Config API helpers ──────────────────────────────────────────────

    def _read_body_json(self):
        """Read and parse JSON request body. Returns dict or None on error."""
        length = int(self.headers.get("Content-Length", 0))
        if length == 0:
            self._error(400, "Empty request body")
            return None
        raw = self.rfile.read(length)
        try:
            return json.loads(raw)
        except (json.JSONDecodeError, ValueError):
            self._error(400, "Invalid JSON")
            return None

    def _collect_agents(self, base_dir: Path, scope: str) -> list:
        """List agent .md files under base_dir/agents/."""
        agents_dir = base_dir / "agents"
        if not agents_dir.is_dir():
            return []
        results = []
        for f in sorted(agents_dir.iterdir()):
            if f.is_file() and f.suffix == ".md":
                results.append({
                    "name": f.stem,
                    "scope": scope,
                    "path": str(f),
                })
        return results

    def _collect_skills(self, base_dir: Path, scope: str) -> list:
        """List skills under base_dir/skills/ (each has SKILL.md)."""
        skills_dir = base_dir / "skills"
        if not skills_dir.is_dir():
            return []
        results = []
        for d in sorted(skills_dir.iterdir()):
            skill_file = d / "SKILL.md"
            if d.is_dir() and skill_file.exists():
                results.append({
                    "name": d.name,
                    "scope": scope,
                    "path": str(skill_file),
                })
        return results

    # ── Config API routes ──────────────────────────────────────────────

    def _api_config_paths(self):
        self._json({
            "global_path": str(GLOBAL_CLAUDE_DIR),
            "project_path": str(PROJECT_CLAUDE_DIR),
        })

    def _api_config_agents_list(self):
        agents = (
            self._collect_agents(GLOBAL_CLAUDE_DIR, "global")
            + self._collect_agents(PROJECT_CLAUDE_DIR, "project")
        )
        self._json({"agents": agents})

    def _api_config_agent_get(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid agent name")
            return
        for base, scope in [(PROJECT_CLAUDE_DIR, "project"), (GLOBAL_CLAUDE_DIR, "global")]:
            agent_file = base / "agents" / f"{name}.md"
            if agent_file.is_file():
                self._json({
                    "name": name,
                    "scope": scope,
                    "content": agent_file.read_text(errors="replace"),
                })
                return
        self._not_found()

    def _api_config_agent_put(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid agent name")
            return
        body = self._read_body_json()
        if body is None:
            return
        scope = body.get("scope", "project")
        content = body.get("content")
        if content is None:
            self._error(400, "Missing 'content' field")
            return
        if scope not in ("global", "project"):
            self._error(400, "scope must be 'global' or 'project'")
            return
        base = GLOBAL_CLAUDE_DIR if scope == "global" else PROJECT_CLAUDE_DIR
        agents_dir = base / "agents"
        agents_dir.mkdir(parents=True, exist_ok=True)
        agent_file = agents_dir / f"{name}.md"
        created = not agent_file.exists()
        agent_file.write_text(content)
        self._json_status(201 if created else 200, {
            "name": name,
            "scope": scope,
            "path": str(agent_file),
        })

    def _api_config_agent_delete(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid agent name")
            return
        for base in [PROJECT_CLAUDE_DIR, GLOBAL_CLAUDE_DIR]:
            agent_file = base / "agents" / f"{name}.md"
            if agent_file.is_file():
                agent_file.unlink()
                self._json({"deleted": name})
                return
        self._not_found()

    def _api_config_skills_list(self):
        skills = (
            self._collect_skills(GLOBAL_CLAUDE_DIR, "global")
            + self._collect_skills(PROJECT_CLAUDE_DIR, "project")
        )
        self._json({"skills": skills})

    def _api_config_skill_get(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid skill name")
            return
        for base, scope in [(PROJECT_CLAUDE_DIR, "project"), (GLOBAL_CLAUDE_DIR, "global")]:
            skill_file = base / "skills" / name / "SKILL.md"
            if skill_file.is_file():
                self._json({
                    "name": name,
                    "scope": scope,
                    "content": skill_file.read_text(errors="replace"),
                })
                return
        self._not_found()

    def _api_config_skill_put(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid skill name")
            return
        body = self._read_body_json()
        if body is None:
            return
        scope = body.get("scope", "project")
        content = body.get("content")
        if content is None:
            self._error(400, "Missing 'content' field")
            return
        if scope not in ("global", "project"):
            self._error(400, "scope must be 'global' or 'project'")
            return
        base = GLOBAL_CLAUDE_DIR if scope == "global" else PROJECT_CLAUDE_DIR
        skill_dir = base / "skills" / name
        skill_dir.mkdir(parents=True, exist_ok=True)
        skill_file = skill_dir / "SKILL.md"
        created = not skill_file.exists()
        skill_file.write_text(content)
        self._json_status(201 if created else 200, {
            "name": name,
            "scope": scope,
            "path": str(skill_file),
        })

    def _api_config_skill_delete(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid skill name")
            return
        for base in [PROJECT_CLAUDE_DIR, GLOBAL_CLAUDE_DIR]:
            skill_file = base / "skills" / name / "SKILL.md"
            if skill_file.is_file():
                skill_file.unlink()
                # Remove the directory if now empty
                skill_dir = skill_file.parent
                try:
                    skill_dir.rmdir()
                except OSError:
                    pass
                self._json({"deleted": name})
                return
        self._not_found()

    def _api_config_hooks_list(self):
        self._json({"hooks": list(HOOK_PROFILES.values())})

    # ── Workspace API routes ──────────────────────────────────────────

    def _api_workspace_repos(self):
        """GET /api/workspace/repos — list available repos."""
        repos = _find_repos()
        self._json({"repos": repos})

    def _api_workspace_repo_tasks(self, raw_path: str):
        """GET /api/workspace/repos/{path}/tasks — list task files in a repo."""
        # Prepend / if the path doesn't start with one (URL encoding strips it)
        if not raw_path.startswith("/"):
            raw_path = "/" + raw_path
        repo_path = _validate_workspace_path(raw_path)
        if repo_path is None:
            self._error(400, "Invalid repo path")
            return
        if not repo_path.is_dir():
            self._not_found()
            return
        task_files = _find_task_files(repo_path)

        # Check if tasks.md exists and read its content
        tasks_md_path = repo_path / "tasks.md"
        tasks_md = None
        if tasks_md_path.is_file():
            try:
                content = tasks_md_path.read_text()
                tasks_md = {
                    "exists": True,
                    "path": str(tasks_md_path),
                    "content": content
                }
            except Exception:
                # If read fails, still include exists=True but without content
                tasks_md = {
                    "exists": True,
                    "path": str(tasks_md_path),
                    "content": None
                }
        else:
            tasks_md = {"exists": False}

        self._json({
            "repo": str(repo_path),
            "task_files": task_files,
            "tasks_md": tasks_md
        })

    def _api_workspace_tasks_file(self):
        """GET /api/workspace/tasks-file?path=... — read tasks from a file."""
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        path_list = qs.get("path", [])
        if not path_list:
            self._error(400, "Missing 'path' query parameter")
            return
        file_path = _validate_workspace_path(path_list[0])
        if file_path is None:
            self._error(400, "Invalid file path")
            return
        data, err = _load_tasks_file(file_path)
        if err:
            self._error(400, err)
            return
        self._json({"tasks": data.get("tasks", []), "file": str(file_path)})

    def _api_workspace_tasks_md_get(self):
        """GET /api/workspace/tasks-md?path=... — read raw tasks.md content."""
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        path_list = qs.get("path", [])
        if not path_list:
            self._error(400, "Missing 'path' query parameter")
            return
        file_path = _validate_workspace_path(path_list[0])
        if file_path is None:
            self._error(400, "Invalid file path")
            return
        exists = file_path.exists()
        content = file_path.read_text(encoding="utf-8") if exists else ""
        self._json({"path": str(file_path), "content": content, "exists": exists})

    def _api_workspace_tasks_md_put(self):
        """PUT /api/workspace/tasks-md — save raw tasks.md content."""
        body = self._read_body_json()
        if body is None:
            return
        path_str = body.get("path")
        content = body.get("content")
        if not path_str:
            self._error(400, "Missing 'path' field")
            return
        if content is None:
            self._error(400, "Missing 'content' field")
            return
        file_path = _validate_workspace_path(path_str)
        if file_path is None:
            self._error(400, "Invalid file path")
            return
        file_path.parent.mkdir(parents=True, exist_ok=True)
        bytes_written = file_path.write_text(content, encoding="utf-8")
        self._json({"path": str(file_path), "bytes_written": bytes_written})

    def _api_workspace_task_create(self):
        """POST /api/workspace/tasks — create a task in a task file."""
        body = self._read_body_json()
        if body is None:
            return
        file_path_str = body.get("file")
        task_data = body.get("task")
        if not file_path_str:
            self._error(400, "Missing 'file' field (path to tasks.json)")
            return
        if not task_data or not isinstance(task_data, dict):
            self._error(400, "Missing or invalid 'task' object")
            return
        task_id = task_data.get("id")
        if not task_id or not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Missing or invalid task 'id'")
            return
        if not task_data.get("name"):
            self._error(400, "Missing task 'name'")
            return

        file_path = _validate_workspace_path(file_path_str)
        if file_path is None:
            self._error(400, "Invalid file path")
            return

        # Load existing file or create new
        if file_path.is_file():
            data, err = _load_tasks_file(file_path)
            if err:
                self._error(400, err)
                return
        else:
            data = {"tasks": []}

        # Check for duplicate ID
        for t in data["tasks"]:
            if t.get("id") == task_id:
                self._error(409, f"Task '{task_id}' already exists")
                return

        # Build task with defaults
        new_task = {
            "id": task_id,
            "name": task_data["name"],
            "prompt": task_data.get("prompt", ""),
            "workdir": task_data.get("workdir", ""),
            "model": task_data.get("model", "opus"),
            "status": "pending",
        }
        # Optional fields
        for field in ("agents", "skills", "hooks", "effort", "allowedTools", "appendSystemPrompt"):
            if field in task_data:
                new_task[field] = task_data[field]

        data["tasks"].append(new_task)
        _save_tasks_file(file_path, data)
        self._json_status(201, {"task": new_task, "file": str(file_path)})

    def _api_workspace_task_update(self, task_id: str):
        """PUT /api/workspace/tasks/{id} — update a task."""
        if not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task ID")
            return
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        file_list = qs.get("file", [])
        if not file_list:
            self._error(400, "Missing 'file' query parameter")
            return
        file_path = _validate_workspace_path(file_list[0])
        if file_path is None:
            self._error(400, "Invalid file path")
            return

        data, err = _load_tasks_file(file_path)
        if err:
            self._error(400, err)
            return

        body = self._read_body_json()
        if body is None:
            return

        # Find and update the task
        for i, t in enumerate(data["tasks"]):
            if t.get("id") == task_id:
                updated = dict(t)
                # Update allowed fields
                for field in ("name", "prompt", "workdir", "model", "status",
                              "agents", "skills", "hooks", "effort",
                              "allowedTools", "appendSystemPrompt"):
                    if field in body:
                        updated[field] = body[field]
                # Don't allow changing the ID
                updated["id"] = task_id
                data["tasks"][i] = updated
                _save_tasks_file(file_path, data)
                self._json({"task": updated, "file": str(file_path)})
                return

        self._not_found()

    def _api_workspace_task_delete(self, task_id: str):
        """DELETE /api/workspace/tasks/{id} — remove a task from a task file."""
        if not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task ID")
            return
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        file_list = qs.get("file", [])
        if not file_list:
            self._error(400, "Missing 'file' query parameter")
            return
        file_path = _validate_workspace_path(file_list[0])
        if file_path is None:
            self._error(400, "Invalid file path")
            return

        data, err = _load_tasks_file(file_path)
        if err:
            self._error(400, err)
            return

        original_len = len(data["tasks"])
        data["tasks"] = [t for t in data["tasks"] if t.get("id") != task_id]
        if len(data["tasks"]) == original_len:
            self._not_found()
            return

        _save_tasks_file(file_path, data)
        self._json({"deleted": task_id, "file": str(file_path)})

    def _api_workspace_task_run(self, task_id: str):
        """POST /api/workspace/tasks/{id}/run — execute a task via orchestra."""
        if not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task ID")
            return
        body = self._read_body_json()
        if body is None:
            return
        file_path_str = body.get("file")
        if not file_path_str:
            self._error(400, "Missing 'file' field")
            return
        file_path = _validate_workspace_path(file_path_str)
        if file_path is None:
            self._error(400, "Invalid file path")
            return

        data, err = _load_tasks_file(file_path)
        if err:
            self._error(400, err)
            return

        # Find the task
        task = None
        for t in data["tasks"]:
            if t.get("id") == task_id:
                task = t
                break
        if task is None:
            self._not_found()
            return

        # Create a temp tasks file with just this task
        run_id = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + "-" + uuid.uuid4().hex[:6]
        tmp_dir = tempfile.mkdtemp(prefix="orchestra-run-")
        tmp_tasks = Path(tmp_dir) / "tasks.json"
        single_data = {"tasks": [{**task, "status": "pending"}]}
        tmp_tasks.write_text(json.dumps(single_data, indent=2) + "\n")

        # Determine workdir for the subprocess
        workdir = task.get("workdir", "")
        cwd = workdir if workdir and Path(workdir).is_dir() else str(ORCHESTRA_DIR)

        # Spawn orchestra in the background
        log_dir = self.logs_dir / run_id
        cmd = [str(ORCHESTRA_BIN), "--name", run_id, str(tmp_tasks)]
        env = {**os.environ, "LOG_DIR": str(log_dir)}
        try:
            subprocess.Popen(
                cmd,
                cwd=cwd,
                env=env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except OSError as e:
            self._error(500, f"Failed to spawn orchestra: {e}")
            return

        self._json_status(202, {"run_id": run_id, "task_id": task_id})

    def _api_workspace_brainstorm(self):
        """POST /api/workspace/brainstorm — generate tasks.md via Claude."""
        body = self._read_body_json()
        if body is None:
            return
        repo_path_str = body.get("repo_path")
        prompt = body.get("prompt")
        model = body.get("model", "sonnet")

        if not repo_path_str:
            self._error(400, "Missing 'repo_path' field")
            return
        if not prompt or not isinstance(prompt, str):
            self._error(400, "Missing or invalid 'prompt' field")
            return
        if not isinstance(model, str) or model not in ("opus", "sonnet", "haiku"):
            self._error(400, "Invalid 'model'; must be opus, sonnet, or haiku")
            return

        repo_path = _validate_workspace_path(repo_path_str)
        if repo_path is None or not repo_path.is_dir():
            self._error(400, "Invalid or non-existent repo_path")
            return

        system_prompt = BRAINSTORM_SYSTEM_PROMPT.replace("{repo_path}", str(repo_path))
        try:
            result = subprocess.run(
                ["claude", "--print", "--model", model, "--append-system-prompt", system_prompt],
                input=prompt,
                capture_output=True,
                text=True,
                timeout=120,
            )
        except FileNotFoundError:
            self._error(500, "claude CLI not found")
            return
        except subprocess.TimeoutExpired:
            self._error(504, "Claude CLI timed out")
            return

        if result.returncode != 0:
            self._error(500, f"Claude CLI error: {result.stderr.strip()[:200]}")
            return

        tasks_md = result.stdout.strip()
        if not tasks_md:
            self._error(500, "Claude returned empty output")
            return

        # Count tasks by counting ## headings
        task_count = sum(1 for line in tasks_md.splitlines() if line.startswith("## "))

        # Save to repo_path/tasks.md atomically
        tasks_file = repo_path / "tasks.md"
        tmp_fd, tmp_path = tempfile.mkstemp(dir=str(repo_path), suffix=".md.tmp")
        try:
            with os.fdopen(tmp_fd, "w") as f:
                f.write(tasks_md)
                f.write("\n")
            os.replace(tmp_path, str(tasks_file))
        except Exception as e:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass
            self._error(500, f"Failed to write tasks.md: {e}")
            return

        self._json({
            "tasks_md": tasks_md,
            "tasks_file": str(tasks_file),
            "task_count": task_count,
        })

    def _api_workspace_tasks_md_convert(self):
        """POST /api/workspace/tasks-md/convert — convert tasks.md to tasks.json."""
        body = self._read_body_json()
        if body is None:
            return
        tasks_md_path_str = body.get("tasks_md_path")
        if not tasks_md_path_str:
            self._error(400, "Missing 'tasks_md_path' field")
            return
        tasks_md_path = _validate_workspace_path(tasks_md_path_str)
        if tasks_md_path is None:
            self._error(400, "Invalid tasks_md_path")
            return
        if not tasks_md_path.is_file():
            self._error(400, "tasks_md_path does not exist")
            return

        # Determine output path
        tasks_json_path_str = body.get("tasks_json_path")
        if tasks_json_path_str:
            tasks_json_path = _validate_workspace_path(tasks_json_path_str)
            if tasks_json_path is None:
                self._error(400, "Invalid tasks_json_path")
                return
        else:
            tasks_json_path = tasks_md_path.with_suffix(".json")

        convert_bin = SCRIPT_DIR / "orchestra-convert"
        try:
            result = subprocess.run(
                [str(convert_bin), str(tasks_md_path), str(tasks_json_path)],
                capture_output=True,
                text=True,
                timeout=30,
            )
        except FileNotFoundError:
            self._error(500, "orchestra-convert not found")
            return
        except subprocess.TimeoutExpired:
            self._error(504, "orchestra-convert timed out")
            return

        if result.returncode != 0:
            self._error(500, f"orchestra-convert failed: {result.stderr.strip()[:200]}")
            return

        # Read the resulting JSON to return task list
        try:
            data = json.loads(tasks_json_path.read_text())
        except Exception as e:
            self._error(500, f"Failed to read converted JSON: {e}")
            return

        tasks = data.get("tasks", [])
        self._json({
            "tasks_json_path": str(tasks_json_path),
            "task_count": len(tasks),
            "tasks": tasks,
        })

    def _api_workspace_orchestra_run(self):
        """POST /api/workspace/orchestra/run — run orchestra on a tasks.json file."""
        body = self._read_body_json()
        if body is None:
            return
        tasks_json_path_str = body.get("tasks_json_path")
        if not tasks_json_path_str:
            self._error(400, "Missing 'tasks_json_path' field")
            return
        tasks_json_path = _validate_workspace_path(tasks_json_path_str)
        if tasks_json_path is None:
            self._error(400, "Invalid tasks_json_path")
            return
        if not tasks_json_path.is_file():
            self._error(400, "tasks_json_path does not exist")
            return

        data, err = _load_tasks_file(tasks_json_path)
        if err:
            self._error(400, err)
            return

        max_parallel = body.get("max_parallel", 5)
        if not isinstance(max_parallel, int) or max_parallel < 1 or max_parallel > 50:
            self._error(400, "max_parallel must be an integer between 1 and 50")
            return

        run_id = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + "-" + uuid.uuid4().hex[:6]
        log_dir = self.logs_dir / run_id
        env = {**os.environ, "LOG_DIR": str(log_dir), "MAX_PARALLEL": str(max_parallel)}
        try:
            subprocess.Popen(
                [str(ORCHESTRA_BIN), "--name", run_id, str(tasks_json_path)],
                cwd=str(ORCHESTRA_DIR),
                env=env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except OSError as e:
            self._error(500, f"Failed to spawn orchestra: {e}")
            return

        self._json_status(202, {
            "run_id": run_id,
            "log_dir": str(log_dir),
            "task_count": len(data.get("tasks", [])),
        })

    # ── Response helpers ───────────────────────────────────────────────

    def _json_status(self, status: int, data):
        body = json.dumps(data, default=str).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def _json(self, data):
        body = json.dumps(data, default=str).encode()
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def _serve_file(self, file_path: Path, content_type: str):
        if not file_path.exists():
            self._not_found()
            return
        data = file_path.read_bytes()
        self.send_response(200)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(data)

    def _not_found(self):
        body = json.dumps({"error": "Not found"}).encode()
        self.send_response(404)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def _error(self, code, msg):
        body = json.dumps({"error": msg}).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, fmt, *args):
        """Suppress default access logs."""
        pass


# ---------------------------------------------------------------------------
# JWT helpers — HS256, stdlib only (hmac + base64)
# ---------------------------------------------------------------------------

_JWT_HEADER = base64.urlsafe_b64encode(
    json.dumps({"alg": "HS256", "typ": "JWT"}, separators=(",", ":")).encode()
).rstrip(b"=").decode()


def _jwt_secret() -> bytes:
    """Return the signing secret as bytes; raises RuntimeError if not set."""
    secret = os.environ.get("ORCHESTRA_JWT_SECRET", "")
    if not secret:
        raise RuntimeError(
            "ORCHESTRA_JWT_SECRET environment variable is not set. "
            "Set it to a long random string before starting orchestra-serve."
        )
    return secret.encode()


def _b64url_encode(data: bytes) -> str:
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode()


def _b64url_decode(s: str) -> bytes:
    # Restore padding
    padding = 4 - len(s) % 4
    if padding != 4:
        s += "=" * padding
    return base64.urlsafe_b64decode(s)


def generate_token(user_id: str, email: str) -> str:
    """Return a signed HS256 JWT with a 24-hour expiry.

    Payload claims:
      sub  — user_id
      email — email address
      iat  — issued-at (UTC epoch seconds)
      exp  — expiry (iat + 86400)
    """
    now = int(datetime.now(tz=timezone.utc).timestamp())
    payload = {
        "sub": user_id,
        "email": email,
        "iat": now,
        "exp": now + 86400,
    }
    encoded_payload = _b64url_encode(
        json.dumps(payload, separators=(",", ":")).encode()
    )
    signing_input = f"{_JWT_HEADER}.{encoded_payload}".encode()
    signature = _b64url_encode(
        hmac.new(_jwt_secret(), signing_input, hashlib.sha256).digest()
    )
    return f"{_JWT_HEADER}.{encoded_payload}.{signature}"


def verify_token(token: str) -> dict:
    """Verify an HS256 JWT and return its decoded payload.

    Raises:
      ValueError  — malformed token or invalid signature
      RuntimeError — expired token or ORCHESTRA_JWT_SECRET not set
    """
    parts = token.split(".")
    if len(parts) != 3:
        raise ValueError("Malformed JWT: expected 3 dot-separated parts")

    header_b64, payload_b64, sig_b64 = parts

    # Verify signature
    signing_input = f"{header_b64}.{payload_b64}".encode()
    expected_sig = _b64url_encode(
        hmac.new(_jwt_secret(), signing_input, hashlib.sha256).digest()
    )
    if not hmac.compare_digest(expected_sig, sig_b64):
        raise ValueError("Invalid JWT signature")

    # Decode payload
    try:
        payload = json.loads(_b64url_decode(payload_b64))
    except Exception as exc:
        raise ValueError(f"Malformed JWT payload: {exc}") from exc

    # Check expiry
    exp = payload.get("exp")
    if exp is None:
        raise ValueError("JWT missing 'exp' claim")
    now = int(datetime.now(tz=timezone.utc).timestamp())
    if now >= exp:
        raise RuntimeError("JWT has expired")

    return payload


def main():
    parser = argparse.ArgumentParser(
        description="claude-orchestra web log viewer",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Example:\n  orchestra-serve\n  orchestra-serve --port 8080\n  orchestra-serve --logs-dir /path/to/logs",
    )
    parser.add_argument("--logs-dir", default=None, help="Path to logs directory")
    parser.add_argument("--port", type=int, default=7890, help="Port (default: 7890)")
    parser.add_argument(
        "--host", default="127.0.0.1", help="Host (default: 127.0.0.1)"
    )
    args = parser.parse_args()

    # JWT secret is optional - only required when auth endpoints are used
    # Skip validation if not set (auth features will be unavailable)

    if args.logs_dir:
        logs_dir = Path(args.logs_dir)
    else:
        candidates = [
            ORCHESTRA_DIR / "logs",
            Path.cwd() / "logs",
        ]
        logs_dir = next((p for p in candidates if p.is_dir()), candidates[0])

    OrchestraHandler.logs_dir = logs_dir

    data_dir = logs_dir.parent / "data"
    init_user_store(data_dir)

    broker = SSEBroker()
    OrchestraHandler.broker = broker

    watcher = LogWatcher(logs_dir, broker)
    watcher.start()

    server = ThreadingHTTPServer((args.host, args.port), OrchestraHandler)
    url = f"http://{args.host}:{args.port}"
    print(f"\033[35mclaude-orchestra viewer\033[0m")
    print(f"  URL:      \033[34m{url}\033[0m")
    print(f"  Logs dir: \033[34m{logs_dir}\033[0m")
    print(f"  SSE:      \033[34m{url}/api/events\033[0m")
    print(f"  Ctrl+C to stop")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down.")
        watcher.stop()
        server.server_close()


if __name__ == "__main__":
    main()
