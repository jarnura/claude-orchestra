# Max tokens per task output before truncation (approximate via chars; 1 token ≈ 4 chars)
_SUMMARY_OUTPUT_MAX_CHARS = 6000  # ~1500 tokens

# ---------------------------------------------------------------------------
# User model — file-based storage in <data_dir>/users.json
# ---------------------------------------------------------------------------
# Set by main() once the data directory is resolved.
_USERS_FILE: Path | None = None

_USERS_LOCK = threading.Lock()

_PBKDF2_ITERATIONS = 600_000
_PBKDF2_HASH = "sha256"


def _users_file() -> Path:
    """Return the resolved users.json path (raises RuntimeError if not configured)."""
    if _USERS_FILE is None:
        raise RuntimeError("User store not initialised — call init_user_store() first")
    return _USERS_FILE


def init_user_store(data_dir: Path) -> None:
    """Configure the user store.  Call once from main() after resolving data_dir."""
    global _USERS_FILE
    data_dir.mkdir(parents=True, exist_ok=True)
    _USERS_FILE = data_dir / "users.json"


def _hash_password(password: str) -> str:
    """Return a self-contained password hash string: algorithm$iterations$salt$digest.

    Uses PBKDF2-HMAC-SHA256 with a 32-byte random salt.  The resulting string
    is safe to store verbatim and can be verified with :func:`_verify_password`.
    """
    salt = secrets.token_hex(32)
    digest = hashlib.pbkdf2_hmac(
        _PBKDF2_HASH,
        password.encode(),
        salt.encode(),
        _PBKDF2_ITERATIONS,
    ).hex()
    return f"pbkdf2:{_PBKDF2_HASH}:{_PBKDF2_ITERATIONS}:{salt}:{digest}"


def _verify_password(password: str, stored_hash: str) -> bool:
    """Return True when *password* matches *stored_hash* produced by :func:`_hash_password`."""
    try:
        algo, hash_name, iterations_str, salt, expected = stored_hash.split(":", 4)
        if algo != "pbkdf2":
            return False
        iterations = int(iterations_str)
        digest = hashlib.pbkdf2_hmac(
            hash_name,
            password.encode(),
            salt.encode(),
            iterations,
        ).hex()
        return secrets.compare_digest(digest, expected)
    except (ValueError, TypeError):
        return False


def load_users() -> list[dict]:
    """Load all users from disk.  Returns an empty list when the file does not exist."""
    path = _users_file()
    with _USERS_LOCK:
        if not path.exists():
            return []
        try:
            data = json.loads(path.read_text())
            if not isinstance(data, list):
                return []
            return data
        except (json.JSONDecodeError, OSError):
            return []


def save_users(users: list[dict]) -> None:
    """Persist *users* to disk atomically."""
    path = _users_file()
    with _USERS_LOCK:
        path.parent.mkdir(parents=True, exist_ok=True)
        tmp_fd, tmp_path = tempfile.mkstemp(dir=str(path.parent), suffix=".json.tmp")
        try:
            with os.fdopen(tmp_fd, "w") as f:
                json.dump(users, f, indent=2)
                f.write("\n")
            os.replace(tmp_path, str(path))
        except Exception:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass
            raise


def find_user_by_email(email: str) -> dict | None:
    """Return the user record whose email matches *email* (case-insensitive), or None."""
    normalised = email.strip().lower()
    for user in load_users():
        if user.get("email", "").lower() == normalised:
            return user
    return None


def create_user(email: str, password: str) -> dict:
    """Create a new user, persist it, and return the record (without password_hash).

    Raises ValueError when a user with that email already exists.
    """
    normalised = email.strip().lower()
    if not normalised:
        raise ValueError("email must not be empty")
    if not password:
        raise ValueError("password must not be empty")

    users = load_users()
    for user in users:
        if user.get("email", "").lower() == normalised:
            raise ValueError(f"user with email '{normalised}' already exists")

    record: dict = {
        "id": str(uuid.uuid4()),
        "email": normalised,
        "password_hash": _hash_password(password),
        "created_at": datetime.now(timezone.utc).isoformat(),
    }
    save_users([*users, record])

    # Return a copy without the hash — callers that need authentication
    # should call find_user_by_email() and _verify_password() explicitly.
    return {k: v for k, v in record.items() if k != "password_hash"}


# ---------------------------------------------------------------------------


def _find_repos() -> list[dict]:
    """Scan common directories for git repos (one level deep)."""
    repos = []
    seen = set()
    for scan_dir in WORKSPACE_SCAN_DIRS:
        if not scan_dir.is_dir():
            continue
        for entry in sorted(scan_dir.iterdir()):
            if not entry.is_dir():
                continue
            resolved = entry.resolve()
            if resolved in seen:
                continue
            seen.add(resolved)
            git_dir = entry / ".git"
            if git_dir.exists():
                repos.append({
                    "name": entry.name,
                    "path": str(resolved),
                    "has_git": True,
                })
    return repos


def _find_task_files(repo_path: Path) -> list[dict]:
    """Find tasks JSON and MD files in a repo directory."""
    results = []
    if not repo_path.is_dir():
        return results
    # Check root-level JSON files
    for f in sorted(repo_path.glob("*.json")):
        if _is_tasks_file(f):
            results.append(_task_file_summary(f))
    # Check root-level MD files (tasks-*.md pattern)
    for f in sorted(repo_path.glob("tasks*.md")):
        results.append(_task_file_summary_md(f))
    # Check tasks/ subdirectory
    tasks_dir = repo_path / "tasks"
    if tasks_dir.is_dir():
        for f in sorted(tasks_dir.glob("*.json")):
            if _is_tasks_file(f):
                results.append(_task_file_summary(f))
        for f in sorted(tasks_dir.glob("*.md")):
            results.append(_task_file_summary_md(f))
    # Check pipelines/ subdirectory for task files
    pipelines_dir = repo_path / "pipelines"
    if pipelines_dir.is_dir():
        for f in sorted(pipelines_dir.glob("*.json")):
            if _is_tasks_file(f):
                results.append(_task_file_summary(f))
    return results


def _task_file_summary_md(f: Path) -> dict:
    """Summarize a tasks.md file by counting ## headings."""
    try:
        content = f.read_text()
        task_count = sum(1 for line in content.splitlines() if line.startswith("## "))
        return {
            "path": str(f),
            "name": f.stem,
            "task_counts": {"total": task_count, "pending": task_count, "running": 0, "done": 0, "failed": 0},
            "is_markdown": True,
        }
    except Exception:
        return {"path": str(f), "name": f.stem, "task_counts": {"total": 0}, "is_markdown": True}


def _is_tasks_file(f: Path) -> bool:
    """Check if a JSON file contains a tasks array."""
    try:
        data = json.loads(f.read_text())
        return isinstance(data.get("tasks"), list)
    except Exception:
        return False


def _task_file_summary(f: Path) -> dict:
    """Summarize a tasks file."""
    try:
        data = json.loads(f.read_text())
        tasks = data.get("tasks", [])
        counts = {"total": len(tasks), "pending": 0, "running": 0, "done": 0, "failed": 0}
        for t in tasks:
            st = t.get("status", "pending")
            if st in counts:
                counts[st] += 1
        return {
            "path": str(f),
            "name": f.stem,
            "task_counts": counts,
        }
    except Exception:
        return {"path": str(f), "name": f.stem, "task_counts": {"total": 0}}


def _is_pipeline_file(f: Path) -> bool:
    """Check if a JSON file is a pipeline (has 'stages' array, not 'tasks')."""
    try:
        data = json.loads(f.read_text())
        return isinstance(data.get("stages"), list) and "tasks" not in data
    except Exception:
        return False


def _pipeline_file_summary(f: Path) -> dict:
    """Summarize a pipeline file."""
    try:
        data = json.loads(f.read_text())
        stages = data.get("stages", [])
        return {
            "path": str(f),
            "name": data.get("name", f.stem),
            "stages": len(stages),
            "stage_names": [s.get("name", f"Stage {i+1}") for i, s in enumerate(stages)],
            "aggregate": data.get("aggregate", False),
        }
    except Exception:
        return {"path": str(f), "name": f.stem, "stages": 0}


def _find_pipeline_files(repo_path: Path) -> list[dict]:
    """Find pipeline JSON files in a repo directory."""
    results = []
    if not repo_path.is_dir():
        return results
    # Check root-level JSON files matching pipeline-*.json
    for f in sorted(repo_path.glob("pipeline*.json")):
        if _is_pipeline_file(f):
            results.append(_pipeline_file_summary(f))
    # Check pipelines/ subdirectory
    pipelines_dir = repo_path / "pipelines"
    if pipelines_dir.is_dir():
        for f in sorted(pipelines_dir.glob("*.json")):
            if _is_pipeline_file(f):
                results.append(_pipeline_file_summary(f))
    return results


def _get_repo_context(repo_path: Path) -> str:
    """Gather context about a repo for brainstorm task generation."""
    context_parts = []

    # Detect languages by file extensions - limit scan to avoid slow traversal
    extensions = {}
    scan_limit = 1000  # Max files to scan
    count = 0
    for f in repo_path.rglob("*"):
        if count >= scan_limit:
            break
        if f.is_file() and not f.name.startswith("."):
            ext = f.suffix.lower()
            if ext:
                extensions[ext] = extensions.get(ext, 0) + 1
            count += 1
    if extensions:
        top_exts = sorted(extensions.items(), key=lambda x: -x[1])[:5]
        langs = ", ".join(f"{ext}({count})" for ext, count in top_exts if ext)
        if langs:
            context_parts.append(f"Languages: {langs}")

    # Check for key config files
    key_files = []
    configs = [
        "package.json", "Cargo.toml", "pyproject.toml", "go.mod",
        "build.gradle", "pom.xml", "Makefile", "CLAUDE.md", "README.md",
    ]
    for cfg in configs:
        if (repo_path / cfg).exists():
            key_files.append(cfg)
    if key_files:
        context_parts.append(f"Key Files: {', '.join(key_files)}")

    # List top-level directories
    dirs = [d.name for d in repo_path.iterdir() if d.is_dir() and not d.name.startswith(".")]
    if dirs:
        context_parts.append(f"Structure: {', '.join(sorted(dirs)[:6])}")

    return "\n".join(context_parts) if context_parts else ""


def _stage_slug(name: str) -> str:
    """Convert a stage name to a file-safe slug."""
    return re.sub(r"[^a-z0-9]+", "-", name.lower()).strip("-")


def _convert_tasks_md_to_json(tasks_md: str) -> dict:
    """Convert tasks markdown to tasks JSON dict (mirrors orchestra-convert logic)."""
    sections = re.split(r"^## ", tasks_md, flags=re.MULTILINE)[1:]
    tasks = []
    for section in sections:
        lines = section.strip().split("\n")
        name = lines[0].strip()
        task_id = re.sub(r"[^a-z0-9]+", "-", name.lower()).strip("-")[:30].rstrip("-")

        meta: dict = {}
        prompt_lines: list[str] = []
        in_prompt = False

        for line in lines[1:]:
            stripped = line.strip()
            if not in_prompt and re.match(r"^- \w+:", stripped):
                key, val = stripped[2:].split(":", 1)
                meta[key.strip()] = val.strip()
            elif stripped == "":
                if not in_prompt:
                    in_prompt = True
                else:
                    prompt_lines.append("")
            else:
                in_prompt = True
                prompt_lines.append(line)

        task: dict = {
            "id": task_id,
            "name": name,
            "prompt": "\n".join(prompt_lines).strip(),
            "workdir": meta.get("workdir", "."),
            "model": meta.get("model", "opus"),
            "effort": meta.get("effort", "high"),
            "status": "pending",
        }
        for field in ("allowedTools", "appendSystemPrompt", "agents", "skills", "hooks"):
            if field in meta:
                task[field] = meta[field]
        # Retry fields
        if "max_retries" in meta:
            task["max_retries"] = int(meta["max_retries"])
        if "retry_delay_seconds" in meta:
            task["retry_delay_seconds"] = int(meta["retry_delay_seconds"])
        if "retry_backoff" in meta:
            task["retry_backoff"] = meta["retry_backoff"]
        # Verification fields
        if "verify" in meta:
            task["verify_strategy"] = meta["verify"]
        if "verifyCommand" in meta:
            task["verify_command"] = meta["verifyCommand"]
        if "verifyTimeout" in meta:
            task["verify_timeout"] = int(meta["verifyTimeout"])
        if "verifyPrompt" in meta:
            task["verify_prompt"] = meta["verifyPrompt"]
        tasks.append(task)
    return {"tasks": tasks}


def _load_tasks_file(file_path: Path) -> tuple[dict | None, str | None]:
    """Load and validate a tasks JSON file. Returns (data, error_msg)."""
    if not file_path.is_file():
        return None, "Task file not found"
    try:
        data = json.loads(file_path.read_text())
    except (json.JSONDecodeError, ValueError):
        return None, "Invalid JSON in task file"
    if not isinstance(data.get("tasks"), list):
        return None, "Task file missing 'tasks' array"
    return data, None


def _save_tasks_file(file_path: Path, data: dict):
    """Write tasks JSON file atomically via temp file."""
    file_path.parent.mkdir(parents=True, exist_ok=True)
    tmp_fd, tmp_path = tempfile.mkstemp(
        dir=str(file_path.parent), suffix=".json.tmp"
    )
    try:
        with os.fdopen(tmp_fd, "w") as f:
            json.dump(data, f, indent=2)
            f.write("\n")
        os.replace(tmp_path, str(file_path))
    except Exception:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


# ---------------------------------------------------------------------------
# Pipeline-mapping file helpers
# ---------------------------------------------------------------------------

_MAPPINGS_LOCK = threading.Lock()


def _mappings_dir() -> Path:
    """Return the data/mappings directory, creating it if needed."""
    d = ORCHESTRA_DIR / "data" / "mappings"
    d.mkdir(parents=True, exist_ok=True)
    return d


def _load_mapping(mapping_id: str) -> tuple[dict | None, str | None]:
    """Load a mapping state file. Returns (data, error_msg)."""
    path = _mappings_dir() / f"{mapping_id}.json"
    if not path.is_file():
        return None, "Mapping not found"
    try:
        data = json.loads(path.read_text())
    except (json.JSONDecodeError, ValueError):
        return None, "Corrupt mapping file"
    return data, None


def _save_mapping(mapping_id: str, data: dict):
    """Write mapping state file atomically."""
    dest = _mappings_dir() / f"{mapping_id}.json"
    tmp_fd, tmp_path = tempfile.mkstemp(dir=str(dest.parent), suffix=".json.tmp")
    try:
        with os.fdopen(tmp_fd, "w") as f:
            json.dump(data, f, indent=2)
            f.write("\n")
        os.replace(tmp_path, str(dest))
    except Exception:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


def _validate_workspace_path(raw_path: str) -> Path:
    """Resolve and validate a workspace file path. Raises ValueError if unsafe."""
    try:
        resolved = Path(raw_path).resolve()
    except (ValueError, OSError) as exc:
        raise ValueError(f"Cannot resolve path: {exc}") from exc

    home = Path.home().resolve()
    resolved_str = str(resolved)
    home_str = str(home)

    # Must be under home directory
    if not resolved_str.startswith(home_str):
        raise ValueError("Path must be under the user's home directory")

    # Reject sensitive directories (contains segment OR path ends at the directory)
    sensitive_dirs = (".ssh", ".aws", ".gnupg")
    for name in sensitive_dirs:
        segment = f"/{name}/"
        suffix = f"/{name}"
        if segment in resolved_str or resolved_str.endswith(suffix):
            raise ValueError(f"Path contains restricted segment: {name}")

    config_segment = "/.config/claude-orchestra/"
    config_suffix = "/.config/claude-orchestra"
    if config_segment in resolved_str or resolved_str.endswith(config_suffix):
        raise ValueError("Path contains restricted segment: .config/claude-orchestra")

    if "/credentials" in resolved_str:
        raise ValueError("Path contains restricted segment: credentials")

    # Reject any dotfile directory directly under $HOME (e.g. $HOME/.anything)
    if resolved.parent == home and resolved.name.startswith("."):
        raise ValueError("Path must not be inside a dotfile directory under home")

    # Must be inside a git repository (walk up from resolved path within home)
    check = resolved if resolved.is_dir() else resolved.parent
    while True:
        if (check / ".git").exists():
            break
        if check == home or check == check.parent:
            raise ValueError("Path must be inside a git repository")
        check = check.parent

    return resolved


class SSEBroker:
    """Manages connected SSE clients and broadcasts events."""

    def __init__(self):
        self._clients: list[queue.Queue] = []
        self._lock = threading.Lock()

    def subscribe(self) -> queue.Queue:
        q = queue.Queue(maxsize=256)
        with self._lock:
            self._clients.append(q)
        return q

    def unsubscribe(self, q: queue.Queue):
        with self._lock:
            try:
                self._clients.remove(q)
            except ValueError:
                pass

    def broadcast(self, event_type: str, data: dict):
        msg = f"event: {event_type}\ndata: {json.dumps(data, default=str)}\n\n"
        with self._lock:
            for q in list(self._clients):
                try:
                    q.put_nowait(msg)
                except queue.Full:
                    pass


class LogWatcher(threading.Thread):
    """Watches logs directory for state changes and stream updates."""

    def __init__(self, logs_dir: Path, broker: SSEBroker):
        super().__init__(daemon=True)
        self._logs_dir = logs_dir
        self._broker = broker
        self._stop_event = threading.Event()
        self._run_states: dict[str, dict[str, str]] = {}
        self._stream_positions: dict[str, int] = {}
        self._pipeline_states: dict[str, dict[int, str]] = {}
        self._snapshot()

    def _snapshot(self):
        """Capture initial state without emitting events."""
        if not self._logs_dir.is_dir():
            return
        for run_dir in self._logs_dir.iterdir():
            if not run_dir.is_dir():
                continue
            state_file = run_dir / "state.json"
            if not state_file.exists():
                continue
            try:
                state = json.loads(state_file.read_text())
            except Exception:
                continue
            tasks = state.get("tasks", [])
            self._run_states[run_dir.name] = {
                t["id"]: t.get("status", "pending") for t in tasks
            }
            for t in tasks:
                stream_f = run_dir / f"{t['id']}.stream.jsonl"
                if stream_f.exists():
                    try:
                        self._stream_positions[str(stream_f)] = stream_f.stat().st_size
                    except OSError:
                        pass
        for f in self._logs_dir.glob("*.json"):
            if f.parent != self._logs_dir:
                continue
            try:
                data = json.loads(f.read_text())
                if not isinstance(data.get("stages"), list):
                    continue
                self._pipeline_states[data["id"]] = {
                    i: s.get("status", "pending")
                    for i, s in enumerate(data["stages"])
                }
            except Exception:
                continue

    def stop(self):
        self._stop_event.set()

    def run(self):
        while not self._stop_event.is_set():
            try:
                self._poll()
            except Exception:
                pass
            self._stop_event.wait(timeout=1.0)

    def _poll(self):
        if not self._logs_dir.is_dir():
            return
        self._poll_runs()
        self._poll_pipelines()

    def _poll_runs(self):
        for run_dir in self._logs_dir.iterdir():
            if not run_dir.is_dir():
                continue
            state_file = run_dir / "state.json"
            if not state_file.exists():
                continue
            run_id = run_dir.name
            try:
                state = json.loads(state_file.read_text())
            except Exception:
                continue
            tasks = state.get("tasks", [])
            old_states = self._run_states.get(run_id, {})
            new_states = {}

            if run_id not in self._run_states:
                self._broker.broadcast("run_started", {
                    "run_id": run_id,
                    "task_count": len(tasks),
                    "started_at": state.get("started_at"),
                })

            for t in tasks:
                tid = t["id"]
                status = t.get("status", "pending")
                new_states[tid] = status
                old_status = old_states.get(tid)

                if old_status == status:
                    continue
                if status == "running" and old_status != "running":
                    self._broker.broadcast("task_started", {
                        "run_id": run_id,
                        "task_id": tid,
                        "task_name": t.get("name", tid),
                    })
                elif status == "retrying":
                    self._broker.broadcast("task_retrying", {
                        "run_id": run_id,
                        "task_id": tid,
                        "task_name": t.get("name", tid),
                        "attempt": t.get("attempt", 1),
                        "max_attempts": t.get("max_attempts", 1),
                    })
                elif status == "verifying":
                    self._broker.broadcast("task_verifying", {
                        "run_id": run_id,
                        "task_id": tid,
                        "task_name": t.get("name", tid),
                    })
                elif status in ("done", "failed"):
                    self._broker.broadcast("task_completed", {
                        "run_id": run_id,
                        "task_id": tid,
                        "task_name": t.get("name", tid),
                        "status": status,
                        "cost_usd": t.get("cost_usd"),
                        "attempt": t.get("attempt", 1),
                        "max_attempts": t.get("max_attempts", 1),
                        "verify_status": t.get("verify_status", "skipped"),
                    })

            self._run_states[run_id] = new_states

            # Emit run_progress on any task status change
            if old_states and new_states != old_states:
                done = sum(1 for s in new_states.values() if s == "done")
                failed = sum(1 for s in new_states.values() if s == "failed")
                running = sum(1 for s in new_states.values() if s == "running")
                retrying = sum(1 for s in new_states.values() if s == "retrying")
                verifying = sum(1 for s in new_states.values() if s == "verifying")
                self._broker.broadcast("run_progress", {
                    "run_id": run_id,
                    "tasks_done": done,
                    "tasks_failed": failed,
                    "tasks_running": running,
                    "tasks_retrying": retrying,
                    "tasks_verifying": verifying,
                    "tasks_total": len(new_states),
                })

            # Emit run_completed when all tasks reach terminal state
            all_terminal = new_states and all(
                s in ("done", "failed") for s in new_states.values()
            )
            was_terminal = old_states and all(
                s in ("done", "failed") for s in old_states.values()
            )
            if all_terminal and not was_terminal:
                done = sum(1 for s in new_states.values() if s == "done")
                failed = sum(1 for s in new_states.values() if s == "failed")
                tasks_retried = sum(
                    1 for t in tasks if t.get("attempt", 1) > 1
                )
                self._broker.broadcast("run_completed", {
                    "run_id": run_id,
                    "tasks_done": done,
                    "tasks_failed": failed,
                    "tasks_retried": tasks_retried,
                })

            # Watch stream files for running tasks
            for t in tasks:
                if t.get("status") != "running":
                    continue
                stream_f = run_dir / f"{t['id']}.stream.jsonl"
                if stream_f.exists():
                    self._poll_stream(run_id, t["id"], stream_f)

    def _poll_stream(self, run_id: str, task_id: str, stream_f: Path):
        key = str(stream_f)
        pos = self._stream_positions.get(key, 0)
        try:
            size = stream_f.stat().st_size
            if size <= pos:
                return
            with open(stream_f, "r", errors="replace") as f:
                f.seek(pos)
                new_data = f.read()
                self._stream_positions[key] = f.tell()

            for line in new_data.strip().split("\n"):
                if not line.strip():
                    continue
                try:
                    ev = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if ev.get("type") == "system" and ev.get("subtype") == "task_progress":
                    self._broker.broadcast("task_progress", {
                        "run_id": run_id,
                        "task_id": task_id,
                        "description": ev.get("description", ""),
                        "tool_name": ev.get("last_tool_name"),
                        "duration_ms": ev.get("usage", {}).get("duration_ms"),
                    })
        except OSError:
            pass

    def _poll_pipelines(self):
        for f in self._logs_dir.glob("*.json"):
            if f.parent != self._logs_dir:
                continue
            try:
                data = json.loads(f.read_text())
                if not isinstance(data.get("stages"), list):
                    continue
                pid = data["id"]
                stages = data["stages"]
                old_stages = self._pipeline_states.get(pid, {})
                new_stages = {}

                for i, stage in enumerate(stages):
                    status = stage.get("status", "pending")
                    new_stages[i] = status
                    old_status = old_stages.get(i)

                    if old_status == status:
                        continue
                    if status == "running":
                        self._broker.broadcast("stage_started", {
                            "pipeline_id": pid,
                            "stage_index": i,
                            "stage_name": stage.get("name", f"Stage {i}"),
                        })
                    elif status in ("done", "failed"):
                        self._broker.broadcast("stage_completed", {
                            "pipeline_id": pid,
                            "stage_index": i,
                            "stage_name": stage.get("name", f"Stage {i}"),
                            "status": status,
                        })

                self._pipeline_states[pid] = new_stages

                # Auto-trigger summary when pipeline reaches terminal state
                all_terminal = new_stages and all(
                    s in ("done", "failed", "skipped") for s in new_stages.values()
                )
                was_terminal = old_stages and all(
                    s in ("done", "failed", "skipped") for s in old_stages.values()
                )
                if all_terminal and not was_terminal:
                    summary_file = _pipeline_summary_path(self._logs_dir, pid)
                    if not summary_file.exists():
                        _generate_summary_async(pid, self._logs_dir, self._broker)
            except Exception:
                continue


def _summarize_tool(tool: str, inp: dict) -> str:
    """One-line summary of a tool call (ported from orchestra-dashboard)."""
    if tool == "Read":
        fp = inp.get("file_path", "")
        return f"Reading {Path(fp).name}" if fp else "Reading..."
    elif tool == "Glob":
        return f"Searching {inp.get('pattern', '...')}"
    elif tool == "Grep":
        pat = inp.get("pattern", "")
        return f"Grep: {pat[:40]}" if pat else "Searching..."
    elif tool == "Edit":
        fp = inp.get("file_path", "")
        return f"Editing {Path(fp).name}" if fp else "Editing..."
    elif tool == "Write":
        fp = inp.get("file_path", "")
        return f"Writing {Path(fp).name}" if fp else "Writing..."
    elif tool == "Bash":
        cmd = inp.get("command", "")
        return f"$ {cmd[:50]}" if cmd else "Running..."
    elif tool in ("Agent", "Task"):
        desc = inp.get("description", inp.get("prompt", "")[:40])
        return f"Agent: {desc[:40]}" if desc else "Agent..."
    elif tool == "WebFetch":
        url = inp.get("url", "")
        return f"Fetch: {url[:50]}" if url else "Fetching..."
    elif tool == "TodoWrite":
        return "Updating todo list"
    return tool


def _format_bytes(n: int) -> str:
    if n < 1024:
        return f"{n}B"
    elif n < 1024 * 1024:
        return f"{n / 1024:.1f}K"
    else:
        return f"{n / (1024 * 1024):.1f}M"


def _extract_cost_from_stream(stream_path: Path):
    """Return total_cost_usd from a stream.jsonl result event, or None."""
    try:
        with open(stream_path, "r", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    ev = json.loads(line)
                    if ev.get("type") == "result" and "total_cost_usd" in ev:
                        return float(ev["total_cost_usd"])
                except (json.JSONDecodeError, ValueError):
                    continue
    except OSError:
        pass
    return None


def _parse_stream(stream_path: Path) -> dict:
    """Single-pass JSONL parse into structured event summary."""
    events = []
    meta = {}
    tool_results = {}

    lines = []
    with open(stream_path, "r", errors="replace") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                lines.append(json.loads(line))
            except json.JSONDecodeError:
                continue

    # First pass: collect tool results
    for ev in lines:
        if ev.get("type") == "user":
            msg = ev.get("message", {})
            content = msg.get("content", [])
            if isinstance(content, list):
                for c in content:
                    if isinstance(c, dict) and c.get("type") == "tool_result":
                        raw = c.get("content", "")
                        if isinstance(raw, list):
                            raw = " ".join(
                                item.get("text", "")
                                for item in raw
                                if isinstance(item, dict)
                            )
                        tool_results[c.get("tool_use_id", "")] = str(raw)

    # Second pass: build event list
    seq = 0
    for ev in lines:
        t = ev.get("type")

        if t == "system":
            sub = ev.get("subtype")
            if sub == "init":
                events.append(
                    {
                        "seq": seq,
                        "type": "init",
                        "cwd": ev.get("cwd"),
                        "model": ev.get("model"),
                        "tool_count": len(ev.get("tools", [])),
                        "session_id": ev.get("session_id"),
                    }
                )
                seq += 1
            elif sub == "task_started":
                events.append(
                    {
                        "seq": seq,
                        "type": "task_started",
                        "description": ev.get("description"),
                    }
                )
                seq += 1
            elif sub == "task_progress":
                events.append(
                    {
                        "seq": seq,
                        "type": "progress",
                        "description": ev.get("description", ""),
                        "tool_name": ev.get("last_tool_name"),
                        "tool_uses_so_far": ev.get("usage", {}).get("tool_uses"),
                        "duration_ms": ev.get("usage", {}).get("duration_ms"),
                    }
                )
                seq += 1
            elif sub == "task_notification":
                events.append(
                    {
                        "seq": seq,
                        "type": "task_notification",
                        "status": ev.get("status"),
                        "summary": ev.get("summary"),
                    }
                )
                seq += 1

        elif t == "assistant":
            for c in ev.get("message", {}).get("content", []):
                ct = c.get("type")
                if ct == "thinking":
                    events.append(
                        {"seq": seq, "type": "thinking", "text": c.get("thinking", "")}
                    )
                    seq += 1
                elif ct == "tool_use":
                    tid = c.get("id", "")
                    raw_result = tool_results.get(tid, "")
                    events.append(
                        {
                            "seq": seq,
                            "type": "tool_use",
                            "name": c.get("name"),
                            "input": c.get("input", {}),
                            "summary": _summarize_tool(
                                c.get("name", ""), c.get("input", {})
                            ),
                            "result": raw_result[:500],
                            "result_truncated": len(raw_result) > 500,
                        }
                    )
                    seq += 1
                elif ct == "text":
                    events.append(
                        {"seq": seq, "type": "text", "text": c.get("text", "")}
                    )
                    seq += 1

        elif t == "result":
            usage = ev.get("usage", {})
            meta = {
                "duration_ms": ev.get("duration_ms"),
                "total_cost_usd": ev.get("total_cost_usd"),
                "num_turns": ev.get("num_turns"),
                "stop_reason": ev.get("stop_reason"),
                "input_tokens": usage.get("input_tokens", 0),
                "output_tokens": usage.get("output_tokens", 0),
            }

        elif t == "rate_limit_event":
            events.append({"seq": seq, "type": "rate_limit"})
            seq += 1

    return {"meta": meta, "events": events}


def _auto_assign_tasks_to_stages(tasks: list[dict], stages: list[str]) -> dict[str, int]:
    """Auto-assign tasks to stages based on content analysis.
    
    Returns a dict mapping task_id -> stage_index.
    """
    if not stages or not tasks:
        return {}
    
    # Keywords for common stage types (include common variations)
    stage_keywords = {
        "plan": ["plan", "planning", "design", "designing", "architect", "architecting", "analyze", "analyse", "analysis", "research", "investigate", "explore", "exploration"],
        "implement": ["implement", "implementing", "implementation", "build", "building", "create", "creating", "add", "adding", "write", "writing", "develop", "developing", "code", "coding", "fix", "fixing", "refactor", "refactoring"],
        "review": ["review", "reviewing", "test", "testing", "tests", "verify", "verifying", "verification", "check", "checking", "audit", "auditing", "validate", "validation", "security", "quality"],
        "audit": ["audit", "auditing", "security", "review", "check", "checking", "scan", "scanning", "vulnerability"],
        "bugfix": ["fix", "fixing", "bug", "bugs", "patch", "patching", "resolve", "resolving", "debug", "debugging", "error", "errors"],
        "release": ["release", "releasing", "deploy", "deploying", "deployment", "publish", "publishing", "changelog", "version", "tag", "tagging"],
    }
    
    assignments = {}
    num_stages = len(stages)
    
    for task in tasks:
        task_id = task.get("id", "")
        task_name = (task.get("name", "") + " " + task.get("prompt", "")).lower()
        
        # Tokenize for word-boundary matching
        import re
        task_words = set(re.findall(r'\b\w+\b', task_name))
        
        # Find best matching stage
        best_stage = 0
        best_score = 0
        
        for i, stage_name in enumerate(stages):
            stage_lower = stage_name.lower()
            score = 0
            
            # Check for exact stage name match (word boundary)
            if stage_lower in task_words:
                score += 10
            
            # Check keywords (word boundary matching)
            keywords = stage_keywords.get(stage_lower, [])
            for kw in keywords:
                if kw in task_words:
                    score += 3
            
            # Prefer later stages in case of ties (makes sense for pipeline flow)
            # This ensures review/test tasks go to later stages
            if score >= best_score:
                best_score = score
                best_stage = i
        
        # If no match found, distribute evenly across stages
        if best_score == 0:
            best_stage = len(assignments) % num_stages
        
        assignments[task_id] = best_stage
    
    return assignments


# ---------------------------------------------------------------------------
# Pipeline summary generation
# ---------------------------------------------------------------------------

def _truncate_output(text: str) -> str:
    """Truncate task output to ~1500 tokens (≈6000 chars) and strip image references.

    Image references are stripped because the summary model cannot process images.
    """
    # Strip markdown image syntax: ![alt text](image.png)
    text = re.sub(r'!\[[^\]]*\]\([^)]+\)', '[image stripped]', text)
    # Strip HTML img tags
    text = re.sub(r'<img[^>]*>', '[image stripped]', text, flags=re.IGNORECASE)

    if len(text) <= _SUMMARY_OUTPUT_MAX_CHARS:
        return text
    return "(truncated — first 1500 tokens)\n" + text[:_SUMMARY_OUTPUT_MAX_CHARS]


def _pipeline_summary_path(logs_dir: Path, pipeline_id: str) -> Path:
    """Return the file path for a pipeline's stored summary."""
    return logs_dir / f"{pipeline_id}.summary.md"


def _build_summary_prompt(pipeline_data: dict, logs_dir: Path) -> str | None:
    """Build the user prompt for summary generation.

    Returns None if every task was skipped (no output at all).
    """
    stages = pipeline_data.get("stages", [])
    started_at = pipeline_data.get("started_at", 0)
    try:
        started_iso = datetime.fromtimestamp(int(started_at), tz=timezone.utc).isoformat()
    except Exception:
        started_iso = "unknown"

    # Compute completed_at from latest task finished_at across all stages
    latest_finished = 0
    for stage in stages:
        for run_id in stage.get("run_ids", []):
            sf = logs_dir / run_id / "state.json"
            if sf.exists():
                try:
                    state = json.loads(sf.read_text())
                    for t in state.get("tasks", []):
                        fin = t.get("finished_at") or 0
                        if fin > latest_finished:
                            latest_finished = fin
                except Exception:
                    pass
    if latest_finished > 0:
        try:
            completed_iso = datetime.fromtimestamp(int(latest_finished), tz=timezone.utc).isoformat()
        except Exception:
            completed_iso = "unknown"
        duration_s = int(latest_finished) - int(started_at) if started_at else 0
        mins, secs = divmod(duration_s, 60)
        duration_str = f"{mins}m {secs}s" if mins else f"{secs}s"
    else:
        completed_iso = "unknown"
        duration_str = "unknown"

    # Compute overall status
    statuses = [s.get("status", "pending") for s in stages]
    if all(s == "done" for s in statuses):
        overall_status = "SUCCEEDED"
    elif all(s in ("failed", "skipped") for s in statuses):
        overall_status = "FAILED"
    elif any(s == "failed" for s in statuses) or any(s == "skipped" for s in statuses):
        overall_status = "PARTIAL"
    else:
        overall_status = "SUCCEEDED"

    # Build stages XML
    stages_xml_parts = []
    has_any_output = False
    for i, stage in enumerate(stages):
        stage_status = stage.get("status", "pending")
        status_map = {"done": "SUCCEEDED", "failed": "FAILED", "skipped": "SKIPPED", "pending": "SKIPPED"}
        stage_status_label = status_map.get(stage_status, stage_status.upper())

        tasks_xml_parts = []
        for run_id in stage.get("run_ids", []):
            sf = logs_dir / run_id / "state.json"
            if not sf.exists():
                continue
            try:
                state = json.loads(sf.read_text())
            except Exception:
                continue
            for t in state.get("tasks", []):
                t_status = t.get("status", "pending")
                t_status_label = status_map.get(t_status, t_status.upper())
                # Read task output
                out_file = logs_dir / run_id / f"{t['id']}.output.md"
                if out_file.exists():
                    try:
                        raw_output = out_file.read_text()
                        if raw_output.strip():
                            has_any_output = True
                            output_text = _truncate_output(raw_output)
                        else:
                            output_text = "(no output — skipped)"
                    except Exception:
                        output_text = "(no output — skipped)"
                else:
                    output_text = "(no output — skipped)"
                tasks_xml_parts.append(
                    f'        <task name="{t.get("name", t["id"])}" status="{t_status_label}">\n'
                    f'          <output>{output_text}</output>\n'
                    f'        </task>'
                )

        # If stage has no run_ids, still include it as skipped
        if not tasks_xml_parts:
            tasks_xml_parts.append(
                f'        <task name="(no tasks)" status="SKIPPED">\n'
                f'          <output>(no output — skipped)</output>\n'
                f'        </task>'
            )

        stages_xml_parts.append(
            f'    <stage index="{i + 1}" name="{stage.get("name", f"Stage {i + 1}")}" status="{stage_status_label}">\n'
            f'      <tasks>\n'
            + "\n".join(tasks_xml_parts) + "\n"
            f'      </tasks>\n'
            f'    </stage>'
        )

    if not has_any_output:
        return None

    stages_xml = "\n".join(stages_xml_parts)

    return PIPELINE_SUMMARY_USER_TEMPLATE.format(
        pipeline_name=pipeline_data.get("name", "Unnamed"),
        run_id=pipeline_data.get("id", "unknown"),
        started_at=started_iso,
        completed_at=completed_iso,
        duration=duration_str,
        overall_status=overall_status,
        stages_xml=stages_xml,
    )


def _generate_summary_sync(pipeline_id: str, logs_dir: Path) -> tuple[str | None, str | None]:
    """Generate a pipeline summary synchronously.

    Returns (summary_markdown, error_message). One of the two will be None.
    """
    summary_file = _pipeline_summary_path(logs_dir, pipeline_id)

    # Immutable: never regenerate
    if summary_file.exists():
        return summary_file.read_text(), None

    pf = logs_dir / f"{pipeline_id}.json"
    if not pf.exists():
        return None, "Pipeline not found"

    try:
        pipeline_data = json.loads(pf.read_text())
    except Exception as e:
        return None, f"Failed to read pipeline state: {e}"

    user_prompt = _build_summary_prompt(pipeline_data, logs_dir)
    if user_prompt is None:
        return None, "no_output"

    try:
        result = subprocess.run(
            [CLAUDE_CMD, "--print", "--model", "opus", "--append-system-prompt", PIPELINE_SUMMARY_SYSTEM_PROMPT],
            input=user_prompt,
            capture_output=True,
            text=True,
            timeout=300,
        )
    except FileNotFoundError:
        return None, f"{CLAUDE_CMD} CLI not found"
    except subprocess.TimeoutExpired:
        return None, "Claude CLI timed out (300s)"

    if result.returncode != 0:
        return None, f"Claude CLI error: {result.stderr.strip()[:200]}"

    summary = result.stdout.strip()
    if not summary:
        return None, "Claude returned empty output"

    # Persist the summary
    try:
        summary_file.write_text(summary)
    except OSError as e:
        return None, f"Failed to write summary file: {e}"

    return summary, None


def _generate_summary_async(pipeline_id: str, logs_dir: Path, broker: SSEBroker | None):
    """Generate summary in a background thread. Broadcasts SSE on completion."""
    def _worker():
        summary, error = _generate_summary_sync(pipeline_id, logs_dir)
        if broker:
            if summary:
                broker.broadcast("pipeline_summary_ready", {
                    "pipeline_id": pipeline_id,
                })
            elif error and error != "no_output":
                broker.broadcast("pipeline_summary_error", {
                    "pipeline_id": pipeline_id,
                    "error": error,
                })
    t = threading.Thread(target=_worker, daemon=True)
    t.start()


class OrchestraHandler(BaseHTTPRequestHandler):
    logs_dir: Path = Path(".")
    broker: SSEBroker = None

    def do_GET(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")
        qs = parse_qs(parsed.query, keep_blank_values=True)

        if path in ("", "/"):
            self._serve_file(VIEWER_DIR / "index.html", "text/html")
        elif path == "/api/runs":
            self._api_runs(qs)
        elif path == "/api/runs/active":
            self._api_runs_active(qs)
        elif m := re.match(r"^/api/runs/([^/]+)$", path):
            self._api_run_detail(m.group(1))
        elif m := re.match(r"^/api/runs/([^/]+)/([^/]+)/output$", path):
            self._api_task_output(m.group(1), m.group(2))
        elif m := re.match(r"^/api/runs/([^/]+)/([^/]+)/stream$", path):
            summarize = "summarize" in qs
            self._api_task_stream(m.group(1), m.group(2), summarize)
        elif m := re.match(r"^/api/runs/([^/]+)/([^/]+)/verify$", path):
            self._api_task_verify(m.group(1), m.group(2))
        elif path == "/api/pipelines":
            self._api_pipelines()
        elif path == "/api/pipelines/templates":
            self._api_pipeline_templates()
        elif path == "/api/pipelines/docs":
            self._api_pipeline_docs()
        elif m := re.match(r"^/api/pipeline/([^/]+)$", path):
            self._api_pipeline_detail(m.group(1))
        elif m := re.match(r"^/api/pipeline/([^/]+)/summary$", path):
            self._api_pipeline_summary_get(m.group(1))
        elif path == "/api/config/paths":
            self._api_config_paths()
        elif path == "/api/config/agents":
            self._api_config_agents_list()
        elif m := re.match(r"^/api/config/agents/([^/]+)$", path):
            self._api_config_agent_get(m.group(1))
        elif path == "/api/config/skills":
            self._api_config_skills_list()
        elif m := re.match(r"^/api/config/skills/([^/]+)$", path):
            self._api_config_skill_get(m.group(1))
        elif path == "/api/config/hooks":
            self._api_config_hooks_list()
        elif path == "/api/events":
            self._api_events()
        elif path == "/api/workspace/repos":
            self._api_workspace_repos()
        elif m := re.match(r"^/api/workspace/repos/(.+)/tasks$", path):
            self._api_workspace_repo_tasks(unquote(m.group(1)))
        elif path == "/api/workspace/tasks-file":
            self._api_workspace_tasks_file()
        elif path == "/api/workspace/tasks-md":
            self._api_workspace_tasks_md_get()
        elif path == "/api/workspace/active-runs":
            self._api_workspace_active_runs()
        elif m := re.match(r"^/api/pipeline-mapping/([^/]+)/history$", path):
            self._api_mapping_history(m.group(1))
        elif m := re.match(r"^/api/pipeline-mapping/([^/]+)$", path):
            self._api_mapping_get(m.group(1))
        else:
            self._not_found()

    def do_POST(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")

        # Auth endpoints are always accessible (no auth guard)
        if path == "/api/auth/register":
            self._api_auth_register()
            return
        elif path == "/api/auth/login":
            self._api_auth_login()
            return

        # Auth guard for all other POST endpoints
        if os.environ.get("ORCHESTRA_AUTH_ENABLED", "false").lower() == "true":
            if self._require_auth() is None:
                return

        if path == "/api/workspace/tasks":
            self._api_workspace_task_create()
        elif m := re.match(r"^/api/workspace/tasks/([^/]+)/run$", path):
            self._api_workspace_task_run(m.group(1))
        elif path == "/api/workspace/brainstorm":
            self._api_workspace_brainstorm()
        elif path == "/api/workspace/brainstorm/pipeline":
            self._api_workspace_brainstorm_pipeline()
        elif path == "/api/workspace/brainstorm/stage":
            self._api_workspace_brainstorm_stage()
        elif path == "/api/workspace/brainstorm/pipeline/run":
            self._api_workspace_brainstorm_pipeline_run()
        elif path == "/api/workspace/brainstorm/to-mapping":
            self._api_workspace_brainstorm_to_mapping()
        elif path == "/api/workspace/tasks-md/convert":
            self._api_workspace_tasks_md_convert()
        elif path == "/api/workspace/orchestra/run":
            self._api_workspace_orchestra_run()
        elif path == "/api/workspace/pipeline/run":
            self._api_workspace_pipeline_run()
        elif m := re.match(r"^/api/workspace/runs/([^/]+)/cancel$", path):
            self._api_workspace_run_cancel(m.group(1))
        elif m := re.match(r"^/api/pipelines/templates/([^/]+)/create$", path):
            self._api_pipeline_template_create(m.group(1))
        elif path == "/api/pipeline-mapping/create":
            self._api_mapping_create()
        elif m := re.match(r"^/api/pipeline/([^/]+)/summary$", path):
            self._api_pipeline_summary_generate(m.group(1))
        elif m := re.match(r"^/api/pipeline-mapping/([^/]+)/execute$", path):
            self._api_mapping_execute(m.group(1))
        else:
            self._not_found()

    def do_PUT(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")

        if os.environ.get("ORCHESTRA_AUTH_ENABLED", "false").lower() == "true":
            if self._require_auth() is None:
                return

        if m := re.match(r"^/api/config/agents/([^/]+)$", path):
            self._api_config_agent_put(m.group(1))
        elif m := re.match(r"^/api/config/skills/([^/]+)$", path):
            self._api_config_skill_put(m.group(1))
        elif m := re.match(r"^/api/workspace/tasks/([^/]+)$", path):
            self._api_workspace_task_update(m.group(1))
        elif path == "/api/workspace/tasks-md":
            self._api_workspace_tasks_md_put()
        elif m := re.match(r"^/api/pipeline-mapping/([^/]+)/assign$", path):
            self._api_mapping_assign(m.group(1))
        else:
            self._not_found()

    def do_DELETE(self):
        parsed = urlparse(self.path)
        path = parsed.path.rstrip("/")

        if os.environ.get("ORCHESTRA_AUTH_ENABLED", "false").lower() == "true":
            if self._require_auth() is None:
                return

        if m := re.match(r"^/api/config/agents/([^/]+)$", path):
            self._api_config_agent_delete(m.group(1))
        elif m := re.match(r"^/api/config/skills/([^/]+)$", path):
            self._api_config_skill_delete(m.group(1))
        elif m := re.match(r"^/api/workspace/tasks/([^/]+)$", path):
            self._api_workspace_task_delete(m.group(1))
        elif m := re.match(r"^/api/pipeline-mapping/([^/]+)/assign/([^/]+)$", path):
            self._api_mapping_unassign(m.group(1), m.group(2))
        else:
            self._not_found()

    def do_OPTIONS(self):
        self.send_response(204)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type, Authorization")
        self.end_headers()

    def _require_auth(self):
        """Extract and verify Bearer token from Authorization header.

        Returns the decoded JWT payload dict on success, or None after
        sending a 401 JSON error response.
        """
        auth_header = self.headers.get("Authorization", "")
        if not auth_header.startswith("Bearer "):
            self._error(401, "Missing or malformed Authorization header")
            return None
        token = auth_header[7:]
        try:
            return verify_token(token)
        except (ValueError, RuntimeError) as exc:
            self._error(401, str(exc))
            return None

    def _validate_ids(self, run_id, task_id=None):
        if not RUN_ID_RE.match(run_id):
            self._error(400, "Invalid run ID format")
            return False
        if task_id and not TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task ID format")
            return False
        return True

    def _load_all_runs(self):
        """Read all run state files and return a list of (run_dir, state) tuples.
        Results are cached for _CACHE_TTL seconds."""
        logs_dir = self.logs_dir

        def _read():
            result = []
            if not logs_dir.is_dir():
                return result
            for run_dir in sorted(logs_dir.iterdir(), reverse=True):
                if not run_dir.is_dir():
                    continue
                state_file = run_dir / "state.json"
                if not state_file.exists():
                    continue
                try:
                    state = json.loads(state_file.read_text())
                except Exception:
                    continue
                result.append((run_dir, state))
            return result

        return _cached(f"runs:{logs_dir}", _read)

    def _api_runs(self, qs: dict):
        repo_filter = qs.get("repo", [None])[0]
        runs = []
        for run_dir, state in self._load_all_runs():
            tasks = state.get("tasks", [])
            # Apply repo filter: include run if any task matches the requested workdir
            if repo_filter:
                if not any(t.get("workdir") == repo_filter for t in tasks):
                    continue
            counts = {
                "total": len(tasks),
                "done": 0,
                "running": 0,
                "pending": 0,
                "failed": 0,
                "retrying": 0,
                "verifying": 0,
            }
            for t in tasks:
                st = t.get("status", "pending")
                if st in counts:
                    counts[st] += 1
            total_output = 0
            total_cost = None
            for t in tasks:
                out_f = run_dir / f"{t['id']}.output.md"
                if out_f.exists():
                    total_output += out_f.stat().st_size
                c = t.get("cost_usd")
                if c is not None:
                    total_cost = (total_cost or 0.0) + c
            # Fall back to parsing stream files for runs without cost in state
            if total_cost is None:
                for t in tasks:
                    if t.get("status") in ("done", "failed"):
                        stream_f = run_dir / f"{t['id']}.stream.jsonl"
                        c = _extract_cost_from_stream(stream_f)
                        if c is not None:
                            total_cost = (total_cost or 0.0) + c
            ts = state.get("started_at", 0)
            try:
                iso = datetime.fromtimestamp(int(ts), tz=timezone.utc).isoformat()
            except Exception:
                iso = None
            workdirs = sorted({
                t.get("workdir", "")
                for t in tasks
                if t.get("workdir", "")
            })

            # Read metadata.json if it exists
            repo_path = None
            metadata_file = run_dir / "metadata.json"
            if metadata_file.exists():
                try:
                    metadata = json.loads(metadata_file.read_text())
                    repo_path = metadata.get("repo_path")
                except Exception:
                    pass

            run_dict = {
                "id": run_dir.name,
                "started_at": ts,
                "started_at_iso": iso,
                "ecc_enabled": state.get("ecc_enabled", False),
                "task_counts": counts,
                "total_output_bytes": total_output,
                "total_cost_usd": total_cost,
                "workdirs": workdirs,
            }
            if repo_path:
                run_dict["repo_path"] = repo_path
            runs.append(run_dict)
        self._json({"runs": runs})

    def _api_runs_active(self, qs: dict):
        """GET /api/runs/active[?repo=...] — return tasks currently running."""
        repo_filter = qs.get("repo", [None])[0]
        active_tasks = []
        for run_dir, state in self._load_all_runs():
            for task in state.get("tasks", []):
                if task.get("status") != "running":
                    continue
                workdir = task.get("workdir")
                if repo_filter and workdir != repo_filter:
                    continue
                active_tasks.append(
                    {
                        "run_id": run_dir.name,
                        "task_id": task["id"],
                        "task_name": task.get("name", ""),
                        "repo": workdir,
                        "status": "running",
                        "started_at": state.get("started_at"),
                    }
                )
        self._json({"active_tasks": active_tasks})

    def _api_run_detail(self, run_id):
        if not self._validate_ids(run_id):
            return
        run_dir = self.logs_dir / run_id
        state_file = run_dir / "state.json"
        if not state_file.exists():
            self._not_found()
            return
        state = json.loads(state_file.read_text())
        tasks = []
        total_cost = None
        for t in state.get("tasks", []):
            tid = t["id"]
            output_f = run_dir / f"{tid}.output.md"
            stream_f = run_dir / f"{tid}.stream.jsonl"
            # Use cost from state; fall back to parsing stream for older runs
            cost = t.get("cost_usd")
            if cost is None and t.get("status") in ("done", "failed") and stream_f.exists():
                cost = _extract_cost_from_stream(stream_f)
            if cost is not None:
                total_cost = (total_cost or 0.0) + cost
            verify_md = run_dir / f"{tid}.verify.md"
            verify_log = run_dir / f"{tid}.verify.log"
            tasks.append(
                {
                    **t,
                    "cost_usd": cost,
                    "output_bytes": output_f.stat().st_size
                    if output_f.exists()
                    else 0,
                    "stream_bytes": stream_f.stat().st_size
                    if stream_f.exists()
                    else 0,
                    "has_output": output_f.exists() and output_f.stat().st_size > 0,
                    "has_stream": stream_f.exists() and stream_f.stat().st_size > 0,
                    "has_verify_output": verify_md.exists() and verify_md.stat().st_size > 0,
                    "has_verify_log": verify_log.exists() and verify_log.stat().st_size > 0,
                }
            )
        ts = state.get("started_at", 0)
        try:
            iso = datetime.fromtimestamp(int(ts), tz=timezone.utc).isoformat()
        except Exception:
            iso = None
        self._json(
            {
                "id": run_id,
                "started_at": ts,
                "started_at_iso": iso,
                "ecc_enabled": state.get("ecc_enabled", False),
                "total_cost_usd": total_cost,
                "tasks": tasks,
            }
        )

    def _api_task_output(self, run_id, task_id):
        if not self._validate_ids(run_id, task_id):
            return
        output_f = self.logs_dir / run_id / f"{task_id}.output.md"
        if not output_f.exists():
            self._not_found()
            return
        self._serve_file(output_f, "text/plain; charset=utf-8")

    def _api_task_stream(self, run_id, task_id, summarize):
        if not self._validate_ids(run_id, task_id):
            return
        stream_f = self.logs_dir / run_id / f"{task_id}.stream.jsonl"
        if not stream_f.exists():
            self._not_found()
            return
        if summarize:
            summary = _parse_stream(stream_f)
            self._json(summary)
        else:
            self._serve_file(stream_f, "application/x-ndjson")

    def _api_task_verify(self, run_id, task_id):
        """GET /api/runs/<run_id>/<task_id>/verify — return verify output and log."""
        if not self._validate_ids(run_id, task_id):
            return
        run_dir = self.logs_dir / run_id
        verify_md = run_dir / f"{task_id}.verify.md"
        verify_log = run_dir / f"{task_id}.verify.log"
        result = {
            "task_id": task_id,
            "has_verify_output": verify_md.exists() and verify_md.stat().st_size > 0,
            "has_verify_log": verify_log.exists() and verify_log.stat().st_size > 0,
            "verify_output": "",
            "verify_log": "",
        }
        if verify_md.exists():
            try:
                result["verify_output"] = verify_md.read_text()[:5000]
            except Exception:
                pass
        if verify_log.exists():
            try:
                result["verify_log"] = verify_log.read_text()[:5000]
            except Exception:
                pass
        self._json(result)

    def _api_pipelines(self):
        pipelines = []
        if not self.logs_dir.is_dir():
            self._json({"pipelines": []})
            return
        # Find pipeline state files: either old format (pipeline-*.json) 
        # or new format (name-slug.json with 'stages' field)
        for f in sorted(self.logs_dir.glob("*.json"), reverse=True):
            # Skip state.json files in run directories
            if f.parent != self.logs_dir:
                continue
            try:
                data = json.loads(f.read_text())
                # Pipeline state files have 'stages' array
                if "stages" not in data or not isinstance(data.get("stages"), list):
                    continue
                stages = data.get("stages", [])
                # Compute overall status
                statuses = [s.get("status", "pending") for s in stages]
                if "running" in statuses:
                    overall = "running"
                elif "failed" in statuses:
                    overall = "failed"
                elif all(s == "done" for s in statuses):
                    overall = "done"
                else:
                    overall = "pending"
                ts = data.get("started_at", 0)
                try:
                    iso = datetime.fromtimestamp(int(ts), tz=timezone.utc).isoformat()
                except Exception:
                    iso = None
                pid = data["id"]
                pipelines.append({
                    "id": pid,
                    "name": data.get("name", "Unnamed"),
                    "started_at": ts,
                    "started_at_iso": iso,
                    "stage_count": len(stages),
                    "status": overall,
                    "stages": stages,
                    "has_summary": _pipeline_summary_path(self.logs_dir, pid).exists(),
                })
            except Exception:
                continue
        self._json({"pipelines": pipelines})

    def _api_pipeline_detail(self, pipeline_id):
        if not PIPELINE_ID_RE.match(pipeline_id):
            self._error(400, "Invalid pipeline ID")
            return
        pf = self.logs_dir / f"{pipeline_id}.json"
        if not pf.exists():
            self._not_found()
            return
        data = json.loads(pf.read_text())
        logs_dir = pf.parent  # logs/ directory
        
        # Get the source pipeline file directory for resolving task files
        pipeline_file = data.get("pipeline_file")
        if pipeline_file:
            pipeline_base_dir = Path(pipeline_file).parent
        else:
            pipeline_base_dir = logs_dir
        
        stages = []
        total_cost = None
        for stage in data.get("stages", []):
            enriched = dict(stage)
            run_ids = stage.get("run_ids", [])
            stage_tasks = []
            stage_cost = None
            
            # Load tasks from run directories (if pipeline has been run)
            for run_id in run_ids:
                run_dir = self.logs_dir / run_id
                sf = run_dir / "state.json"
                if sf.exists():
                    try:
                        state = json.loads(sf.read_text())
                        for t in state.get("tasks", []):
                            cost = t.get("cost_usd")
                            if cost is not None:
                                stage_cost = (stage_cost or 0.0) + cost
                            stage_tasks.append({**t, "run_id": run_id})
                    except Exception:
                        pass
            
            # If no run_ids or no tasks found, try loading from referenced task files
            if not stage_tasks:
                # Handle both 'tasks' (array of dicts with file key) and 'task_files' (array of strings)
                task_refs = stage.get("tasks", [])
                task_files = stage.get("task_files", [])
                
                # Normalize to list of file names
                file_names = []
                for task_ref in task_refs:
                    if isinstance(task_ref, dict) and "file" in task_ref:
                        file_names.append(task_ref["file"])
                    elif isinstance(task_ref, str):
                        file_names.append(task_ref)
                for tf in task_files:
                    if isinstance(tf, str):
                        file_names.append(tf)
                
                for task_file_name in file_names:
                    # Try multiple locations for the task file
                    task_file_paths = [
                        pipeline_base_dir / task_file_name,  # Same directory as source pipeline file
                        Path(task_file_name),  # Absolute path
                        logs_dir / task_file_name,  # logs/ directory
                    ]
                    for task_file in task_file_paths:
                        if task_file.exists():
                            try:
                                tf_data = json.loads(task_file.read_text())
                                for t in tf_data.get("tasks", []):
                                    stage_tasks.append({**t, "source": str(task_file)})
                            except Exception:
                                pass
                            break
            
            enriched["tasks"] = stage_tasks
            enriched["cost_usd"] = stage_cost
            if stage_cost is not None:
                total_cost = (total_cost or 0.0) + stage_cost
            stages.append(enriched)
        ts = data.get("started_at", 0)
        try:
            iso = datetime.fromtimestamp(int(ts), tz=timezone.utc).isoformat()
        except Exception:
            iso = None
        self._json({
            **data,
            "started_at_iso": iso,
            "total_cost_usd": total_cost,
            "stages": stages,
            "has_summary": _pipeline_summary_path(self.logs_dir, pipeline_id).exists(),
        })

    def _api_pipeline_summary_get(self, pipeline_id: str):
        """GET /api/pipeline/<id>/summary — read stored summary."""
        if not PIPELINE_ID_RE.match(pipeline_id):
            self._error(400, "Invalid pipeline ID")
            return
        summary_file = _pipeline_summary_path(self.logs_dir, pipeline_id)
        if not summary_file.exists():
            self._json({"pipeline_id": pipeline_id, "summary": None})
            return
        self._json({
            "pipeline_id": pipeline_id,
            "summary": summary_file.read_text(),
        })

    def _api_pipeline_summary_generate(self, pipeline_id: str):
        """POST /api/pipeline/<id>/summary — generate summary on demand."""
        if not PIPELINE_ID_RE.match(pipeline_id):
            self._error(400, "Invalid pipeline ID")
            return
        summary_file = _pipeline_summary_path(self.logs_dir, pipeline_id)
        if summary_file.exists():
            self._json({
                "pipeline_id": pipeline_id,
                "summary": summary_file.read_text(),
                "cached": True,
            })
            return
        summary, error = _generate_summary_sync(pipeline_id, self.logs_dir)
        if error == "no_output":
            self._json({
                "pipeline_id": pipeline_id,
                "summary": None,
                "skipped": True,
                "reason": "No task output available — summary not generated.",
            })
            return
        if error:
            self._error(500, error)
            return
        self._json({
            "pipeline_id": pipeline_id,
            "summary": summary,
            "cached": False,
        })

    def _api_pipeline_templates(self):
        templates_dir = ORCHESTRA_DIR / "templates" / "pipelines"
        templates = []
        # Metadata for known templates
        known = {
            "feature": {
                "description": "Plan → Implement → Review pipeline for new features",
                "stages": ["Plan", "Implement", "Review"],
            },
            "bugfix": {
                "description": "Diagnose → Fix → Verify pipeline for bug fixes",
                "stages": ["Diagnose", "Fix", "Verify"],
            },
            "audit": {
                "description": "Parallel security, quality, and architecture audit",
                "stages": ["Audit (Parallel)"],
            },
            "release": {
                "description": "Test → Security → Documentation pipeline for releases",
                "stages": ["Test", "Security", "Documentation"],
            },
            "refactor": {
                "description": "Architect → Implement → Test → Review refactoring pipeline",
                "stages": ["Architect", "Implement", "Test", "Review"],
            },
        }
        if templates_dir.is_dir():
            for f in sorted(templates_dir.glob("*.json")):
                name = f.stem
                pipeline_name = name
                stages = []
                try:
                    data = json.loads(f.read_text())
                    pipeline_name = data.get("name", name)
                    stages = [s.get("name", "") for s in data.get("stages", [])]
                except Exception:
                    pass
                meta = known.get(name, {})
                templates.append({
                    "name": name,
                    "description": meta.get("description", pipeline_name),
                    "stages": meta.get("stages", stages),
                    "file": f"pipelines/{f.name}",
                })
        self._json({"templates": templates})

    def _api_pipeline_template_create(self, template_name: str):
        """POST /api/pipelines/templates/{name}/create — copy template to dest_dir."""
        body = self._read_body_json()
        if body is None:
            return
        dest_dir_str = body.get("dest_dir", ".")
        
        # Validate destination directory
        dest_dir = _validate_workspace_path(dest_dir_str)
        if dest_dir is None or not dest_dir.is_dir():
            self._error(400, "Invalid or non-existent dest_dir")
            return
        
        # Find the template
        template_file = ORCHESTRA_DIR / "templates" / "pipelines" / f"{template_name}.json"
        if not template_file.is_file():
            self._error(404, f"Template '{template_name}' not found")
            return
        
        # Read template
        try:
            template_data = json.loads(template_file.read_text())
        except json.JSONDecodeError as e:
            self._error(500, f"Invalid template JSON: {e}")
            return
        
        # Write to destination
        dest_file = dest_dir / f"pipeline-{template_name}.json"
        try:
            dest_file.write_text(json.dumps(template_data, indent=2))
        except Exception as e:
            self._error(500, f"Failed to write pipeline: {e}")
            return
        
        self._json({"path": str(dest_file), "name": template_name})

    def _api_pipeline_docs(self):
        how_to_write = (
            "## Pipeline Format\n\n"
            "Pipelines are JSON files in the `pipelines/` directory (or pass directly to `orchestra-pipeline`).\n\n"
            "### Top-level fields\n\n"
            "| Field | Type | Description |\n"
            "|-------|------|-------------|\n"
            "| `name` | string | Human-readable pipeline name |\n"
            "| `stages` | array | Ordered list of stage objects |\n"
            "| `aggregate` | boolean | Aggregate stage outputs into a final report |\n\n"
            "### Stage fields\n\n"
            "| Field | Type | Description |\n"
            "|-------|------|-------------|\n"
            "| `name` | string | Stage name |\n"
            "| `tasks` | array | Task file references (each with `file` and optional `max_parallel`) |\n"
            "| `pass_outputs_to_next` | boolean | Inject this stage's outputs as context into the next stage |\n\n"
            "### Running a pipeline\n\n"
            "```bash\n"
            "orchestra-pipeline pipeline.json\n"
            "```\n\n"
            "Use the built-in templates in `templates/pipelines/` as a starting point."
        )
        example = json.dumps({
            "name": "my-pipeline",
            "stages": [
                {
                    "name": "Plan",
                    "tasks": [{"file": "tasks-plan.json", "max_parallel": 1}],
                    "pass_outputs_to_next": True,
                },
                {
                    "name": "Implement",
                    "tasks": [{"file": "tasks-implement.json", "max_parallel": 5}],
                    "pass_outputs_to_next": False,
                },
            ],
            "aggregate": True,
        }, indent=2)
        self._json({"how_to_write": how_to_write, "example": example})

    # ── SSE endpoint ───────────────────────────────────────────────────

    def _api_events(self):
        if self.broker is None:
            self._error(503, "SSE not available")
            return
        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream")
        self.send_header("Cache-Control", "no-cache")
        self.send_header("Connection", "keep-alive")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()

        client_q = self.broker.subscribe()
        try:
            while True:
                try:
                    msg = client_q.get(timeout=15)
                    self.wfile.write(msg.encode())
                    self.wfile.flush()
                except queue.Empty:
                    self.wfile.write(b": heartbeat\n\n")
                    self.wfile.flush()
        except (BrokenPipeError, ConnectionResetError, OSError):
            pass
        finally:
            self.broker.unsubscribe(client_q)

    # ── Config API helpers ──────────────────────────────────────────────

    def _read_body_json(self):
        """Read and parse JSON request body. Returns dict or None on error."""
        length = int(self.headers.get("Content-Length", 0))
        if length == 0:
            self._error(400, "Empty request body")
            return None
        raw = self.rfile.read(length)
        try:
            return json.loads(raw)
        except (json.JSONDecodeError, ValueError):
            self._error(400, "Invalid JSON")
            return None

    def _collect_agents(self, base_dir: Path, scope: str) -> list:
        """List agent .md files under base_dir/agents/."""
        agents_dir = base_dir / "agents"
        if not agents_dir.is_dir():
            return []
        results = []
        for f in sorted(agents_dir.iterdir()):
            if f.is_file() and f.suffix == ".md":
                results.append({
                    "name": f.stem,
                    "scope": scope,
                    "path": str(f),
                })
        return results

    def _collect_skills(self, base_dir: Path, scope: str) -> list:
        """List skills under base_dir/skills/ (each has SKILL.md)."""
        skills_dir = base_dir / "skills"
        if not skills_dir.is_dir():
            return []
        results = []
        for d in sorted(skills_dir.iterdir()):
            skill_file = d / "SKILL.md"
            if d.is_dir() and skill_file.exists():
                results.append({
                    "name": d.name,
                    "scope": scope,
                    "path": str(skill_file),
                })
        return results

    # ── Config API routes ──────────────────────────────────────────────

    def _api_config_paths(self):
        self._json({
            "global_path": str(GLOBAL_CLAUDE_DIR),
            "project_path": str(PROJECT_CLAUDE_DIR),
        })

    def _api_config_agents_list(self):
        agents = (
            self._collect_agents(GLOBAL_CLAUDE_DIR, "global")
            + self._collect_agents(PROJECT_CLAUDE_DIR, "project")
        )
        self._json({"agents": agents})

    def _api_config_agent_get(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid agent name")
            return
        for base, scope in [(PROJECT_CLAUDE_DIR, "project"), (GLOBAL_CLAUDE_DIR, "global")]:
            agent_file = base / "agents" / f"{name}.md"
            if agent_file.is_file():
                self._json({
                    "name": name,
                    "scope": scope,
                    "content": agent_file.read_text(errors="replace"),
                })
                return
        self._not_found()

    def _api_config_agent_put(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid agent name")
            return
        body = self._read_body_json()
        if body is None:
            return
        scope = body.get("scope", "project")
        content = body.get("content")
        if content is None:
            self._error(400, "Missing 'content' field")
            return
        if scope not in ("global", "project"):
            self._error(400, "scope must be 'global' or 'project'")
            return
        base = GLOBAL_CLAUDE_DIR if scope == "global" else PROJECT_CLAUDE_DIR
        agents_dir = base / "agents"
        agents_dir.mkdir(parents=True, exist_ok=True)
        agent_file = agents_dir / f"{name}.md"
        created = not agent_file.exists()
        agent_file.write_text(content)
        self._json_status(201 if created else 200, {
            "name": name,
            "scope": scope,
            "path": str(agent_file),
        })

    def _api_config_agent_delete(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid agent name")
            return
        for base in [PROJECT_CLAUDE_DIR, GLOBAL_CLAUDE_DIR]:
            agent_file = base / "agents" / f"{name}.md"
            if agent_file.is_file():
                agent_file.unlink()
                self._json({"deleted": name})
                return
        self._not_found()

    def _api_config_skills_list(self):
        skills = (
            self._collect_skills(GLOBAL_CLAUDE_DIR, "global")
            + self._collect_skills(PROJECT_CLAUDE_DIR, "project")
        )
        self._json({"skills": skills})

    def _api_config_skill_get(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid skill name")
            return
        for base, scope in [(PROJECT_CLAUDE_DIR, "project"), (GLOBAL_CLAUDE_DIR, "global")]:
            skill_file = base / "skills" / name / "SKILL.md"
            if skill_file.is_file():
                self._json({
                    "name": name,
                    "scope": scope,
                    "content": skill_file.read_text(errors="replace"),
                })
                return
        self._not_found()

    def _api_config_skill_put(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid skill name")
            return
        body = self._read_body_json()
        if body is None:
            return
        scope = body.get("scope", "project")
        content = body.get("content")
        if content is None:
            self._error(400, "Missing 'content' field")
            return
        if scope not in ("global", "project"):
            self._error(400, "scope must be 'global' or 'project'")
            return
        base = GLOBAL_CLAUDE_DIR if scope == "global" else PROJECT_CLAUDE_DIR
        skill_dir = base / "skills" / name
        skill_dir.mkdir(parents=True, exist_ok=True)
        skill_file = skill_dir / "SKILL.md"
