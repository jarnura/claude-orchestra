        skill_file.write_text(content)
        self._json_status(201 if created else 200, {
            "name": name,
            "scope": scope,
            "path": str(skill_file),
        })

    def _api_config_skill_delete(self, name: str):
        if not CONFIG_NAME_RE.match(name):
            self._error(400, "Invalid skill name")
            return
        for base in [PROJECT_CLAUDE_DIR, GLOBAL_CLAUDE_DIR]:
            skill_file = base / "skills" / name / "SKILL.md"
            if skill_file.is_file():
                skill_file.unlink()
                # Remove the directory if now empty
                skill_dir = skill_file.parent
                try:
                    skill_dir.rmdir()
                except OSError:
                    pass
                self._json({"deleted": name})
                return
        self._not_found()

    def _api_config_hooks_list(self):
        self._json({"hooks": list(HOOK_PROFILES.values())})

    # ── Workspace API routes ──────────────────────────────────────────

    def _api_workspace_repos(self):
        """GET /api/workspace/repos — list available repos."""
        repos = _find_repos()
        self._json({"repos": repos})

    def _api_workspace_repo_tasks(self, raw_path: str):
        """GET /api/workspace/repos/{path}/tasks — list task files in a repo."""
        # Prepend / if the path doesn't start with one (URL encoding strips it)
        if not raw_path.startswith("/"):
            raw_path = "/" + raw_path
        repo_path = _validate_workspace_path(raw_path)
        if repo_path is None:
            self._error(400, "Invalid repo path")
            return
        if not repo_path.is_dir():
            self._not_found()
            return
        task_files = _find_task_files(repo_path)
        pipeline_files = _find_pipeline_files(repo_path)

        # Check if tasks.md exists and read its content
        tasks_md_path = repo_path / "tasks.md"
        tasks_md = None
        if tasks_md_path.is_file():
            try:
                content = tasks_md_path.read_text()
                tasks_md = {
                    "exists": True,
                    "path": str(tasks_md_path),
                    "content": content
                }
            except Exception:
                # If read fails, still include exists=True but without content
                tasks_md = {
                    "exists": True,
                    "path": str(tasks_md_path),
                    "content": None
                }
        else:
            tasks_md = {"exists": False}

        self._json({
            "repo": str(repo_path),
            "task_files": task_files,
            "tasks_md": tasks_md,
            "pipelines": pipeline_files
        })

    def _api_workspace_tasks_file(self):
        """GET /api/workspace/tasks-file?path=... — read tasks from a file."""
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        path_list = qs.get("path", [])
        if not path_list:
            self._error(400, "Missing 'path' query parameter")
            return
        file_path = _validate_workspace_path(path_list[0])
        if file_path is None:
            self._error(400, "Invalid file path")
            return
        data, err = _load_tasks_file(file_path)
        if err:
            self._error(400, err)
            return
        self._json({"tasks": data.get("tasks", []), "file": str(file_path)})

    def _api_workspace_tasks_md_get(self):
        """GET /api/workspace/tasks-md?path=... — read raw tasks.md content."""
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        path_list = qs.get("path", [])
        if not path_list:
            self._error(400, "Missing 'path' query parameter")
            return
        file_path = _validate_workspace_path(path_list[0])
        if file_path is None:
            self._error(400, "Invalid file path")
            return
        exists = file_path.exists()
        content = file_path.read_text(encoding="utf-8") if exists else ""
        self._json({"path": str(file_path), "content": content, "exists": exists})

    def _api_workspace_tasks_md_put(self):
        """PUT /api/workspace/tasks-md — save raw tasks.md content."""
        body = self._read_body_json()
        if body is None:
            return
        path_str = body.get("path")
        content = body.get("content")
        if not path_str:
            self._error(400, "Missing 'path' field")
            return
        if content is None:
            self._error(400, "Missing 'content' field")
            return
        file_path = _validate_workspace_path(path_str)
        if file_path is None:
            self._error(400, "Invalid file path")
            return
        file_path.parent.mkdir(parents=True, exist_ok=True)
        bytes_written = file_path.write_text(content, encoding="utf-8")
        self._json({"path": str(file_path), "bytes_written": bytes_written})

    def _api_workspace_task_create(self):
        """POST /api/workspace/tasks — create a task in a task file."""
        body = self._read_body_json()
        if body is None:
            return
        file_path_str = body.get("file")
        task_data = body.get("task")
        if not file_path_str:
            self._error(400, "Missing 'file' field (path to tasks.json)")
            return
        if not task_data or not isinstance(task_data, dict):
            self._error(400, "Missing or invalid 'task' object")
            return
        task_id = task_data.get("id")
        if not task_id or not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Missing or invalid task 'id'")
            return
        if not task_data.get("name"):
            self._error(400, "Missing task 'name'")
            return

        file_path = _validate_workspace_path(file_path_str)
        if file_path is None:
            self._error(400, "Invalid file path")
            return

        # Load existing file or create new
        if file_path.is_file():
            data, err = _load_tasks_file(file_path)
            if err:
                self._error(400, err)
                return
        else:
            data = {"tasks": []}

        # Check for duplicate ID
        for t in data["tasks"]:
            if t.get("id") == task_id:
                self._error(409, f"Task '{task_id}' already exists")
                return

        # Build task with defaults
        new_task = {
            "id": task_id,
            "name": task_data["name"],
            "prompt": task_data.get("prompt", ""),
            "workdir": task_data.get("workdir", ""),
            "model": task_data.get("model", "opus"),
            "status": "pending",
        }
        # Optional fields
        for field in ("agents", "skills", "hooks", "effort", "allowedTools", "appendSystemPrompt"):
            if field in task_data:
                new_task[field] = task_data[field]

        data["tasks"].append(new_task)
        _save_tasks_file(file_path, data)
        self._json_status(201, {"task": new_task, "file": str(file_path)})

    def _api_workspace_task_update(self, task_id: str):
        """PUT /api/workspace/tasks/{id} — update a task."""
        if not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task ID")
            return
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        file_list = qs.get("file", [])
        if not file_list:
            self._error(400, "Missing 'file' query parameter")
            return
        file_path = _validate_workspace_path(file_list[0])
        if file_path is None:
            self._error(400, "Invalid file path")
            return

        data, err = _load_tasks_file(file_path)
        if err:
            self._error(400, err)
            return

        body = self._read_body_json()
        if body is None:
            return

        # Find and update the task
        for i, t in enumerate(data["tasks"]):
            if t.get("id") == task_id:
                updated = dict(t)
                # Update allowed fields
                for field in ("name", "prompt", "workdir", "model", "status",
                              "agents", "skills", "hooks", "effort",
                              "allowedTools", "appendSystemPrompt"):
                    if field in body:
                        updated[field] = body[field]
                # Don't allow changing the ID
                updated["id"] = task_id
                data["tasks"][i] = updated
                _save_tasks_file(file_path, data)
                self._json({"task": updated, "file": str(file_path)})
                return

        self._not_found()

    def _api_workspace_task_delete(self, task_id: str):
        """DELETE /api/workspace/tasks/{id} — remove a task from a task file."""
        if not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task ID")
            return
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        file_list = qs.get("file", [])
        if not file_list:
            self._error(400, "Missing 'file' query parameter")
            return
        file_path = _validate_workspace_path(file_list[0])
        if file_path is None:
            self._error(400, "Invalid file path")
            return

        data, err = _load_tasks_file(file_path)
        if err:
            self._error(400, err)
            return

        original_len = len(data["tasks"])
        data["tasks"] = [t for t in data["tasks"] if t.get("id") != task_id]
        if len(data["tasks"]) == original_len:
            self._not_found()
            return

        _save_tasks_file(file_path, data)
        self._json({"deleted": task_id, "file": str(file_path)})

    def _api_workspace_task_run(self, task_id: str):
        """POST /api/workspace/tasks/{id}/run — execute a task via orchestra."""
        if not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task ID")
            return
        body = self._read_body_json()
        if body is None:
            return
        file_path_str = body.get("file")
        if not file_path_str:
            self._error(400, "Missing 'file' field")
            return
        file_path = _validate_workspace_path(file_path_str)
        if file_path is None:
            self._error(400, "Invalid file path")
            return

        data, err = _load_tasks_file(file_path)
        if err:
            self._error(400, err)
            return

        # Find the task
        task = None
        for t in data["tasks"]:
            if t.get("id") == task_id:
                task = t
                break
        if task is None:
            self._not_found()
            return

        # Create a temp tasks file with just this task
        run_id = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + "-" + uuid.uuid4().hex[:6]
        tmp_dir = tempfile.mkdtemp(prefix="orchestra-run-")
        tmp_tasks = Path(tmp_dir) / "tasks.json"
        single_data = {"tasks": [{**task, "status": "pending"}]}
        tmp_tasks.write_text(json.dumps(single_data, indent=2) + "\n")

        # Determine workdir for the subprocess
        workdir = task.get("workdir", "")
        cwd = workdir if workdir and Path(workdir).is_dir() else str(ORCHESTRA_DIR)

        # Spawn orchestra in the background
        log_dir = self.logs_dir / run_id
        log_dir.mkdir(parents=True, exist_ok=True)
        cmd = [str(ORCHESTRA_BIN), "--name", run_id, str(tmp_tasks)]
        env = {**os.environ, "LOG_DIR": str(log_dir)}
        try:
            proc = subprocess.Popen(
                cmd,
                cwd=cwd,
                env=env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except OSError as e:
            self._error(500, f"Failed to spawn orchestra: {e}")
            return

        # Write meta.json for active-runs tracking
        repo_path = body.get("repo_path", "")
        meta = {"repo_path": repo_path, "pid": proc.pid, "source": "workspace",
                "task_name": task.get("name", task_id), "started_at": int(time.time())}
        (log_dir / "meta.json").write_text(json.dumps(meta))

        self._json_status(202, {"run_id": run_id, "task_id": task_id})

    def _api_workspace_brainstorm(self):
        """POST /api/workspace/brainstorm — generate tasks.md via Claude."""
        body = self._read_body_json()
        if body is None:
            return
        repo_path_str = body.get("repo_path")
        prompt = body.get("prompt")
        model = body.get("model", "sonnet")

        if not repo_path_str:
            self._error(400, "Missing 'repo_path' field")
            return
        if not prompt or not isinstance(prompt, str):
            self._error(400, "Missing or invalid 'prompt' field")
            return
        if not isinstance(model, str) or model not in ("opus", "sonnet", "haiku"):
            self._error(400, "Invalid 'model'; must be opus, sonnet, or haiku")
            return

        repo_path = _validate_workspace_path(repo_path_str)
        if repo_path is None or not repo_path.is_dir():
            self._error(400, "Invalid or non-existent repo_path")
            return

        system_prompt = BRAINSTORM_SYSTEM_PROMPT.replace("{repo_path}", str(repo_path))

        # Gather repo context for better task generation
        repo_name = repo_path.name
        repo_context = _get_repo_context(repo_path)

        # Structure the user prompt with explicit repo context to prevent model from using wrong project
        full_prompt = f"""Target Repository: {repo_name}
Repository Path: {repo_path}
{repo_context}

USER REQUEST:
{prompt}

CRITICAL: All tasks MUST have `workdir: {repo_path}` - the model must NOT use any other path. The target is "{repo_name}", not the current working directory."""
        
        try:
            result = subprocess.run(
                [CLAUDE_CMD, "--print", "--model", model, "--append-system-prompt", system_prompt],
                input=full_prompt,
                capture_output=True,
                text=True,
                timeout=300,  # 5 minutes for brainstorm
            )
        except FileNotFoundError:
            self._error(500, f"{CLAUDE_CMD} CLI not found. Install claude CLI or set CLAUDE_CMD env var")
            return
        except subprocess.TimeoutExpired:
            self._error(504, "Claude CLI timed out")
            return

        if result.returncode != 0:
            self._error(500, f"Claude CLI error: {result.stderr.strip()[:200]}")
            return

        tasks_md = result.stdout.strip()
        if not tasks_md:
            self._error(500, "Claude returned empty output")
            return

        # Count tasks by counting ## headings
        task_count = sum(1 for line in tasks_md.splitlines() if line.startswith("## "))

        # Generate a descriptive filename from the prompt + timestamp
        slug = re.sub(r"[^a-z0-9]+", "-", prompt.lower().strip())[:40].strip("-")
        timestamp = int(time.time())
        tasks_filename = f"tasks-{slug}-{timestamp}.md"
        tasks_file = repo_path / tasks_filename

        tmp_fd, tmp_path = tempfile.mkstemp(dir=str(repo_path), suffix=".md.tmp")
        try:
            with os.fdopen(tmp_fd, "w") as f:
                f.write(tasks_md)
                f.write("\n")
            os.replace(tmp_path, str(tasks_file))
        except Exception as e:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass
            self._error(500, f"Failed to write {tasks_filename}: {e}")
            return

        self._json({
            "tasks_md": tasks_md,
            "tasks_file": str(tasks_file),
            "tasks_filename": tasks_filename,
            "task_count": task_count,
        })

    def _api_workspace_brainstorm_pipeline_run(self):
        """POST /api/workspace/brainstorm/pipeline/run — generate a pipeline via Claude and immediately run it."""
        body = self._read_body_json()
        if body is None:
            return
        repo_path_str = body.get("repo_path")
        prompt = body.get("prompt")
        model = body.get("model", "sonnet")
        max_parallel = body.get("max_parallel", 3)

        if not repo_path_str:
            self._error(400, "Missing 'repo_path' field")
            return
        if not prompt or not isinstance(prompt, str):
            self._error(400, "Missing or invalid 'prompt' field")
            return
        if not isinstance(model, str) or model not in ("opus", "sonnet", "haiku"):
            self._error(400, "Invalid 'model'; must be opus, sonnet, or haiku")
            return
        if not isinstance(max_parallel, int) or max_parallel < 1 or max_parallel > 50:
            self._error(400, "max_parallel must be an integer between 1 and 50")
            return

        repo_path = _validate_workspace_path(repo_path_str)
        if repo_path is None or not repo_path.is_dir():
            self._error(400, "Invalid or non-existent repo_path")
            return

        system_prompt = BRAINSTORM_PIPELINE_SYSTEM_PROMPT.replace("{repo_path}", str(repo_path))

        repo_name = repo_path.name
        repo_context = _get_repo_context(repo_path)
        full_prompt = f"""Target Repository: {repo_name}
Repository Path: {repo_path}
{repo_context}

USER REQUEST:
{prompt}

CRITICAL: All task workdir fields MUST be "{repo_path}". Generate a realistic multi-stage pipeline for this request."""

        try:
            result = subprocess.run(
                [CLAUDE_CMD, "--print", "--model", model, "--append-system-prompt", system_prompt],
                input=full_prompt,
                capture_output=True,
                text=True,
                timeout=300,
            )
        except FileNotFoundError:
            self._error(500, f"{CLAUDE_CMD} CLI not found. Install claude CLI or set CLAUDE_CMD env var")
            return
        except subprocess.TimeoutExpired:
            self._error(504, "Claude CLI timed out")
            return

        if result.returncode != 0:
            self._error(500, f"Claude CLI error: {result.stderr.strip()[:200]}")
            return

        raw = result.stdout.strip()
        if not raw:
            self._error(500, "Claude returned empty output")
            return

        # Strip markdown code fences if present
        raw = re.sub(r"^```[a-z]*\n?", "", raw)
        raw = re.sub(r"\n?```$", "", raw.rstrip())

        try:
            pipeline_spec = json.loads(raw)
        except json.JSONDecodeError as e:
            self._error(500, f"Claude returned invalid JSON: {e} — output: {raw[:300]}")
            return

        if "stages" not in pipeline_spec or not isinstance(pipeline_spec["stages"], list):
            self._error(500, "Generated pipeline missing 'stages' array")
            return

        # Write per-stage task JSON files and build pipeline.json referencing them
        timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
        pipeline_name = pipeline_spec.get("name", "Brainstorm Pipeline")
        pipeline_slug = re.sub(r"[^a-z0-9]+", "-", pipeline_name.lower()).strip("-")
        pipeline_dir = repo_path / f"pipeline-{pipeline_slug}-{timestamp}"
        try:
            pipeline_dir.mkdir(parents=True, exist_ok=True)
        except OSError as e:
            self._error(500, f"Failed to create pipeline directory: {e}")
            return

        pipeline_stages = []
        total_tasks = 0
        for i, stage_spec in enumerate(pipeline_spec["stages"]):
            stage_name = stage_spec.get("name", f"Stage {i + 1}")
            stage_slug = re.sub(r"[^a-z0-9]+", "-", stage_name.lower()).strip("-") or f"stage-{i + 1}"
            inline_tasks = stage_spec.get("tasks", [])

            normalised = []
            # Task fields to preserve from brainstorm output
            _TASK_OPTIONAL_FIELDS = [
                "effort", "agents", "skills", "hooks", "allowedTools",
                "appendSystemPrompt", "max_retries", "retry_delay_seconds",
                "retry_backoff", "verify_strategy", "verify_command",
                "verify_timeout", "verify_prompt",
            ]
            for t in inline_tasks:
                task_id = re.sub(r"[^a-z0-9-]", "-", str(t.get("id", stage_slug)).lower()).strip("-") or f"task-{i}"
                task_obj = {
                    "id": task_id,
                    "name": t.get("name", task_id),
                    "prompt": t.get("prompt", ""),
                    "model": t.get("model", "sonnet"),
                    "workdir": str(repo_path),
                    "status": "pending",
                }
                for field in _TASK_OPTIONAL_FIELDS:
                    if field in t and t[field] is not None:
                        task_obj[field] = t[field]
                normalised.append(task_obj)
            total_tasks += len(normalised)

            tasks_file = pipeline_dir / f"tasks-{stage_slug}.json"
            tasks_file.write_text(json.dumps({"tasks": normalised}, indent=2))

            stage_entry = {
                "name": stage_name,
                "tasks": [{"file": str(tasks_file), "max_parallel": max_parallel}],
                "pass_outputs_to_next": stage_spec.get(
                    "pass_outputs_to_next", i < len(pipeline_spec["stages"]) - 1
                ),
            }
            if stage_spec.get("max_stage_retries"):
                stage_entry["max_stage_retries"] = int(stage_spec["max_stage_retries"])
            pipeline_stages.append(stage_entry)

        pipeline_json = {
            "name": pipeline_name,
            "halt_on_stage_failure": pipeline_spec.get("halt_on_stage_failure", True),
            "stages": pipeline_stages,
            "aggregate": True,
        }
        pipeline_path = pipeline_dir / "pipeline.json"
        pipeline_path.write_text(json.dumps(pipeline_json, indent=2))

        # Spawn orchestra-pipeline in the background
        pipeline_bin = SCRIPT_DIR / "orchestra-pipeline"
        if not pipeline_bin.exists():
            self._error(500, "orchestra-pipeline binary not found")
            return

        run_id = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + "-" + uuid.uuid4().hex[:6]
        log_dir = self.logs_dir / run_id
        log_dir.mkdir(parents=True, exist_ok=True)

        # Pass LOGS_BASE so orchestra-pipeline writes state file to our logs directory
        env = {**os.environ, "LOGS_BASE": str(self.logs_dir), "MAX_PARALLEL": str(max_parallel)}
        try:
            proc = subprocess.Popen(
                [str(pipeline_bin), str(pipeline_path)],
                cwd=str(repo_path),
                env=env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except OSError as e:
            self._error(500, f"Failed to spawn pipeline: {e}")
            return

        stage_count = len(pipeline_stages)
        meta = {
            "repo_path": str(repo_path),
            "pid": proc.pid,
            "source": "brainstorm-pipeline",
            "task_name": f"Pipeline: {pipeline_name} ({stage_count} stages, {total_tasks} tasks)",
            "started_at": int(time.time()),
            "pipeline_path": str(pipeline_path),
        }
        (log_dir / "meta.json").write_text(json.dumps(meta))

        started_at_iso = datetime.now(timezone.utc).isoformat()
        metadata = {
            "repo_path": str(repo_path),
            "pipeline_file": str(pipeline_path),
            "pipeline_name": pipeline_name,
            "started_at": started_at_iso,
            "triggered_from": "brainstorm-pipeline",
            "prompt": prompt[:500],
        }
        (log_dir / "metadata.json").write_text(json.dumps(metadata, indent=2))

        self._json_status(202, {
            "run_id": run_id,
            "log_dir": str(log_dir),
            "pipeline": pipeline_name,
            "pipeline_path": str(pipeline_path),
            "stage_count": stage_count,
            "task_count": total_tasks,
        })

    def _api_workspace_brainstorm_to_mapping(self):
        """POST /api/workspace/brainstorm/to-mapping

        Combines brainstorm task generation with mapping session creation.
        Accepts: { "use_case": "...", "pipeline_template": "feature", "repo_path": "/...", "custom_stages": ["Stage1", "Stage2"] }
        Returns: { "mapping_id": "...", "tasks": [...], "stages": [...], "tasks_file": "...", "auto_assignments": {...} }
        """
        body = self._read_body_json()
        if body is None:
            return
        use_case = body.get("use_case")
        pipeline_template = body.get("pipeline_template", "feature")
        custom_stages = body.get("custom_stages")  # Optional: user-provided stages for custom pipeline
        repo_path_str = body.get("repo_path")
        model = body.get("model", "sonnet")

        if not use_case or not isinstance(use_case, str):
            self._error(400, "Missing or invalid 'use_case' field")
            return
        if not repo_path_str:
            self._error(400, "Missing 'repo_path' field")
            return
        if pipeline_template not in VALID_PIPELINE_TEMPLATES:
            self._error(
                400,
                f"Invalid pipeline_template; must be one of: {', '.join(sorted(VALID_PIPELINE_TEMPLATES))}",
            )
            return

        if not isinstance(model, str) or model not in ("opus", "sonnet", "haiku"):
            model = "sonnet"

        repo_path = _validate_workspace_path(repo_path_str)
        if repo_path is None or not repo_path.is_dir():
            self._error(400, "Invalid or non-existent repo_path")
            return

        # Step 1: Generate tasks via brainstorm (reuses same logic as _api_workspace_brainstorm)
        system_prompt = BRAINSTORM_SYSTEM_PROMPT.replace("{repo_path}", str(repo_path))
        repo_name = repo_path.name
        repo_context = _get_repo_context(repo_path)
        full_prompt = (
            f"Target Repository: {repo_name}\n"
            f"Repository Path: {repo_path}\n"
            f"{repo_context}\n\n"
            f"USER REQUEST:\n{use_case}\n\n"
            f"CRITICAL: All tasks MUST have `workdir: {repo_path}` - "
            f'the model must NOT use any other path. The target is "{repo_name}", '
            "not the current working directory."
        )

        try:
            result = subprocess.run(
                [CLAUDE_CMD, "--print", "--model", model, "--append-system-prompt", system_prompt],
                input=full_prompt,
                capture_output=True,
                text=True,
                timeout=300,
            )
        except FileNotFoundError:
            self._error(500, f"{CLAUDE_CMD} CLI not found. Install claude CLI or set CLAUDE_CMD env var")
            return
        except subprocess.TimeoutExpired:
            self._error(504, "Claude CLI timed out")
            return

        if result.returncode != 0:
            self._error(500, f"Claude CLI error: {result.stderr.strip()[:200]}")
            return

        tasks_md = result.stdout.strip()
        if not tasks_md:
            self._error(500, "Claude returned empty output")
            return

        # Step 2: Convert markdown to JSON and save to data/brainstorm-<timestamp>.json
        tasks_data = _convert_tasks_md_to_json(tasks_md)
        timestamp = int(time.time())
        data_dir = ORCHESTRA_DIR / "data"
        data_dir.mkdir(parents=True, exist_ok=True)
        tasks_file = data_dir / f"brainstorm-{timestamp}.json"
        try:
            _save_tasks_file(tasks_file, tasks_data)
        except Exception as e:
            self._error(500, f"Failed to save tasks file: {e}")
            return

        # Step 3: Load template stage names (or use custom / generate for custom)
        if pipeline_template == "custom":
            # Use provided custom stages, or generate, or fallback
            if custom_stages and isinstance(custom_stages, list) and all(isinstance(s, str) for s in custom_stages):
                stages = custom_stages
            else:
                # Generate custom stages based on use case
                stages = self._generate_custom_stages(use_case, model)
                if not stages:
                    # Fallback to feature template stages if generation fails
                    tpl_file = ORCHESTRA_DIR / "templates" / "pipelines" / "feature.json"
                    try:
                        template_data = json.loads(tpl_file.read_text())
                        stages = [s["name"] for s in template_data.get("stages", [])]
                    except Exception:
                        stages = ["Plan", "Implement", "Review"]
        else:
            tpl_file = ORCHESTRA_DIR / "templates" / "pipelines" / f"{pipeline_template}.json"
            try:
                template_data = json.loads(tpl_file.read_text())
            except Exception as e:
                self._error(500, f"Failed to load pipeline template: {e}")
                return
            stages = [s["name"] for s in template_data.get("stages", [])]

        # Step 4: Auto-assign tasks to stages based on content analysis
        auto_assignments = _auto_assign_tasks_to_stages(tasks_data["tasks"], stages)

        # Step 5: Create mapping session
        # Build stage objects for storage
        stage_objects = [{"index": i, "name": name} for i, name in enumerate(stages)]
        mapping_id = str(uuid.uuid4())
        mapping = {
            "mapping_id": mapping_id,
            "tasks_file": str(tasks_file),
            "pipeline_template": pipeline_template,
            "custom_stages": stages if pipeline_template == "custom" else [],
            "stages": stage_objects,
            "assignments": auto_assignments,
            "created_at": timestamp,
        }
        mappings_dir = ORCHESTRA_DIR / "data" / "mappings"
        mappings_dir.mkdir(parents=True, exist_ok=True)
        mapping_file = mappings_dir / f"{mapping_id}.json"
        try:
            mapping_file.write_text(json.dumps(mapping, indent=2) + "\n")
        except Exception as e:
            self._error(500, f"Failed to save mapping session: {e}")
            return

        self._json({
            "mapping_id": mapping_id,
            "tasks": tasks_data["tasks"],
            "stages": stage_objects,
            "tasks_file": str(tasks_file),
            "auto_assignments": auto_assignments,
        })

    def _generate_custom_stages(self, use_case: str, model: str = "haiku") -> list[str]:
        """Generate custom pipeline stages based on use case.
        
        Returns a list of stage names, or empty list on failure.
        """
        full_prompt = f"USER REQUEST:\n{use_case}\n\nSuggest appropriate pipeline stage names for this use case."
        
        try:
            result = subprocess.run(
                [CLAUDE_CMD, "--print", "--model", model, "--append-system-prompt", CUSTOM_STAGES_PROMPT],
                input=full_prompt,
                capture_output=True,
                text=True,
                timeout=30,  # Quick response for stage names
            )
        except (FileNotFoundError, subprocess.TimeoutExpired):
            return []
        
        if result.returncode != 0:
            return []
        
        output = result.stdout.strip()
        if not output:
            return []
        
        # Parse JSON array of stage names
        try:
            # Remove any markdown code fences if present
            if output.startswith("```"):
                lines = output.split("\n")
                output = "\n".join(lines[1:-1] if lines[-1].startswith("```") else lines[1:])
            stages = json.loads(output.strip())
            if isinstance(stages, list) and all(isinstance(s, str) for s in stages):
                return stages
        except (json.JSONDecodeError, ValueError):
            pass
        
        return []

    def _brainstorm_stage_tasks(
        self, repo_path: Path, stage_name: str, prompt: str, model: str
    ) -> tuple[str | None, str | None]:
        """Call Claude to generate tasks markdown for one pipeline stage.

        Returns (tasks_md, error_message).
        """
        system_prompt = BRAINSTORM_SYSTEM_PROMPT.replace("{repo_path}", str(repo_path))
        repo_name = repo_path.name
        repo_context = _get_repo_context(repo_path)
        full_prompt = (
            f"Target Repository: {repo_name}\n"
            f"Repository Path: {repo_path}\n"
            f"{repo_context}\n\n"
            f"Pipeline Stage: {stage_name}\n\n"
            f"USER REQUEST:\n{prompt}\n\n"
            f"CRITICAL: All tasks MUST have `workdir: {repo_path}`. "
            f'Generate tasks appropriate for the "{stage_name}" stage of the pipeline. '
            "Start immediately with ##."
        )
        try:
            result = subprocess.run(
                [CLAUDE_CMD, "--print", "--model", model, "--append-system-prompt", system_prompt],
                input=full_prompt,
                capture_output=True,
                text=True,
                timeout=300,
            )
        except FileNotFoundError:
            return None, "claude CLI not found"
        except subprocess.TimeoutExpired:
            return None, "Claude CLI timed out"
        if result.returncode != 0:
            return None, f"Claude CLI error: {result.stderr.strip()[:200]}"
        tasks_md = result.stdout.strip()
        if not tasks_md:
            return None, "Claude returned empty output"
        return tasks_md, None

    def _api_workspace_brainstorm_pipeline(self):
        """POST /api/workspace/brainstorm/pipeline — generate pipeline + per-stage task files."""
        body = self._read_body_json()
        if body is None:
            return
        repo_path_str = body.get("repo_path")
        prompt = body.get("prompt")
        template_name = body.get("template_name")
        stages_input = body.get("stages")  # Can be string (comma-sep) or array
        model = body.get("model", "sonnet")

        if not repo_path_str:
            self._error(400, "Missing 'repo_path' field")
            return
        if not prompt or not isinstance(prompt, str):
            self._error(400, "Missing or invalid 'prompt' field")
            return
        if not isinstance(model, str) or model not in ("opus", "sonnet", "haiku"):
            model = "sonnet"

        repo_path = _validate_workspace_path(repo_path_str)
        if repo_path is None or not repo_path.is_dir():
            self._error(400, "Invalid or non-existent repo_path")
            return

        if template_name and template_name not in VALID_PIPELINE_TEMPLATES:
            self._error(
                400,
                f"Invalid template_name; must be one of: {', '.join(sorted(VALID_PIPELINE_TEMPLATES))}",
            )
            return

        # Resolve template data and initial stage list
        template_data: dict | None = None
        stage_names: list[str] = []

        if template_name:
            tpl_file = ORCHESTRA_DIR / "templates" / "pipelines" / f"{template_name}.json"
            try:
                template_data = json.loads(tpl_file.read_text())
            except Exception as e:
                self._error(500, f"Failed to load template '{template_name}': {e}")
                return
            stage_names = [s["name"] for s in template_data.get("stages", [])]

        # User-provided stages override template stage names
        # Accept both comma-separated string and JSON array
        if stages_input:
            if isinstance(stages_input, list):
                custom = [s.strip() for s in stages_input if isinstance(s, str) and s.strip()]
            elif isinstance(stages_input, str):
                custom = [s.strip() for s in stages_input.split(",") if s.strip()]
            else:
                custom = []
            if custom:
                stage_names = custom

        if not stage_names:
            self._error(400, "No stages defined; provide 'template_name' or 'stages'")
            return

        # Generate tasks for each stage via Claude IN PARALLEL
        tasks_files: list[str] = []
        stage_file_map: dict[str, str] = {}
        stage_errors: dict[str, str] = {}
        stage_results: dict[str, tuple] = {}  # stage_name -> (tasks_md, error)

        def generate_stage_tasks(stage_name: str):
            """Generate tasks for one stage. Returns (stage_name, tasks_md, error)."""
            tasks_md, err = self._brainstorm_stage_tasks(repo_path, stage_name, prompt, model)
            return (stage_name, tasks_md, err)

        # Use ThreadPoolExecutor to parallelize Claude calls
        from concurrent.futures import ThreadPoolExecutor, as_completed
        with ThreadPoolExecutor(max_workers=min(len(stage_names), 5)) as executor:
            futures = {executor.submit(generate_stage_tasks, s): s for s in stage_names}
            for future in as_completed(futures):
                stage_name, tasks_md, err = future.result()
                if err:
                    stage_errors[stage_name] = err
                else:
                    stage_results[stage_name] = (tasks_md, None)

        # Report any errors
        if stage_errors:
            first_error = list(stage_errors.values())[0]
            self._error(500, f"Stage generation failed: {first_error}")
            return

        # Save task files
        for stage_name in stage_names:
            tasks_md, _ = stage_results.get(stage_name, (None, None))
            if tasks_md:
                tasks_data = _convert_tasks_md_to_json(tasks_md)
                slug = _stage_slug(stage_name)
                filename = f"tasks-{slug}.json"
                tasks_file = repo_path / filename
                _save_tasks_file(tasks_file, tasks_data)
                tasks_files.append(str(tasks_file))
                stage_file_map[stage_name] = filename

        # Build pipeline JSON
        pipeline_name = template_name or "custom"
        if template_data:
            # Preserve template structure; replace per-stage task file references
            new_stages = []
            for stage in template_data["stages"]:
                new_stage = dict(stage)
                sname = stage["name"]
                if sname in stage_file_map:
                    orig_parallel = (
                        stage["tasks"][0].get("max_parallel", 5)
                        if stage.get("tasks")
                        else 5
                    )
                    new_stage["tasks"] = [{"file": stage_file_map[sname], "max_parallel": orig_parallel}]
                new_stages.append(new_stage)
            pipeline: dict = {**template_data, "stages": new_stages}
        else:
            stages_list = []
            for i, sname in enumerate(stage_names):
                stages_list.append({
                    "name": sname,
                    "tasks": [{"file": stage_file_map[sname], "max_parallel": 5}],
                    "pass_outputs_to_next": i < len(stage_names) - 1,
                })
            pipeline = {
                "name": f"{pipeline_name.title()} Pipeline",
                "stages": stages_list,
                "aggregate": True,
            }

        pipeline_file = repo_path / f"pipeline-{pipeline_name}.json"
        _save_tasks_file(pipeline_file, pipeline)

        self._json({
            "pipeline_path": str(pipeline_file),
            "tasks_files": tasks_files,
            "stages": [{"name": s, "file": stage_file_map[s]} for s in stage_names],
        })

    def _api_workspace_brainstorm_stage(self):
        """POST /api/workspace/brainstorm/stage — generate tasks for one named pipeline stage."""
        body = self._read_body_json()
        if body is None:
            return
        repo_path_str = body.get("repo_path")
        pipeline_path_str = body.get("pipeline_path")
        stage_name = body.get("stage_name")
        prompt = body.get("prompt")
        model = body.get("model", "sonnet")

        if not repo_path_str:
            self._error(400, "Missing 'repo_path' field")
            return
        if not pipeline_path_str:
            self._error(400, "Missing 'pipeline_path' field")
            return
        if not stage_name or not isinstance(stage_name, str):
            self._error(400, "Missing or invalid 'stage_name' field")
            return
        if not prompt or not isinstance(prompt, str):
            self._error(400, "Missing or invalid 'prompt' field")
            return
        if not isinstance(model, str) or model not in ("opus", "sonnet", "haiku"):
            model = "sonnet"

        repo_path = _validate_workspace_path(repo_path_str)
        if repo_path is None or not repo_path.is_dir():
            self._error(400, "Invalid or non-existent repo_path")
            return

        pipeline_path = _validate_workspace_path(pipeline_path_str)
        if pipeline_path is None or not pipeline_path.is_file():
            self._error(400, "Invalid or non-existent pipeline_path")
            return

        tasks_md, err = self._brainstorm_stage_tasks(repo_path, stage_name, prompt, model)
        if err:
            self._error(500, err)
            return

        tasks_data = _convert_tasks_md_to_json(tasks_md)
        tasks_file = pipeline_path.parent / f"tasks-{_stage_slug(stage_name)}.json"
        _save_tasks_file(tasks_file, tasks_data)

        self._json({
            "tasks_file": str(tasks_file),
            "task_count": len(tasks_data.get("tasks", [])),
        })

    def _api_workspace_tasks_md_convert(self):
        """POST /api/workspace/tasks-md/convert — convert tasks.md to tasks.json."""
        body = self._read_body_json()
        if body is None:
            return
        tasks_md_path_str = body.get("tasks_md_path")
        if not tasks_md_path_str:
            self._error(400, "Missing 'tasks_md_path' field")
            return
        tasks_md_path = _validate_workspace_path(tasks_md_path_str)
        if tasks_md_path is None:
            self._error(400, "Invalid tasks_md_path")
            return
        if not tasks_md_path.is_file():
            self._error(400, "tasks_md_path does not exist")
            return

        # Determine output path
        tasks_json_path_str = body.get("tasks_json_path")
        if tasks_json_path_str:
            tasks_json_path = _validate_workspace_path(tasks_json_path_str)
            if tasks_json_path is None:
                self._error(400, "Invalid tasks_json_path")
                return
        else:
            tasks_json_path = tasks_md_path.with_suffix(".json")

        convert_bin = SCRIPT_DIR / "orchestra-convert"
        try:
            result = subprocess.run(
                [str(convert_bin), str(tasks_md_path), str(tasks_json_path)],
                capture_output=True,
                text=True,
                timeout=30,
            )
        except FileNotFoundError:
            self._error(500, "orchestra-convert not found")
            return
        except subprocess.TimeoutExpired:
            self._error(504, "orchestra-convert timed out")
            return

        if result.returncode != 0:
            self._error(500, f"orchestra-convert failed: {result.stderr.strip()[:200]}")
            return

        # Read the resulting JSON to return task list
        try:
            data = json.loads(tasks_json_path.read_text())
        except Exception as e:
            self._error(500, f"Failed to read converted JSON: {e}")
            return

        tasks = data.get("tasks", [])
        self._json({
            "tasks_json_path": str(tasks_json_path),
            "task_count": len(tasks),
            "tasks": tasks,
        })

    def _api_workspace_orchestra_run(self):
        """POST /api/workspace/orchestra/run — run orchestra on a tasks.json file."""
        body = self._read_body_json()
        if body is None:
            return
        tasks_json_path_str = body.get("tasks_json_path")
        if not tasks_json_path_str:
            self._error(400, "Missing 'tasks_json_path' field")
            return
        tasks_json_path = _validate_workspace_path(tasks_json_path_str)
        if tasks_json_path is None:
            self._error(400, "Invalid tasks_json_path")
            return
        if not tasks_json_path.is_file():
            self._error(400, "tasks_json_path does not exist")
            return

        data, err = _load_tasks_file(tasks_json_path)
        if err:
            self._error(400, err)
            return

        max_parallel = body.get("max_parallel", 5)
        if not isinstance(max_parallel, int) or max_parallel < 1 or max_parallel > 50:
            self._error(400, "max_parallel must be an integer between 1 and 50")
            return

        run_id = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + "-" + uuid.uuid4().hex[:6]
        log_dir = self.logs_dir / run_id
        log_dir.mkdir(parents=True, exist_ok=True)
        env = {**os.environ, "LOG_DIR": str(log_dir), "MAX_PARALLEL": str(max_parallel)}
        try:
            proc = subprocess.Popen(
                [str(ORCHESTRA_BIN), "--name", run_id, str(tasks_json_path)],
                cwd=str(ORCHESTRA_DIR),
                env=env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except OSError as e:
            self._error(500, f"Failed to spawn orchestra: {e}")
            return

        # Write meta.json for active-runs tracking
        repo_path = body.get("repo_path", "")
        task_count = len(data.get("tasks", []))
        meta = {"repo_path": repo_path, "pid": proc.pid, "source": "workspace",
                "task_name": f"{task_count} tasks", "started_at": int(time.time())}
        (log_dir / "meta.json").write_text(json.dumps(meta))

        # Write metadata.json with repo and trigger info
        started_at_iso = datetime.now(timezone.utc).isoformat()
        metadata = {
            "repo_path": str(tasks_json_path.parent),
            "tasks_file": str(tasks_json_path),
            "started_at": started_at_iso,
            "triggered_from": "workspace"
        }
        (log_dir / "metadata.json").write_text(json.dumps(metadata, indent=2))

        self._json_status(202, {
            "run_id": run_id,
            "log_dir": str(log_dir),
            "task_count": task_count,
        })

    def _api_workspace_pipeline_run(self):
        """POST /api/workspace/pipeline/run — run a pipeline.json file."""
        body = self._read_body_json()
        if body is None:
            return
        pipeline_path_str = body.get("pipeline_path")
        if not pipeline_path_str:
            self._error(400, "Missing 'pipeline_path' field")
            return
        pipeline_path = _validate_workspace_path(pipeline_path_str)
        if pipeline_path is None:
            self._error(400, "Invalid pipeline_path")
            return
        if not pipeline_path.is_file():
            self._error(400, f"Pipeline file does not exist: {pipeline_path}")
            return

        # Validate pipeline JSON
        try:
            pipeline_data = json.loads(pipeline_path.read_text())
            if "stages" not in pipeline_data:
                self._error(400, "Pipeline JSON must have 'stages' array")
                return
        except json.JSONDecodeError as e:
            self._error(400, f"Invalid JSON: {e}")
            return

        max_parallel = body.get("max_parallel", 3)
        if not isinstance(max_parallel, int) or max_parallel < 1 or max_parallel > 50:
            self._error(400, "max_parallel must be an integer between 1 and 50")
            return

        run_id = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + "-" + uuid.uuid4().hex[:6]
        log_dir = self.logs_dir / run_id
        log_dir.mkdir(parents=True, exist_ok=True)

        # Use orchestra-pipeline binary
        pipeline_bin = SCRIPT_DIR / "orchestra-pipeline"
        if not pipeline_bin.exists():
            self._error(500, "orchestra-pipeline binary not found")
            return

        # Pass LOGS_BASE so orchestra-pipeline writes state file to our logs directory
        env = {**os.environ, "LOGS_BASE": str(self.logs_dir), "MAX_PARALLEL": str(max_parallel)}
        try:
            proc = subprocess.Popen(
                [str(pipeline_bin), str(pipeline_path)],
                cwd=str(pipeline_path.parent),
                env=env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except OSError as e:
            self._error(500, f"Failed to spawn pipeline: {e}")
            return

        # Write meta.json for active-runs tracking
        pipeline_name = pipeline_data.get("name", pipeline_path.stem)
        stage_count = len(pipeline_data.get("stages", []))
        meta = {
            "repo_path": str(pipeline_path.parent),
            "pid": proc.pid,
            "source": "pipeline",
            "task_name": f"Pipeline: {pipeline_name} ({stage_count} stages)",
            "started_at": int(time.time()),
            "pipeline_path": str(pipeline_path),
        }
        (log_dir / "meta.json").write_text(json.dumps(meta))

        # Write metadata.json
        started_at_iso = datetime.now(timezone.utc).isoformat()
        metadata = {
            "repo_path": str(pipeline_path.parent),
            "pipeline_file": str(pipeline_path),
            "pipeline_name": pipeline_name,
            "started_at": started_at_iso,
            "triggered_from": "workspace",
        }
        (log_dir / "metadata.json").write_text(json.dumps(metadata, indent=2))

        self._json_status(202, {
            "run_id": run_id,
            "log_dir": str(log_dir),
            "pipeline": pipeline_name,
            "stage_count": stage_count,
        })

    def _api_workspace_active_runs(self):
        """GET /api/workspace/active-runs?repo_path=... — running runs for a repo."""
        parsed = urlparse(self.path)
        qs = parse_qs(parsed.query)
        repo_path_str = (qs.get("repo_path") or [""])[0]

        active = []
        now = int(time.time())
        if not self.logs_dir.is_dir():
            self._json({"runs": []})
            return

        for run_dir in sorted(self.logs_dir.iterdir(), reverse=True):
            if not run_dir.is_dir():
                continue
            state_file = run_dir / "state.json"
            meta_file = run_dir / "meta.json"
            if not state_file.exists():
                continue

            # Filter by repo_path if provided
            if repo_path_str and meta_file.exists():
                try:
                    meta = json.loads(meta_file.read_text())
                    if meta.get("repo_path", "") != repo_path_str:
                        continue
                except Exception:
                    continue
            elif repo_path_str and not meta_file.exists():
                continue

            try:
                state = json.loads(state_file.read_text())
            except Exception:
                continue

            tasks = state.get("tasks", [])
            counts = {"total": len(tasks), "running": 0, "pending": 0, "done": 0, "failed": 0}
            for t in tasks:
                st = t.get("status", "pending")
                if st in counts:
                    counts[st] += 1

            # Only include runs that are still active (running or pending tasks)
            if counts["running"] == 0 and counts["pending"] == 0:
                continue

            started_at = state.get("started_at", 0)
            elapsed = now - int(started_at) if started_at else 0

            meta_data = {}
            if meta_file.exists():
                try:
                    meta_data = json.loads(meta_file.read_text())
                except Exception:
                    pass

            active.append({
                "run_id": run_dir.name,
                "task_name": meta_data.get("task_name", run_dir.name),
                "repo_path": meta_data.get("repo_path", ""),
                "started_at": started_at,
                "elapsed_seconds": elapsed,
                "task_counts": counts,
                "pid": meta_data.get("pid"),
            })

        self._json({"runs": active})

    def _api_workspace_run_cancel(self, run_id):
        """POST /api/workspace/runs/{id}/cancel — kill a running orchestra process."""
        if not RUN_ID_RE.match(run_id):
            self._error(400, "Invalid run ID format")
            return
        run_dir = self.logs_dir / run_id
        meta_file = run_dir / "meta.json"
        if not meta_file.exists():
            self._error(404, "No meta.json for this run")
            return
        try:
            meta = json.loads(meta_file.read_text())
        except Exception:
            self._error(500, "Failed to read meta.json")
            return
        pid = meta.get("pid")
        if not pid:
            self._error(400, "No PID recorded for this run")
            return
        try:
            pgid = os.getpgid(pid)
            os.killpg(pgid, signal.SIGTERM)
        except ProcessLookupError:
            pass  # already gone
        except Exception as e:
            self._error(500, f"Failed to kill process: {e}")
            return
        self._json({"cancelled": True, "run_id": run_id})

    # ── Pipeline-mapping endpoints ─────────────────────────────────────

    def _validate_mapping_id(self, mapping_id: str) -> bool:
        if not MAPPING_ID_RE.match(mapping_id):
            self._error(400, "Invalid mapping ID format")
            return False
        return True

    def _api_mapping_create(self):
        """POST /api/pipeline-mapping/create — create a new mapping session.
        
        Accepts either:
        - tasks_file: single file path (backward compatible)
        - tasks_files: array of file paths (new, multiple files)
        """
        body = self._read_body_json()
        if body is None:
            return

        # Support both single file and multiple files
        tasks_file = body.get("tasks_file")
        tasks_files = body.get("tasks_files")
        pipeline_template = body.get("pipeline_template")
        
        # Normalize to array
        if tasks_files:
            file_paths = tasks_files if isinstance(tasks_files, list) else [tasks_files]
        elif tasks_file:
            file_paths = [tasks_file]
        else:
            self._error(400, "Missing 'tasks_file' or 'tasks_files' field")
            return
            
        if not pipeline_template:
            self._error(400, "Missing 'pipeline_template' field")
            return

        # Load and merge tasks from all files
        all_tasks = []
        loaded_files = []
        for fp in file_paths:
            try:
                tasks_path = _validate_workspace_path(fp)
            except ValueError as exc:
                self._error(400, str(exc))
                return
            tasks_data, err = _load_tasks_file(tasks_path)
            if err:
                self._error(400, f"Tasks file error ({fp}): {err}")
                return
            
            # Add source file to each task for tracking
            for t in tasks_data.get("tasks", []):
                task_entry = {
                    "id": t.get("id", ""),
                    "name": t.get("name", ""),
                    "model": t.get("model", ""),
                    "agents": t.get("agents", ""),
                    "skills": t.get("skills", ""),
                    "status": t.get("status", "pending"),
                    "source_file": str(tasks_path),
                }
                all_tasks.append(task_entry)
            loaded_files.append(str(tasks_path))

        # Validate pipeline template
        if pipeline_template not in VALID_PIPELINE_TEMPLATES:
            self._error(400, f"Invalid pipeline_template: must be one of {', '.join(sorted(VALID_PIPELINE_TEMPLATES))}")
            return

        # Build stage list - handle custom template specially
        custom_stages = body.get("custom_stages")  # Array of stage names for custom pipeline
        stages = []
        
        if pipeline_template == "custom":
            # Use provided custom stages or fallback to default
            if custom_stages and isinstance(custom_stages, list):
                stage_names = [s for s in custom_stages if isinstance(s, str)]
            else:
                # Fallback to feature template stages
                stage_names = ["Plan", "Implement", "Review"]
            for i, name in enumerate(stage_names):
                stages.append({"index": i, "name": name})
        else:
            # Load stages from template file
            template_path = ORCHESTRA_DIR / "templates" / "pipelines" / f"{pipeline_template}.json"
            if not template_path.is_file():
                self._error(404, f"Pipeline template not found: {pipeline_template}")
                return
            try:
                pipeline_data = json.loads(template_path.read_text())
            except (json.JSONDecodeError, ValueError):
                self._error(500, "Corrupt pipeline template file")
                return
            if not isinstance(pipeline_data.get("stages"), list):
                self._error(500, "Pipeline template missing 'stages' array")
                return
            for i, stage in enumerate(pipeline_data["stages"]):
                stages.append({
                    "index": i,
                    "name": stage.get("name", f"Stage {i}"),
                })

        # Auto-assign tasks to stages
        auto_assignments = _auto_assign_tasks_to_stages(all_tasks, [s["name"] for s in stages])

        mapping_id = str(uuid.uuid4())
        mapping_state = {
            "mapping_id": mapping_id,
            "tasks_file": loaded_files[0] if len(loaded_files) == 1 else loaded_files[0],  # Backward compat
            "tasks_files": loaded_files,  # New field with all files
            "pipeline_template": pipeline_template,
            "custom_stages": [s["name"] for s in stages] if pipeline_template == "custom" else [],
            "stages": stages,  # Store stages for easy retrieval
            "assignments": auto_assignments,
            "batches": [],
        }

        with _MAPPINGS_LOCK:
            _save_mapping(mapping_id, mapping_state)

        if self.broker:
            self.broker.broadcast("mapping_created", {
                "mapping_id": mapping_id,
                "pipeline_template": pipeline_template,
                "task_count": len(all_tasks),
                "stage_count": len(stages),
            })

        self._json_status(201, {
            "mapping_id": mapping_id,
            "tasks": all_tasks,
            "stages": stages,
            "auto_assignments": auto_assignments,
            "tasks_files": loaded_files,
        })

    def _api_mapping_get(self, mapping_id: str):
        """GET /api/pipeline-mapping/<mapping_id> — get current mapping state."""
        if not self._validate_mapping_id(mapping_id):
            return

        with _MAPPINGS_LOCK:
            mapping, err = _load_mapping(mapping_id)
        if err:
            self._error(404, err)
            return

        # Reload tasks from file for current state
        tasks_path = Path(mapping["tasks_file"])
        tasks_data, terr = _load_tasks_file(tasks_path)
        tasks = []
        if tasks_data:
            for t in tasks_data["tasks"]:
                tasks.append({
                    "id": t.get("id", ""),
                    "name": t.get("name", ""),
                    "model": t.get("model", ""),
                    "agents": t.get("agents", ""),
                    "skills": t.get("skills", ""),
                    "status": t.get("status", "pending"),
                })

        # Reload pipeline stages - prefer stored stages for custom pipelines
        pipeline_template = mapping.get("pipeline_template", "feature")
        stages = mapping.get("stages", [])
        
        if not stages:
            # Fallback: load from template file
            template_path = ORCHESTRA_DIR / "templates" / "pipelines" / f"{pipeline_template}.json"
            if template_path.is_file():
                try:
                    pipeline_data = json.loads(template_path.read_text())
                    for i, stage in enumerate(pipeline_data.get("stages", [])):
                        stages.append({
                            "index": i,
                            "name": stage.get("name", f"Stage {i}"),
                        })
                except (json.JSONDecodeError, ValueError):
                    pass

        resp = {
            "mapping_id": mapping_id,
            "tasks_file": mapping["tasks_file"],
            "pipeline_template": mapping["pipeline_template"],
            "assignments": mapping.get("assignments", {}),
            "tasks": tasks,
            "stages": stages,
        }
        if terr:
            resp["tasks_file_error"] = terr

        self._json(resp)

    def _api_mapping_assign(self, mapping_id: str):
        """PUT /api/pipeline-mapping/<mapping_id>/assign — assign task to stage."""
        if not self._validate_mapping_id(mapping_id):
            return

        body = self._read_body_json()
        if body is None:
            return

        task_id = body.get("task_id")
        stage_index = body.get("stage_index")
        if not task_id or not isinstance(task_id, str):
            self._error(400, "Missing or invalid 'task_id'")
            return
        if not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task_id format")
            return
        if stage_index is None or not isinstance(stage_index, int) or stage_index < 0:
            self._error(400, "Missing or invalid 'stage_index'")
            return

        with _MAPPINGS_LOCK:
            mapping, err = _load_mapping(mapping_id)
            if err:
                self._error(404, err)
                return

            # Validate task_id exists in any of the tasks files
            # Check tasks_files array first (multi-file support), fall back to single tasks_file
            tasks_files = mapping.get("tasks_files") or [mapping.get("tasks_file")]
            if not tasks_files or not any(tasks_files):
                self._error(500, "No tasks file configured in mapping")
                return

            task_found = False
            for tf in tasks_files:
                if not tf:
                    continue
                tasks_data, terr = _load_tasks_file(Path(tf))
                if terr:
                    continue  # Try next file
                task_ids = {t.get("id") for t in tasks_data.get("tasks", [])}
                if task_id in task_ids:
                    task_found = True
                    break

            if not task_found:
                self._error(404, f"Task '{task_id}' not found in any tasks file")
                return

            # Validate stage_index exists in template
            # Use stored stages for custom pipelines, otherwise load from file
            pipeline_template = mapping.get("pipeline_template", "feature")
            if pipeline_template == "custom" and mapping.get("stages"):
                num_stages = len(mapping["stages"])
            else:
                template_path = ORCHESTRA_DIR / "templates" / "pipelines" / f"{pipeline_template}.json"
                try:
                    pipeline_data = json.loads(template_path.read_text())
                except Exception:
                    self._error(500, "Cannot read pipeline template")
                    return
                num_stages = len(pipeline_data.get("stages", []))
            if stage_index >= num_stages:
                self._error(400, f"stage_index {stage_index} out of range (0-{num_stages - 1})")
                return

            # Enforce one-to-one: reject if task is already assigned
            assignments = mapping.get("assignments", {})
            if task_id in assignments:
                self._error(409, f"Task '{task_id}' is already assigned to stage {assignments[task_id]}. Unassign first.")
                return

            assignments[task_id] = stage_index
            mapping["assignments"] = assignments
            _save_mapping(mapping_id, mapping)

        if self.broker:
            self.broker.broadcast("task_assigned", {
                "mapping_id": mapping_id,
                "task_id": task_id,
                "stage_index": stage_index,
            })

        self._json({"assigned": True, "task_id": task_id, "stage_index": stage_index})

    def _api_mapping_unassign(self, mapping_id: str, task_id: str):
        """DELETE /api/pipeline-mapping/<mapping_id>/assign/<task_id> — unassign task."""
        if not self._validate_mapping_id(mapping_id):
            return
        if not WORKSPACE_TASK_ID_RE.match(task_id):
            self._error(400, "Invalid task ID format")
            return

        with _MAPPINGS_LOCK:
            mapping, err = _load_mapping(mapping_id)
            if err:
                self._error(404, err)
                return

            assignments = mapping.get("assignments", {})
            if task_id not in assignments:
                self._error(404, f"Task '{task_id}' is not assigned to any stage")
                return

            removed_stage = assignments.pop(task_id)
            mapping["assignments"] = assignments
            _save_mapping(mapping_id, mapping)

        if self.broker:
            self.broker.broadcast("task_unassigned", {
                "mapping_id": mapping_id,
                "task_id": task_id,
                "stage_index": removed_stage,
            })

        self._json({"unassigned": True, "task_id": task_id, "stage_index": removed_stage})

    def _api_mapping_execute(self, mapping_id: str):
        """POST /api/pipeline-mapping/<mapping_id>/execute — run mapped tasks as pipeline."""
        if not self._validate_mapping_id(mapping_id):
            return

        body = self._read_body_json()
        if body is None:
            return

        task_ids = body.get("task_ids")
        if not isinstance(task_ids, list) or not task_ids:
            self._error(400, "Missing or empty 'task_ids' array")
            return
        if len(task_ids) > 100:
            self._error(400, "'task_ids' must contain at most 100 entries")
            return
        for tid in task_ids:
            if not isinstance(tid, str) or not WORKSPACE_TASK_ID_RE.match(tid):
                self._error(400, f"Invalid task_id format: {tid!r}")
                return

        # Phase 1: Read mapping state under lock (fast)
        with _MAPPINGS_LOCK:
            mapping, err = _load_mapping(mapping_id)
        if err:
            self._error(404, err)
            return

        assignments = mapping.get("assignments", {})

        # Validate all requested task_ids are assigned
        unassigned = [tid for tid in task_ids if tid not in assignments]
        if unassigned:
            self._error(400, f"Tasks not assigned to any stage: {', '.join(unassigned)}")
            return

        # Phase 2: Load data and generate pipeline files (no lock needed)
        tasks_data, terr = _load_tasks_file(Path(mapping["tasks_file"]))
        if terr:
            self._error(500, f"Cannot read tasks file: {terr}")
            return
        tasks_by_id = {t["id"]: t for t in tasks_data["tasks"] if "id" in t}

        # Get stages - use stored stages for custom, otherwise load from file
        pipeline_template = mapping.get("pipeline_template", "feature")
        if pipeline_template == "custom" and mapping.get("stages"):
            # Use stored stages for custom pipelines (simpler format)
            template_stages = mapping["stages"]
            halt_on_failure = True  # Default for custom
            aggregate = False
        else:
            template_path = ORCHESTRA_DIR / "templates" / "pipelines" / f"{pipeline_template}.json"
            try:
                pipeline_data = json.loads(template_path.read_text())
            except Exception:
                self._error(500, "Cannot read pipeline template")
                return
            template_stages = pipeline_data.get("stages", [])
            halt_on_failure = pipeline_data.get("halt_on_stage_failure", True)
            aggregate = pipeline_data.get("aggregate", False)

        # Group selected tasks by stage_index
        stage_tasks: dict[int, list[dict]] = {}
        for tid in task_ids:
            sidx = assignments[tid]
            if sidx not in stage_tasks:
                stage_tasks[sidx] = []
            task_obj = tasks_by_id.get(tid)
            if task_obj:
                stage_tasks[sidx].append(task_obj)

        # Build filtered pipeline JSON — only stages with mapped tasks
        filtered_stages = []
        for sidx in sorted(stage_tasks.keys()):
            if sidx >= len(template_stages):
                continue
            source_stage = template_stages[sidx]
            # Write a temporary tasks file per stage
            stage_tasks_file = f"mapping-{mapping_id}-stage-{sidx}.json"
            stage_tasks_data = {"tasks": stage_tasks[sidx]}
            stage_tasks_path = self.logs_dir / stage_tasks_file
            stage_tasks_path.write_text(json.dumps(stage_tasks_data, indent=2))

            # Use a sensible default for mapper-generated pipelines (5 parallel tasks)
            # Template max_parallel values are for template-specific task files,
            # not for user-generated task files from the mapper
            max_par = 5
            filtered_stages.append({
                "name": source_stage.get("name", f"Stage {sidx}"),
                "tasks": [{"file": str(stage_tasks_path), "max_parallel": max_par}],
                "pass_outputs_to_next": source_stage.get("pass_outputs_to_next", False),
            })

        if not filtered_stages:
            self._error(400, "No valid stages with assigned tasks")
            return

        run_id = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + "-" + uuid.uuid4().hex[:6]
        pipeline_id = f"mapping-{mapping_id[:8]}-{run_id}"
        generated_pipeline = {
            "name": f"Mapping: {pipeline_template} (batch)",
            "halt_on_stage_failure": halt_on_failure,
            "stages": filtered_stages,
            "aggregate": aggregate,
        }
        pipeline_file = self.logs_dir / f"{pipeline_id}.json"
        pipeline_file.write_text(json.dumps(generated_pipeline, indent=2))

        # Phase 3: Spawn pipeline process
        pipeline_bin = SCRIPT_DIR / "orchestra-pipeline"
        if not pipeline_bin.exists():
            self._error(500, "orchestra-pipeline binary not found")
            return

        log_dir = self.logs_dir / run_id
        log_dir.mkdir(parents=True, exist_ok=True)

        env = {**os.environ, "LOGS_BASE": str(self.logs_dir), "MAX_PARALLEL": "5"}
        try:
            proc = subprocess.Popen(
                [str(pipeline_bin), str(pipeline_file)],
                cwd=str(Path(mapping["tasks_file"]).parent),
                env=env,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        except OSError as e:
            self._error(500, f"Failed to spawn pipeline: {e}")
            return

        # Phase 4: Record batch only after Popen succeeds (under lock)
        batch_entry = {
            "run_id": run_id,
            "pipeline_id": pipeline_id,
            "task_ids": task_ids,
            "status": "running",
            "started_at": datetime.now(timezone.utc).isoformat(),
        }
        with _MAPPINGS_LOCK:
            mapping, _ = _load_mapping(mapping_id)
            if mapping:
                mapping.setdefault("batches", []).append(batch_entry)
                _save_mapping(mapping_id, mapping)

        # Write meta.json for tracking
        meta = {
            "repo_path": str(Path(mapping["tasks_file"]).parent),
            "pid": proc.pid,
            "source": "pipeline-mapping",
            "task_name": f"Mapping: {mapping['pipeline_template']} ({len(task_ids)} tasks)",
            "started_at": int(time.time()),
            "pipeline_path": str(pipeline_file),
            "mapping_id": mapping_id,
        }
        (log_dir / "meta.json").write_text(json.dumps(meta))

        # Start a background thread to monitor batch completion
        threading.Thread(
            target=self._monitor_mapping_batch,
            args=(mapping_id, run_id, proc.pid),
            daemon=True,
        ).start()

        if self.broker:
            self.broker.broadcast("batch_started", {
                "mapping_id": mapping_id,
                "run_id": run_id,
                "pipeline_id": pipeline_id,
                "task_ids": task_ids,
            })

        self._json_status(202, {
            "run_id": run_id,
            "pipeline_id": pipeline_id,
        })

    @staticmethod
    def _monitor_mapping_batch(mapping_id: str, run_id: str, pid: int):
        """Background thread: wait for pipeline process to exit, then update batch status."""
        exit_code = -1
        try:
            _, raw_status = os.waitpid(pid, 0)
            exit_code = os.waitstatus_to_exitcode(raw_status)
        except ChildProcessError:
            exit_code = -1
        except OSError:
            # Process already reaped or not a child — poll until gone
            while True:
                try:
                    os.kill(pid, 0)
                    time.sleep(5)
                except OSError:
                    break

        final_status = "completed" if exit_code == 0 else "failed"

        with _MAPPINGS_LOCK:
            mapping, err = _load_mapping(mapping_id)
            if mapping:
                for batch in mapping.get("batches", []):
                    if batch["run_id"] == run_id:
                        batch["status"] = final_status
                        batch["exit_code"] = exit_code
                        batch["completed_at"] = datetime.now(timezone.utc).isoformat()
                        break
                _save_mapping(mapping_id, mapping)

        # SSE event — broker is a class var so access via the handler class
        if OrchestraHandler.broker:
            OrchestraHandler.broker.broadcast("batch_completed", {
                "mapping_id": mapping_id,
                "run_id": run_id,
                "status": final_status,
                "exit_code": exit_code,
            })

    def _api_mapping_history(self, mapping_id: str):
        """GET /api/pipeline-mapping/<mapping_id>/history — past batch executions."""
        if not self._validate_mapping_id(mapping_id):
            return

        with _MAPPINGS_LOCK:
            mapping, err = _load_mapping(mapping_id)
        if err:
            self._error(404, err)
            return

        self._json({"mapping_id": mapping_id, "batches": mapping.get("batches", [])})

    # ── Response helpers ───────────────────────────────────────────────

    def _json_status(self, status: int, data):
        body = json.dumps(data, default=str).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def _json(self, data):
        body = json.dumps(data, default=str).encode()
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def _serve_file(self, file_path: Path, content_type: str):
        if not file_path.exists():
            self._not_found()
            return
        data = file_path.read_bytes()
        self.send_response(200)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(data)

    def _api_auth_register(self):
        """POST /api/auth/register — create a new user account."""
        body = self._read_body_json()
        if body is None:
            return
        email = body.get("email", "")
        password = body.get("password", "")
        if not email or not password:
            self._error(400, "Missing 'email' or 'password'")
            return
        try:
            user = create_user(email, password)
        except ValueError as exc:
            if "already exists" in str(exc):
                self._error(409, str(exc))
            else:
                self._error(400, str(exc))
            return
        resp = json.dumps(user).encode()
        self.send_response(201)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(resp)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(resp)

    def _api_auth_login(self):
        """POST /api/auth/login — authenticate and return a JWT."""
        body = self._read_body_json()
        if body is None:
            return
        email = body.get("email", "")
        password = body.get("password", "")
        if not email or not password:
            self._error(400, "Missing 'email' or 'password'")
            return
        user = find_user_by_email(email)
        if user is None or not _verify_password(password, user.get("password_hash", "")):
            self._error(401, "Invalid email or password")
            return
        token = generate_token(user["id"], user["email"])
        resp = json.dumps({"token": token}).encode()
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(resp)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(resp)

    def _not_found(self):
        body = json.dumps({"error": "Not found"}).encode()
        self.send_response(404)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def _error(self, code, msg):
        body = json.dumps({"error": msg}).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, fmt, *args):
        """Suppress default access logs."""
        pass


# ---------------------------------------------------------------------------
# JWT helpers — HS256, stdlib only (hmac + base64)
# ---------------------------------------------------------------------------

_JWT_HEADER = base64.urlsafe_b64encode(
    json.dumps({"alg": "HS256", "typ": "JWT"}, separators=(",", ":")).encode()
).rstrip(b"=").decode()


def _jwt_secret() -> bytes:
    """Return the signing secret as bytes; raises RuntimeError if not set."""
    secret = os.environ.get("ORCHESTRA_JWT_SECRET", "")
    if not secret:
        raise RuntimeError(
            "ORCHESTRA_JWT_SECRET environment variable is not set. "
            "Set it to a long random string before starting orchestra-serve."
        )
    return secret.encode()


def _b64url_encode(data: bytes) -> str:
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode()


def _b64url_decode(s: str) -> bytes:
    # Restore padding
    padding = 4 - len(s) % 4
    if padding != 4:
        s += "=" * padding
    return base64.urlsafe_b64decode(s)


def generate_token(user_id: str, email: str) -> str:
    """Return a signed HS256 JWT with a 24-hour expiry.

    Payload claims:
      sub  — user_id
      email — email address
      iat  — issued-at (UTC epoch seconds)
      exp  — expiry (iat + 86400)
    """
    now = int(datetime.now(tz=timezone.utc).timestamp())
    payload = {
        "sub": user_id,
        "email": email,
        "iat": now,
        "exp": now + 86400,
    }
    encoded_payload = _b64url_encode(
        json.dumps(payload, separators=(",", ":")).encode()
    )
    signing_input = f"{_JWT_HEADER}.{encoded_payload}".encode()
    signature = _b64url_encode(
        hmac.new(_jwt_secret(), signing_input, hashlib.sha256).digest()
    )
    return f"{_JWT_HEADER}.{encoded_payload}.{signature}"


def verify_token(token: str) -> dict:
    """Verify an HS256 JWT and return its decoded payload.

    Raises:
      ValueError  — malformed token or invalid signature
      RuntimeError — expired token or ORCHESTRA_JWT_SECRET not set
    """
    parts = token.split(".")
    if len(parts) != 3:
        raise ValueError("Malformed JWT: expected 3 dot-separated parts")

    header_b64, payload_b64, sig_b64 = parts

    # Verify signature
    signing_input = f"{header_b64}.{payload_b64}".encode()
    expected_sig = _b64url_encode(
        hmac.new(_jwt_secret(), signing_input, hashlib.sha256).digest()
    )
    if not hmac.compare_digest(expected_sig, sig_b64):
        raise ValueError("Invalid JWT signature")

    # Decode payload
    try:
        payload = json.loads(_b64url_decode(payload_b64))
    except Exception as exc:
        raise ValueError(f"Malformed JWT payload: {exc}") from exc

    # Check expiry
    exp = payload.get("exp")
    if exp is None:
        raise ValueError("JWT missing 'exp' claim")
    now = int(datetime.now(tz=timezone.utc).timestamp())
    if now >= exp:
        raise RuntimeError("JWT has expired")

    return payload


def main():
    parser = argparse.ArgumentParser(
        description="claude-orchestra web log viewer",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Example:\n  orchestra-serve\n  orchestra-serve --port 8080\n  orchestra-serve --logs-dir /path/to/logs",
    )
    parser.add_argument("--logs-dir", default=None, help="Path to logs directory")
    parser.add_argument("--port", type=int, default=7890, help="Port (default: 7890)")
    parser.add_argument(
        "--host", default="127.0.0.1", help="Host (default: 127.0.0.1)"
    )
    args = parser.parse_args()

    # JWT secret is optional - only required when auth endpoints are used
    # Skip validation if not set (auth features will be unavailable)

    if args.logs_dir:
        logs_dir = Path(args.logs_dir)
    else:
        candidates = [
            ORCHESTRA_DIR / "logs",
            Path.cwd() / "logs",
        ]
        logs_dir = next((p for p in candidates if p.is_dir()), candidates[0])

    OrchestraHandler.logs_dir = logs_dir

    data_dir = logs_dir.parent / "data"
    init_user_store(data_dir)

    broker = SSEBroker()
    OrchestraHandler.broker = broker

    watcher = LogWatcher(logs_dir, broker)
    watcher.start()

    server = ThreadingHTTPServer((args.host, args.port), OrchestraHandler)
    url = f"http://{args.host}:{args.port}"
    print(f"\033[35mclaude-orchestra viewer\033[0m")
    print(f"  URL:      \033[34m{url}\033[0m")
    print(f"  Logs dir: \033[34m{logs_dir}\033[0m")
    print(f"  SSE:      \033[34m{url}/api/events\033[0m")
    print(f"  Ctrl+C to stop")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down.")
        watcher.stop()
        server.server_close()


if __name__ == "__main__":
    main()
