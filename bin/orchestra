#!/usr/bin/env bash
set -eo pipefail

# claude-orchestra — Parallel task orchestrator with ECC intelligence
# Runs multiple Claude Code sessions from a tasks JSON file in parallel,
# with optional agent/skill/hook injection from Everything-Claude-Code.

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
BIN_DIR="$SCRIPT_DIR"
ORCHESTRA_DIR="$(dirname "$BIN_DIR")"
LIB_DIR="$ORCHESTRA_DIR/lib"

# Load shared libraries
source "$LIB_DIR/config.sh"
source "$LIB_DIR/ecc-adapter.sh"
source "$LIB_DIR/prompt-builder.sh"

load_config

# When using Claude Max subscription (OAuth), clear any custom API base URL
# that might point to a proxy. Claude CLI with OAuth needs the default endpoint.
if [[ "$(claude auth status 2>/dev/null | python3 -c 'import json,sys; print(json.load(sys.stdin).get("authMethod",""))' 2>/dev/null)" == "oauth_token" ]]; then
    unset ANTHROPIC_BASE_URL
    unset ANTHROPIC_API_KEY
fi

# Parse arguments: [--name NAME] [tasks_file]
RUN_NAME="${RUN_NAME:-}"
TASKS_FILE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)
            RUN_NAME="$2"
            shift 2
            ;;
        --name=*)
            RUN_NAME="${1#--name=}"
            shift
            ;;
        *)
            if [[ -z "$TASKS_FILE" ]]; then
                TASKS_FILE="$1"
            fi
            shift
            ;;
    esac
done
TASKS_FILE="${TASKS_FILE:-tasks.json}"

# Auto-convert .md -> .json
if [[ "$TASKS_FILE" == *.md ]]; then
    MD_FILE="$TASKS_FILE"
    TASKS_FILE="${TASKS_FILE%.md}.json"
    echo -e "\033[0;36m[orchestra]\033[0m Converting $(basename "$MD_FILE") -> $(basename "$TASKS_FILE")"
    "$BIN_DIR/orchestra-convert" "$MD_FILE" "$TASKS_FILE"
else
    # Auto-convert .md -> .json if md is newer or json missing
    MD_FILE="${TASKS_FILE%.json}.md"
    if [[ -f "$MD_FILE" ]] && { [[ ! -f "$TASKS_FILE" ]] || [[ "$MD_FILE" -nt "$TASKS_FILE" ]]; }; then
        echo -e "\033[0;36m[orchestra]\033[0m Converting $(basename "$MD_FILE") -> $(basename "$TASKS_FILE")"
        "$BIN_DIR/orchestra-convert" "$MD_FILE" "$TASKS_FILE"
    fi
fi

# Resolve LOG_DIR
if [[ -z "$LOG_DIR" ]]; then
    if [[ -n "$RUN_NAME" ]]; then
        LOG_DIR="./logs/${RUN_NAME}"
    else
        LOG_DIR="./logs/$(date +%Y-%m-%d_%H-%M-%S)"
    fi
fi
[[ "$LOG_DIR" != /* ]] && LOG_DIR="$(pwd)/${LOG_DIR#./}"

# CLI command resolution
if [[ -z "$CLAUDE_CMD" ]]; then
    if [[ "$MODE" == "interactive" ]] && command -v happy &>/dev/null; then
        CLAUDE_CMD="happy"
    else
        CLAUDE_CMD="claude"
    fi
fi

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'

mkdir -p "$LOG_DIR"

log() { echo -e "${CYAN}[orchestra $(date +%H:%M:%S)]${NC} $*"; }
err() { echo -e "${RED}[error]${NC} $*" >&2; }

# Check dependencies
if ! command -v "$CLAUDE_CMD" &>/dev/null; then
    err "$CLAUDE_CMD CLI not found in PATH"
    exit 1
fi
if ! command -v jq &>/dev/null; then
    err "jq required. Install: brew install jq"
    exit 1
fi

# Validate tasks file
if [[ ! -f "$TASKS_FILE" ]]; then
    err "Tasks file not found: $TASKS_FILE"
    exit 1
fi

# Initialize ECC adapter
ecc_init

TASK_COUNT=$(jq '.tasks | length' "$TASKS_FILE")
PENDING_TASKS=$(jq '[.tasks[] | select(.status == "pending")] | length' "$TASKS_FILE")

log "Loaded ${BLUE}$TASK_COUNT${NC} tasks (${YELLOW}$PENDING_TASKS pending${NC})"
log "Max parallel: ${BLUE}$MAX_PARALLEL${NC}"
log "Mode: ${BLUE}$MODE${NC}"
log "CLI: ${BLUE}$CLAUDE_CMD${NC}"
log "Logs: ${BLUE}$LOG_DIR${NC}"
echo ""

# Write state.json for dashboard (enhanced with ECC metadata)
write_state() {
    local ecc_status="false"
    ecc_available && ecc_status="true"

    jq --arg logdir "$LOG_DIR" --arg start "$ORCHESTRATOR_START" \
       --argjson ecc "$ecc_status" '{
        log_dir: $logdir,
        started_at: ($start | tonumber),
        ecc_enabled: $ecc,
        total_elapsed_seconds: ([.tasks[] | .elapsed_seconds // 0] | add // 0),
        tasks: [.tasks[] | {
            id: .id,
            name: .name,
            status: .status,
            model: (.model // "opus"),
            agents: (.agents // null),
            skills: (.skills // null),
            hooks: (.hooks // null),
            cost_usd: (.cost_usd // null),
            workdir: (.workdir // null),
            started_at: (.started_at // null),
            finished_at: (.finished_at // null),
            elapsed_seconds: (.elapsed_seconds // null)
        }]
    }' "$TASKS_FILE" > "$LOG_DIR/state.json" 2>/dev/null || true
}

ORCHESTRATOR_START=$(date +%s)

# Interactive mode: launch each task as a worktree + tmux session
if [[ "$MODE" == "interactive" ]]; then
    count=0
    while IFS= read -r task_json; do
        [[ -z "$task_json" ]] && continue
        [[ $count -ge $MAX_PARALLEL ]] && break

        id=$(echo "$task_json" | jq -r '.id')
        name=$(echo "$task_json" | jq -r '.name')
        prompt=$(echo "$task_json" | jq -r '.prompt')
        workdir=$(echo "$task_json" | jq -r '.workdir // "."')
        workdir="${workdir/#\~/$HOME}"
        model=$(echo "$task_json" | jq -r '.model // "opus"')
        effort=$(echo "$task_json" | jq -r '.effort // "high"')

        log "Launching interactive: ${GREEN}$name${NC}"

        (
            cd "$workdir"
            "$CLAUDE_CMD" --worktree "$id" --tmux \
                --model "$model" --effort "$effort" \
                --name "$name" \
                "$prompt"
        ) &

        update_task_status "$id" "running"
        count=$(( count + 1 ))
        sleep 1
    done < <(jq -c '.tasks[] | select(.status == "pending")' "$TASKS_FILE")

    log "Launched $count interactive sessions. Use tmux to switch between them."
    exit 0
fi

# Track PIDs
declare -A PIDS        # pid -> task_id
declare -A TASK_NAMES  # task_id -> name
declare -A TASK_STARTS # task_id -> start time

update_task_status() {
    local task_id="$1" new_status="$2"
    local tmp=$(mktemp)
    jq --arg id "$task_id" --arg s "$new_status" \
        '(.tasks[] | select(.id == $id)).status = $s' \
        "$TASKS_FILE" > "$tmp" && mv "$tmp" "$TASKS_FILE"
}

update_task_cost() {
    local task_id="$1" cost="$2"
    local tmp=$(mktemp)
    jq --arg id "$task_id" --argjson cost "$cost" \
        '(.tasks[] | select(.id == $id)).cost_usd = $cost' \
        "$TASKS_FILE" > "$tmp" && mv "$tmp" "$TASKS_FILE"
}

update_task_started_at() {
    local task_id="$1" started="$2"
    local tmp=$(mktemp)
    jq --arg id "$task_id" --argjson t "$started" \
        '(.tasks[] | select(.id == $id)).started_at = $t' \
        "$TASKS_FILE" > "$tmp" && mv "$tmp" "$TASKS_FILE"
}

update_task_finished_at() {
    local task_id="$1" finished="$2" elapsed="$3"
    local tmp=$(mktemp)
    jq --arg id "$task_id" --argjson f "$finished" --argjson e "$elapsed" \
        '(.tasks[] | select(.id == $id)).finished_at = $f |
         (.tasks[] | select(.id == $id)).elapsed_seconds = $e' \
        "$TASKS_FILE" > "$tmp" && mv "$tmp" "$TASKS_FILE"
}

extract_task_cost() {
    local stream_file="$1"
    [[ -f "$stream_file" ]] || return
    python3 -c "
import json, sys
try:
    for line in open(sys.argv[1]):
        line = line.strip()
        if not line: continue
        try:
            ev = json.loads(line)
            if ev.get('type') == 'result' and 'total_cost_usd' in ev:
                print(ev['total_cost_usd'])
                break
        except: pass
except: pass
" "$stream_file" 2>/dev/null || true
}

# Enhanced launch_task with ECC integration
launch_task() {
    local task_json="$1"
    local id=$(echo "$task_json" | jq -r '.id')
    local name=$(echo "$task_json" | jq -r '.name')
    local prompt=$(echo "$task_json" | jq -r '.prompt')
    local workdir=$(echo "$task_json" | jq -r '.workdir // "."')
    workdir="${workdir/#\~/$HOME}"
    local allowed_tools=$(echo "$task_json" | jq -r '.allowedTools // ""')

    # ECC-aware model resolution (agent model > task model > global default)
    local model
    model=$(ecc_get_model_override "$task_json")
    local effort=$(echo "$task_json" | jq -r ".effort // \"$EFFORT\"")

    # Build compound system prompt (user + agents + skills)
    local compound_prompt
    compound_prompt=$(ecc_build_system_prompt "$task_json")

    # Resolve hook profile
    local hook_profile
    hook_profile=$(ecc_get_hook_profile "$task_json")

    local log_file="$LOG_DIR/${id}.log"
    local out_file="$LOG_DIR/${id}.output.md"
    local stream_file="$LOG_DIR/${id}.stream.jsonl"

    # Enhanced logging with ECC metadata
    local agents_info=$(echo "$task_json" | jq -r '.agents // "none"')
    local skills_info=$(echo "$task_json" | jq -r '.skills // "none"')
    log "Starting: ${GREEN}$name${NC} (model=${BLUE}$model${NC}, agents=${MAGENTA}$agents_info${NC}, skills=${MAGENTA}$skills_info${NC}, hooks=$hook_profile)"

    local cmd=("$CLAUDE_CMD" --print --verbose --model "$model" --output-format stream-json --dangerously-skip-permissions)

    # Only add --effort if CLI supports it (check once, cache result)
    if [[ -z "${_EFFORT_SUPPORTED:-}" ]]; then
        if "$CLAUDE_CMD" --help 2>&1 | grep -q '\-\-effort'; then
            _EFFORT_SUPPORTED="yes"
        else
            _EFFORT_SUPPORTED="no"
        fi
    fi
    if [[ "$_EFFORT_SUPPORTED" == "yes" && -n "$effort" ]]; then
        cmd+=(--effort "$effort")
    fi

    if [[ -n "$allowed_tools" ]]; then
        cmd+=(--allowedTools $allowed_tools)
    fi
    if [[ -n "$compound_prompt" ]]; then
        cmd+=(--append-system-prompt "$compound_prompt")
    fi

    (
        cd "$workdir"
        export ECC_HOOK_PROFILE="$hook_profile"
        echo "$prompt" | "${cmd[@]}" 2> "$log_file" | tee "$stream_file" | jq -r --unbuffered '
            select(.type == "assistant")
            | .message.content[]? | select(.type == "text") | .text // empty
        ' > "$out_file"
    ) &
    local pid=$!

    PIDS[$pid]="$id"
    TASK_NAMES[$id]="$name"
    TASK_STARTS[$id]=$(date +%s)
    update_task_status "$id" "running"
    update_task_started_at "$id" "${TASK_STARTS[$id]}"
    write_state
}

# Reap completed tasks
reap() {
    [[ ${#PIDS[@]} -eq 0 ]] && return
    for pid in "${!PIDS[@]}"; do
        if ! kill -0 "$pid" 2>/dev/null; then
            local id="${PIDS[$pid]}"
            local name="${TASK_NAMES[$id]}"
            local start="${TASK_STARTS[$id]}"
            local finished_at=$(date +%s)
            local elapsed=$(( finished_at - start ))
            local mins=$(( elapsed / 60 ))
            local secs=$(( elapsed % 60 ))

            wait "$pid" 2>/dev/null
            local exit_code=$?

            if [[ $exit_code -eq 0 ]]; then
                log "✓ ${GREEN}Completed${NC}: $name (${mins}m${secs}s)"
                update_task_status "$id" "done"
            else
                log "✗ ${RED}Failed${NC}: $name (exit=$exit_code, ${mins}m${secs}s)"
                update_task_status "$id" "failed"
            fi
            update_task_finished_at "$id" "$finished_at" "$elapsed"

            local cost
            cost=$(extract_task_cost "$LOG_DIR/${id}.stream.jsonl")
            if [[ -n "$cost" ]]; then
                update_task_cost "$id" "$cost"
                log "  cost: \$${cost}"
            fi

            unset "PIDS[$pid]"
            write_state
        fi
    done
}

# Cleanup on exit
cleanup() {
    log "Shutting down..."
    for pid in "${!PIDS[@]}"; do
        kill "$pid" 2>/dev/null || true
    done
    wait 2>/dev/null
    log "Done. Logs in: $LOG_DIR"
}
trap cleanup EXIT INT TERM

# Main loop
while true; do
    reap

    running=${#PIDS[@]}

    slots=$(( MAX_PARALLEL - running ))
    if [[ $slots -gt 0 ]]; then
        launched=0
        while IFS= read -r task_json; do
            [[ -z "$task_json" ]] && continue
            launch_task "$task_json"
            launched=$(( launched + 1 ))
            slots=$(( slots - 1 ))
            [[ $slots -le 0 ]] && break
            # Stagger launches to avoid OAuth rate limiting (configurable)
            [[ $launched -gt 0 ]] && sleep "${LAUNCH_DELAY:-2}"
        done < <(jq -c '.tasks[] | select(.status == "pending")' "$TASKS_FILE" | head -n "$slots")
    fi

    remaining=$(jq '[.tasks[] | select(.status == "pending" or .status == "running")] | length' "$TASKS_FILE")
    if [[ $remaining -eq 0 && ${#PIDS[@]} -eq 0 ]]; then
        echo ""
        log "All tasks complete"
        echo ""
        done_count=$(jq '[.tasks[] | select(.status == "done")] | length' "$TASKS_FILE")
        fail_count=$(jq '[.tasks[] | select(.status == "failed")] | length' "$TASKS_FILE")
        log "Results: ${GREEN}$done_count done${NC}, ${RED}$fail_count failed${NC}"
        log "Outputs in: $LOG_DIR/"
        write_state
        break
    fi

    sleep "$POLL_INTERVAL"
done
